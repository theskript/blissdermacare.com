---
export interface Props {
  title: string;
  activeNav?: 'dashboard' | 'calendar' | 'clients' | 'new-appointment' | 'staff' | 'audit' | 'availability';
}
const { title, activeNav } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Bliss Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Cormorant:wght@400;600&display=swap" rel="stylesheet" />
  <!-- Prevent indexing of admin panel -->
  <meta name="robots" content="noindex, nofollow" />
  <!-- Synchronous auth guard — runs before first paint to prevent dashboard flash -->
  <script>
    (function () {
      try {
        const token = localStorage.getItem('bliss_admin_token');
        if (!token) throw new Error('no token');
        const payload = JSON.parse(atob(token.split('.')[1].replace(/-/g, '+').replace(/_/g, '/')));
        if (!payload.exp || payload.exp < Date.now() / 1000) throw new Error('expired');
      } catch (e) {
        document.documentElement.style.display = 'none';
        window.location.replace('/admin/login');
      }
    })();
  </script>
</head>
<body class="bg-neutral-50 font-sans min-h-screen">

  <!-- Mobile top bar -->
  <div class="lg:hidden flex items-center justify-between bg-white border-b border-neutral-200 px-4 py-3 sticky top-0 z-40">
    <div class="flex items-center gap-2">
      <div class="w-7 h-7 rounded-full bg-primary-600 flex items-center justify-center">
        <span class="text-white text-xs font-bold">B</span>
      </div>
      <span class="font-semibold text-sm text-neutral-900">Bliss Admin</span>
    </div>
    <button id="mobile-menu-btn" class="p-2 rounded-lg text-neutral-500 hover:bg-neutral-100 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <div class="flex">
    <!-- Sidebar -->
    <aside id="sidebar" class="hidden lg:flex flex-col w-64 min-h-screen bg-white border-r border-neutral-200 fixed top-0 left-0 z-30 transition-all">
      <!-- Brand -->
      <div class="px-6 py-6 border-b border-neutral-100">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-xl bg-primary-600 flex items-center justify-center shrink-0">
            <span class="text-white text-sm font-bold">B</span>
          </div>
          <div>
            <div class="font-serif text-base font-semibold text-neutral-900 leading-tight">Bliss Dermacare</div>
            <div class="text-xs text-primary-500 font-medium tracking-wide">Admin Panel</div>
          </div>
        </div>
      </div>

      <!-- Nav -->
      <nav class="flex-1 px-3 py-4 space-y-0.5">
        <a href="/admin/"
           class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${activeNav === 'dashboard' ? 'bg-primary-50 text-primary-700' : 'text-neutral-600 hover:bg-neutral-50 hover:text-neutral-900'}`}>
          <svg class="w-4.5 h-4.5 w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          Dashboard
        </a>
        <a href="/admin/calendar"
           class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${activeNav === 'calendar' ? 'bg-primary-50 text-primary-700' : 'text-neutral-600 hover:bg-neutral-50 hover:text-neutral-900'}`}>
          <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          Calendar
        </a>
        <a href="/admin/clients"
           class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${activeNav === 'clients' ? 'bg-primary-50 text-primary-700' : 'text-neutral-600 hover:bg-neutral-50 hover:text-neutral-900'}`}>
          <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Clients
        </a>
        <a href="/admin/new-appointment"
           class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${activeNav === 'new-appointment' ? 'bg-primary-50 text-primary-700' : 'text-neutral-600 hover:bg-neutral-50 hover:text-neutral-900'}`}>
          <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          New Appointment
        </a>
        <!-- Owner-only nav items (shown via JS) -->
        <div class="owner-only-nav hidden">
          <div class="my-2 border-t border-neutral-100"></div>
          <a href="/admin/staff"
             class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${activeNav === 'staff' ? 'bg-primary-50 text-primary-700' : 'text-neutral-600 hover:bg-neutral-50 hover:text-neutral-900'}`}>
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            Staff Management
          </a>
          <a href="/admin/availability"
             class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${activeNav === 'availability' ? 'bg-primary-50 text-primary-700' : 'text-neutral-600 hover:bg-neutral-50 hover:text-neutral-900'}`}>
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Availability
          </a>
          <a href="/admin/audit"
             class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${activeNav === 'audit' ? 'bg-primary-50 text-primary-700' : 'text-neutral-600 hover:bg-neutral-50 hover:text-neutral-900'}`}>
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
            </svg>
            Audit Log
          </a>
        </div>
      </nav>

      <!-- User info + logout -->
      <div class="px-4 py-4 border-t border-neutral-100">
        <div id="sidebar-role-badge" class="flex items-center gap-2 mb-3 px-2">
          <div class="w-7 h-7 rounded-full bg-primary-100 flex items-center justify-center">
            <svg class="w-3.5 h-3.5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
          <div>
            <div id="sidebar-username" class="text-xs font-semibold text-neutral-800 capitalize">—</div>
            <div id="sidebar-role" class="text-xs text-neutral-400 capitalize">—</div>
          </div>
        </div>
        <a href="/" target="_blank" class="flex items-center gap-2 px-3 py-2 rounded-lg text-xs text-neutral-500 hover:bg-neutral-50 hover:text-neutral-700 transition-colors mb-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
          View Public Site
        </a>
        <button id="logout-btn" class="w-full flex items-center gap-2 px-3 py-2 rounded-lg text-xs text-red-500 hover:bg-red-50 hover:text-red-700 transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Log Out
        </button>
      </div>
    </aside>

    <!-- Mobile sidebar drawer -->
    <div id="mobile-sidebar" class="hidden fixed inset-0 z-50 lg:hidden">
      <div class="absolute inset-0 bg-black/40" id="mobile-sidebar-overlay"></div>
      <aside class="absolute left-0 top-0 bottom-0 w-64 bg-white shadow-xl flex flex-col">
        <div class="px-6 py-5 border-b border-neutral-100 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-xl bg-primary-600 flex items-center justify-center">
              <span class="text-white text-sm font-bold">B</span>
            </div>
            <span class="font-serif text-base font-semibold text-neutral-900">Bliss Admin</span>
          </div>
          <button id="mobile-close-btn" class="p-1 rounded text-neutral-400 hover:text-neutral-600">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <nav class="flex-1 px-3 py-4 space-y-0.5">
          <a href="/admin/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-neutral-600 hover:bg-neutral-50">Dashboard</a>
          <a href="/admin/calendar" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-neutral-600 hover:bg-neutral-50">Calendar</a>
          <a href="/admin/clients" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-neutral-600 hover:bg-neutral-50">Clients</a>
          <a href="/admin/new-appointment" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-neutral-600 hover:bg-neutral-50">New Appointment</a>
          <a href="/admin/availability" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-neutral-600 hover:bg-neutral-50">Availability</a>
        </nav>
        <div class="px-4 py-4 border-t border-neutral-100">
          <button id="mobile-logout-btn" class="w-full text-left px-3 py-2 text-sm text-red-500 hover:bg-red-50 rounded-lg transition-colors">Log Out</button>
        </div>
      </aside>
    </div>

    <!-- Main content -->
    <main class="lg:ml-64 flex-1 min-h-screen">
      <slot />
    </main>
  </div>

  <script>
    import { requireLogin, getRole, clearAuth, decodePayload, getToken } from '../scripts/adminAuth.js';

    requireLogin();

    // Populate sidebar user info
    const token = getToken();
    const payload = decodePayload(token || '');
    const role = getRole();
    const usernameEl = document.getElementById('sidebar-username');
    const roleEl = document.getElementById('sidebar-role');
    if (usernameEl && payload) usernameEl.textContent = payload.username || role || '—';
    if (roleEl && role) roleEl.textContent = role;

    // Show owner-only nav items
    if (role === 'owner') {
      document.querySelectorAll('.owner-only-nav').forEach(el => el.classList.remove('hidden'));
    }

    // Logout
    function doLogout() {
      clearAuth();
      window.location.href = '/admin/login';
    }
    document.getElementById('logout-btn')?.addEventListener('click', doLogout);
    document.getElementById('mobile-logout-btn')?.addEventListener('click', doLogout);

    // Mobile menu
    const mobileSidebar = document.getElementById('mobile-sidebar');
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      mobileSidebar?.classList.remove('hidden');
    });
    document.getElementById('mobile-sidebar-overlay')?.addEventListener('click', () => {
      mobileSidebar?.classList.add('hidden');
    });
    document.getElementById('mobile-close-btn')?.addEventListener('click', () => {
      mobileSidebar?.classList.add('hidden');
    });
  </script>

</body>
</html>
