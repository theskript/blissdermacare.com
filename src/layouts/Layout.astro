      }
      function isInCart(id) { return getCart().some(i => i.id === id); }

      // ── Validation (same rules as booking page) ────────────────────────────
      function canAdd(id) {
        const ids = getCart().map(i => i.id);
        if (ids.some(i => SOLO.has(i)))          return 'Your cart has a package that must be booked alone. Remove it first.';
        if (SOLO.has(id) && ids.length > 0)      return 'This package must be booked alone. Clear the cart first.';
        if (!SOLO.has(id)) {
          const dur     = DURATIONS[id] ?? 60;
          const current = ids.reduce((s, i) => s + (DURATIONS[i] ?? 60), 0);
          if (current + dur > 120) return 'Adding this exceeds the 2‑hour visit limit. Remove a service first.';
        }
        return null;
      }

      // ── Toast notification ─────────────────────────────────────────────────
      function showToast(msg) {
        let toast = document.getElementById('cart-toast');
        if (!toast) {
          toast = document.createElement('div');
          toast.id = 'cart-toast';
          toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-[200] bg-neutral-900 text-white text-sm font-sans font-medium px-5 py-3 rounded-full shadow-xl transition-opacity duration-300 opacity-0 pointer-events-none max-w-[90vw] text-center';
          document.body.appendChild(toast);
        }
        toast.textContent = msg;
        toast.style.opacity = '1';
        clearTimeout(toast._t);
        toast._t = setTimeout(() => { toast.style.opacity = '0'; }, 3200);
      }

      // ── Mutations ──────────────────────────────────────────────────────────
      function addItem(id) {
        if (id === 'mix-match-package') { openMMModal(); return; }
        const svc = SERVICES[id];
        if (!svc) return;
        const err = canAdd(id);
        if (err) { showToast(err); return; }
        if (isInCart(id)) { openDrawer(); return; }
        const items = getCart();
        items.push({ id, name: svc.name, price: svc.price, duration: svc.duration });
        saveCart(items);
        renderAll();
        pulseBadge();
        openDrawer();
      }
      function removeItem(id) {
        saveCart(getCart().filter(i => i.id !== id));
        renderAll();
      }
      function clearAll() { saveCart([]); renderAll(); }

      function fmt(n) { return '$' + n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ','); }

      // ── Badge ──────────────────────────────────────────────────────────────
      function updateBadge() {
        const count = getCart().length;
        document.querySelectorAll('.cart-badge').forEach(b => {
          b.textContent = count;
          b.classList.toggle('hidden', count === 0);
          b.classList.toggle('flex', count > 0);
        });
        const cl = document.getElementById('cart-count-label');
        if (cl) cl.textContent = '(' + count + ')';
      }
      function pulseBadge() {
        document.querySelectorAll('.cart-badge').forEach(b => {
          b.classList.add('scale-125');
          setTimeout(() => b.classList.remove('scale-125'), 200);
        });
      }

      // ── Drawer rendering ───────────────────────────────────────────────────
      function renderDrawer() {
        const items  = getCart();
        const empty  = document.getElementById('cart-empty');
        const list   = document.getElementById('cart-items');
        const foot   = document.getElementById('cart-footer');
        if (!empty || !list || !foot) return;

        if (items.length === 0) {
          empty.classList.remove('hidden');
          list.classList.add('hidden');
          foot.classList.add('hidden');
          return;
        }
        empty.classList.add('hidden');
        list.classList.remove('hidden');
        foot.classList.remove('hidden');

        list.innerHTML = items.map(item => `
          <div class="flex items-start gap-3 py-3.5 border-b border-neutral-100 last:border-0">
            <div class="w-8 h-8 bg-primary-50 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-neutral-900 leading-snug">${item.name}</p>
              <p class="text-xs text-neutral-400 mt-0.5">${item.duration}&nbsp;&middot;&nbsp;<span class="font-semibold text-primary-600">${fmt(item.price)}</span></p>
            </div>
            <button onclick="window.BlissCart.remove('${item.id}')" class="p-1.5 text-neutral-300 hover:text-red-400 transition-colors rounded hover:bg-red-50 shrink-0 mt-0.5" aria-label="Remove">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>`).join('');

        const total = items.reduce((s, i) => s + i.price, 0);
        const sub = document.getElementById('cart-subtotal');
        if (sub) sub.textContent = fmt(total);
      }

      function renderAll() { updateBadge(); renderDrawer(); updateAddButtons(); }

      // ── Add-button state (greyed = blocked by rules) ───────────────────────
      function updateAddButtons() {
        const ids        = getCart().map(i => i.id);
        const currentDur = ids.reduce((s, i) => s + (DURATIONS[i] ?? 60), 0);
        const hasSolo    = ids.some(i => SOLO.has(i));

        document.querySelectorAll('[data-add-to-cart]').forEach(btn => {
          const id     = btn.getAttribute('data-add-to-cart');
          const inCart = ids.includes(id);
          let blocked  = false;
          let blockLabel = 'Cart Full';
          if (!inCart) {
            if (hasSolo) {
              blocked    = true;
              blockLabel = 'Pkg Only';
            } else if (SOLO.has(id) && ids.length > 0) {
              blocked    = true;
              blockLabel = 'Clear Cart';
            } else if (!SOLO.has(id) && (currentDur + (DURATIONS[id] ?? 60)) > 120) {
              blocked    = true;
              blockLabel = 'Cart Full';
            }
          }
          const textEl  = btn.querySelector('.cart-btn-text');
          const plusEl  = btn.querySelector('.cart-btn-icon');
          const checkEl = btn.querySelector('.cart-check-icon');
          if (textEl)  textEl.textContent = inCart ? 'Added' : (blocked ? blockLabel : 'Add');
          if (plusEl)  plusEl.classList.toggle('hidden', inCart || blocked);
          if (checkEl) checkEl.classList.toggle('hidden', !inCart);
          btn.classList.toggle('!border-emerald-300', inCart);
          btn.classList.toggle('!text-emerald-700',   inCart);
          btn.classList.toggle('!bg-emerald-50',       inCart);
          btn.classList.toggle('opacity-50',           blocked && !inCart);
          // Keep clickable so the toast explanation fires — not disabled
          btn.disabled = false;
        });
      }

      // ── Inject Add buttons next to <a data-service-id> links ──────────────
      function injectCartButtons() {
        document.querySelectorAll('a[data-service-id]:not([data-cart-injected])').forEach(link => {
          link.setAttribute('data-cart-injected', '1');
          const id        = link.getAttribute('data-service-id');
          const isPackage = link.classList.contains('block');

          const btn = document.createElement('button');
          btn.setAttribute('data-add-to-cart', id);
          btn.innerHTML = `
            <svg class="cart-btn-icon w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
            <svg class="cart-check-icon hidden w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            <span class="cart-btn-text">Add</span>`;

          if (isPackage) {
            // Package card: split full-width button into flex pair
            btn.className = 'flex-1 flex items-center justify-center gap-1.5 border border-primary-200 text-primary-600 text-xs font-medium py-2.5 rounded-full hover:bg-primary-50 transition-all';
            link.classList.remove('block');
            link.classList.add('flex-1');
            const wrapper = document.createElement('div');
            wrapper.className = 'flex gap-2';
            link.parentNode.insertBefore(wrapper, link);
            wrapper.appendChild(btn);
            wrapper.appendChild(link);
          } else {
            // Regular card: insert Add button before the Book link in its flex row
            btn.className = 'flex items-center gap-1 px-2.5 py-1.5 border border-neutral-200 text-neutral-500 text-[11px] font-medium rounded-full hover:border-primary-400 hover:text-primary-600 transition-all';
            link.parentNode.insertBefore(btn, link);
          }
        });
        updateAddButtons();
      }

      // ── Mix & Match Modal ──────────────────────────────────────────────────
      let mmModalSelected = [];

      function buildMMGrid() {
        const grid = document.getElementById('mm-modal-grid');
        if (!grid) return;
        grid.innerHTML = MM_OPTIONS.map(opt => `
          <button type="button"
            data-mm-val="${opt.value}" data-mm-price="${opt.price}"
            data-mm-label="${opt.label}" data-mm-dur="${opt.dur}" data-mm-cat="${opt.cat}"
            class="mm-opt-btn text-left rounded-xl border-2 border-neutral-200 bg-white p-3 hover:border-primary-300 transition-all">
            <p class="font-semibold text-xs text-neutral-900 leading-snug">${opt.label}</p>
            <p class="text-primary-600 font-bold text-xs mt-1">$${opt.price.toFixed(2)}</p>
            <p class="text-[10px] text-neutral-400">${opt.dur}</p>
          </button>`).join('');

        grid.addEventListener('click', e => {
          const btn = e.target.closest('.mm-opt-btn');
          if (!btn) return;
          const val = btn.dataset.mmVal;
          const idx = mmModalSelected.findIndex(s => s.value === val);
          if (idx >= 0) {
            mmModalSelected.splice(idx, 1);
            btn.classList.remove('!border-primary-500', '!bg-primary-50');
          } else {
            if (mmModalSelected.length >= 2) { showToast('Select exactly 2 services.'); return; }
            // Category rule: both services must be from different categories
            if (mmModalSelected.length === 1) {
              const existingCat = MM_OPTIONS.find(o => o.value === mmModalSelected[0].value)?.cat;
              if (existingCat === btn.dataset.mmCat) {
                showToast('Choose services from different categories — e.g. a facial + a wax or lash service.');
                return;
              }
            }
            mmModalSelected.push({ value: val, label: btn.dataset.mmLabel, price: parseFloat(btn.dataset.mmPrice) });
            btn.classList.add('!border-primary-500', '!bg-primary-50');
          }
          updateMMModal();
        });
      }

      function updateMMModal() {
        const breakdown  = document.getElementById('mm-modal-breakdown');
        const confirmBtn = document.getElementById('mm-modal-confirm');
        const grid       = document.getElementById('mm-modal-grid');
        const atMax       = mmModalSelected.length >= 2;
        // Category of the already-selected item (when exactly 1 selected)
        const takenCat    = mmModalSelected.length === 1
          ? MM_OPTIONS.find(o => o.value === mmModalSelected[0].value)?.cat
          : null;
        if (grid) grid.querySelectorAll('.mm-opt-btn').forEach(btn => {
          const sel      = mmModalSelected.some(s => s.value === btn.dataset.mmVal);
          const sameCat  = !sel && takenCat && btn.dataset.mmCat === takenCat;
          const blocked  = (atMax && !sel) || sameCat;
          btn.classList.toggle('opacity-40',          blocked);
          btn.classList.toggle('pointer-events-none',  blocked);
        });
        if (mmModalSelected.length === 2) {
          const total = mmModalSelected[0].price + mmModalSelected[1].price - 15;
          document.getElementById('mm-m-svc1-label').textContent = mmModalSelected[0].label;
          document.getElementById('mm-m-svc1-price').textContent = '$' + mmModalSelected[0].price.toFixed(2);
          document.getElementById('mm-m-svc2-label').textContent = mmModalSelected[1].label;
          document.getElementById('mm-m-svc2-price').textContent = '$' + mmModalSelected[1].price.toFixed(2);
          document.getElementById('mm-m-total').textContent      = fmt(total);
          breakdown?.classList.remove('hidden');
          if (confirmBtn) confirmBtn.disabled = false;
        } else {
          breakdown?.classList.add('hidden');
          if (confirmBtn) confirmBtn.disabled = true;
        }
      }

      function openMMModal() {
        const items = getCart();
        if (items.some(i => i.id !== 'mix-match-package')) {
          showToast('Mix & Match must be booked alone. Clear the cart first.');
          return;
        }
        mmModalSelected = [];
        buildMMGrid();
        const existing = items.find(i => i.id === 'mix-match-package');
        if (existing && existing.mmServices && existing.mmServices.length === 2) {
          existing.mmServices.forEach(v => {
            const opt = MM_OPTIONS.find(o => o.value === v);
            if (!opt) return;
            mmModalSelected.push({ value: opt.value, label: opt.label, price: opt.price });
            const btn = document.querySelector('.mm-opt-btn[data-mm-val="' + v + '"]');
            if (btn) btn.classList.add('!border-primary-500', '!bg-primary-50');
          });
          updateMMModal();
        }
        const overlay = document.getElementById('mm-modal-overlay');
        if (overlay) { overlay.classList.remove('hidden'); overlay.classList.add('flex'); }
        document.body.style.overflow = 'hidden';
      }

      function closeMMModal() {
        const overlay = document.getElementById('mm-modal-overlay');
        if (overlay) { overlay.classList.remove('flex'); overlay.classList.add('hidden'); }
        if (!drawerOpen) document.body.style.overflow = '';
      }

      function confirmMMModal() {
        if (mmModalSelected.length !== 2) return;
        const total = mmModalSelected[0].price + mmModalSelected[1].price - 15;
        const newItem = {
          id: 'mix-match-package',
          name: 'Mix & Match: ' + mmModalSelected[0].label + ' + ' + mmModalSelected[1].label,
          price: total,
          duration: '~2 hrs 15 min',
          mmServices: mmModalSelected.map(s => s.value),
        };
        const items = getCart().filter(i => i.id !== 'mix-match-package');
        items.push(newItem);
        saveCart(items);
        closeMMModal();
        renderAll();
        pulseBadge();
        openDrawer();
      }

      // ── Drawer open / close ────────────────────────────────────────────────
      let drawerOpen = false;
      function openDrawer() {
        drawerOpen = true;
        const overlay = document.getElementById('cart-overlay');
        const drawer  = document.getElementById('cart-drawer');
        if (!overlay || !drawer) return;
        overlay.classList.remove('hidden');
        requestAnimationFrame(() => {
          overlay.classList.remove('opacity-0');
          overlay.classList.add('opacity-100');
          drawer.classList.remove('translate-x-full');
        });
        document.body.style.overflow = 'hidden';
      }
      function closeDrawer() {
        drawerOpen = false;
        const overlay = document.getElementById('cart-overlay');
        const drawer  = document.getElementById('cart-drawer');
        if (!overlay || !drawer) return;
        overlay.classList.remove('opacity-100');
        overlay.classList.add('opacity-0');
        drawer.classList.add('translate-x-full');
        setTimeout(() => overlay.classList.add('hidden'), 300);
        document.body.style.overflow = '';
      }

      // ── Click delegation ───────────────────────────────────────────────────
      document.addEventListener('click', e => {
        const addBtn = e.target.closest('[data-add-to-cart]');
        if (addBtn) { e.preventDefault(); addItem(addBtn.getAttribute('data-add-to-cart')); return; }
        if (e.target.closest('#cart-btn, #cart-btn-mobile')) { drawerOpen ? closeDrawer() : openDrawer(); return; }
        if (e.target.closest('#cart-close'))                 { closeDrawer(); return; }
        if (e.target.id === 'cart-overlay')                  { closeDrawer(); return; }
        if (e.target.closest('#cart-clear-btn'))             { clearAll(); return; }
        if (e.target.closest('#mm-modal-close'))             { closeMMModal(); return; }
        if (e.target.id === 'mm-modal-overlay')              { closeMMModal(); return; }
        if (e.target.closest('#mm-modal-confirm'))           { confirmMMModal(); return; }
      });

      // ── Keyboard ───────────────────────────────────────────────────────────
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
          if (document.getElementById('mm-modal-overlay')?.classList.contains('flex')) { closeMMModal(); return; }
          if (drawerOpen) closeDrawer();
        }
      });

      // ── Public API ─────────────────────────────────────────────────────────
      window.BlissCart = { add: addItem, remove: removeItem, clear: clearAll, get: getCart, open: openDrawer, close: closeDrawer };

      // ── Init ───────────────────────────────────────────────────────────────
      function init() { renderAll(); injectCartButtons(); }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
    </script>
  </body>
</html>
