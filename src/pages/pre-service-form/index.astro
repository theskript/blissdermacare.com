<script>
  document.addEventListener('DOMContentLoaded', function() {
    // ── Age section toggle ─────────────────────────────────────────────────
    const ageRadios    = document.querySelectorAll('input[name="age_category"]');
    const teenSection  = document.getElementById('teen-section')  as HTMLElement | null;
    const adultSection = document.getElementById('adult-section') as HTMLElement | null;
    const guardianInputs = document.querySelectorAll<HTMLInputElement>('#teen-section input, #teen-section select');

    function updateAgeDisplay() {
      const selectedAge = document.querySelector('input[name="age_category"]:checked') as HTMLInputElement | null;
      if (selectedAge?.value === 'under-18') {
        teenSection?.classList.remove('hidden');
        adultSection?.classList.add('hidden');
        guardianInputs.forEach(input => {
          if (input.name.startsWith('guardian_') && input.type !== 'checkbox') input.required = true;
        });
      } else if (selectedAge?.value === '18-plus') {
        teenSection?.classList.add('hidden');
        adultSection?.classList.remove('hidden');
        guardianInputs.forEach(input => {
          if (input.name.startsWith('guardian_') && input.type !== 'checkbox') {
            input.required = false;
            input.value = '';
          }
        });
      }
    }
    ageRadios.forEach(r => r.addEventListener('change', updateAgeDisplay));
    updateAgeDisplay();

    // ── Form submission → Supabase via Netlify function ────────────────────
    const form       = document.getElementById('psf-form')      as HTMLFormElement | null;
    const submitBtn  = document.getElementById('psf-submit')    as HTMLButtonElement | null;
    const successEl  = document.getElementById('psf-success')   as HTMLElement | null;
    const errorEl    = document.getElementById('psf-error')     as HTMLElement | null;
    const errorMsg   = document.getElementById('psf-error-msg') as HTMLElement | null;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form) return;

      // Hide previous banners
      successEl?.classList.add('hidden');
      errorEl?.classList.add('hidden');

      // Collect form fields into a plain object
      const fd = new FormData(form);
      const body: Record<string, string | string[]> = {};

      // Multi-value fields (checkboxes with same name)
      const multiFields = ['skin_conditions', 'medical_history', 'skin_prep', 'recent_treatments'];

      for (const key of new Set(fd.keys())) {
        if (multiFields.includes(key)) {
          body[key] = fd.getAll(key) as string[];
        } else {
          body[key] = fd.get(key) as string;
        }
      }

      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Submitting…'; }

      try {
        const res = await fetch('/.netlify/functions/pre-service-form', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify(body),
        });
        const json = await res.json();
        if (!res.ok) throw new Error(json.error || 'Submission failed');

        // Success
        form.classList.add('hidden');
        successEl?.classList.remove('hidden');
        successEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } catch (err: any) {
        if (errorMsg) errorMsg.textContent = err.message || 'Something went wrong. Please try again.';
        errorEl?.classList.remove('hidden');
        errorEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit Pre-Service Questionnaire'; }
      }
    });
  });
</script>
