---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Pre-Service Form – Bliss Dermacare" description="Complete your pre-service questionnaire before your skincare or waxing appointment at Bliss Dermacare.">

  <!-- Page Header -->
  <section class="py-14 bg-[#faf9f7] border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-4 block">Before Your Appointment</span>
      <h1 class="text-5xl font-serif text-neutral-900 mb-4">Pre-Service Questionnaire</h1>
      <p class="text-lg text-neutral-600">Please complete this form to ensure your safety and the best results for your treatment.</p>
    </div>
  </section>

  <!-- Form Section -->
  <section class="py-14 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <!-- Success banner (hidden until submission) -->
      <div id="psf-success" class="hidden mb-8 p-5 bg-emerald-50 border border-emerald-200 rounded-2xl text-center">
        <svg class="w-10 h-10 mx-auto mb-3 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <h2 class="text-lg font-semibold text-emerald-800 mb-1">Form submitted successfully!</h2>
        <p class="text-sm text-emerald-700">Thank you. We've received your questionnaire and look forward to seeing you.</p>
      </div>

      <!-- Error banner (hidden until submission error) -->
      <div id="psf-error" class="hidden mb-8 p-4 bg-red-50 border border-red-200 rounded-2xl">
        <p id="psf-error-msg" class="text-sm text-red-700 text-center">Something went wrong. Please try again.</p>
      </div>

      <form id="psf-form" class="space-y-10">

        <!-- Client Information -->
        <div class="space-y-5">
          <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3">Your Information</h2>
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="clientName" class="block text-sm font-medium text-neutral-700 mb-1.5">Full Name *</label>
              <input type="text" id="clientName" name="name" required placeholder="Jane Smith"
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
            </div>
            <div>
              <label for="appointmentDate" class="block text-sm font-medium text-neutral-700 mb-1.5">Appointment Date *</label>
              <input type="date" id="appointmentDate" name="appointment_date" required
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
            </div>
            <div>
              <label for="appointmentTime" class="block text-sm font-medium text-neutral-700 mb-1.5">Appointment Time *</label>
              <input type="time" id="appointmentTime" name="appointment_time" required
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
            </div>
            <div>
              <label for="serviceRequested" class="block text-sm font-medium text-neutral-700 mb-1.5">Service Requested *</label>
              <select id="serviceRequested" name="service_requested" required
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm bg-white">
                <option value="">Select a service…</option>
                <option value="Classic Facial">Classic Facial</option>
                <option value="Deep Cleansing Facial">Deep Cleansing Facial</option>
                <option value="Hydrating Facial">Hydrating Facial</option>
                <option value="Anti-Aging Facial">Anti-Aging Facial</option>
                <option value="Chemical Peel">Chemical Peel</option>
                <option value="Microneedling">Microneedling</option>
                <option value="LED Light Therapy">LED Light Therapy</option>
                <option value="Dermaplaning">Dermaplaning</option>
                <option value="Eyebrow Wax / Shaping">Eyebrow Wax / Shaping</option>
                <option value="Full Face Wax">Full Face Wax</option>
                <option value="Body Waxing">Body Waxing</option>
                <option value="Lash Lift & Tint">Lash Lift &amp; Tint</option>
                <option value="Brow Lamination">Brow Lamination</option>
                <option value="Semi-Permanent Makeup">Semi-Permanent Makeup</option>
                <option value="Package / Bundle">Package / Bundle</option>
                <option value="Other">Other / Not Listed</option>
              </select>
            </div>
            <div>
              <label for="clientPhone" class="block text-sm font-medium text-neutral-700 mb-1.5">Phone Number *</label>
              <input type="tel" id="clientPhone" name="phone" required placeholder="(609) 366-0857"
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
            </div>
            <div>
              <label for="clientEmail" class="block text-sm font-medium text-neutral-700 mb-1.5">Email Address *</label>
              <input type="email" id="clientEmail" name="email" required placeholder="jane@example.com"
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
            </div>
          </div>
        </div>

        <!-- Age Verification & Guardian Consent -->
        <div class="space-y-5">
          <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3">Age Verification & Guardian Consent</h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-3">Client Age Category *</label>
              <div class="space-y-2">
                <label class="flex items-center">
                  <input type="radio" name="age_category" value="18-plus" 
                    class="w-4 h-4 border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">I am 18 years of age or older</span>
                </label>
                <label class="flex items-center">
                  <input type="radio" name="age_category" value="under-18" 
                    class="w-4 h-4 border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">I am under 18 (parent/guardian consent required)</span>
                </label>
              </div>
            </div>

            <!-- Teen/Minor Section (Conditional) -->
            <div id="teen-section" class="hidden p-4 bg-blue-50 rounded-xl border border-blue-200 space-y-4">
              <div class="flex items-start gap-2">
                <svg class="w-5 h-5 text-blue-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-sm text-blue-800"><strong>Parent or Legal Guardian:</strong> For clients under 18, a parent or legal guardian must be present during the entire appointment and must complete this section.</p>
              </div>

              <div class="border-t border-blue-200 pt-4 space-y-4">
                <p class="text-sm font-medium text-neutral-900">Parent/Guardian Information</p>
                
                <div class="grid sm:grid-cols-2 gap-4">
                  <div>
                    <label for="guardianName" class="block text-sm font-medium text-neutral-700 mb-1.5">Parent/Guardian Full Name *</label>
                    <input type="text" id="guardianName" name="guardian_name" placeholder="John Smith"
                      class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
                  </div>
                  <div>
                    <label for="guardianRelationship" class="block text-sm font-medium text-neutral-700 mb-1.5">Relationship to Client *</label>
                    <select id="guardianRelationship" name="guardian_relationship"
                      class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm">
                      <option value="">Select relationship...</option>
                      <option value="mother">Mother</option>
                      <option value="father">Father</option>
                      <option value="legal-guardian">Legal Guardian</option>
                      <option value="other-parent">Other Parent</option>
                    </select>
                  </div>
                </div>

                <div class="grid sm:grid-cols-2 gap-4">
                  <div>
                    <label for="guardianPhone" class="block text-sm font-medium text-neutral-700 mb-1.5">Guardian Phone Number *</label>
                    <input type="tel" id="guardianPhone" name="guardian_phone" placeholder="(609) 366-0857"
                      class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
                  </div>
                  <div>
                    <label for="guardianEmail" class="block text-sm font-medium text-neutral-700 mb-1.5">Guardian Email *</label>
                    <input type="email" id="guardianEmail" name="guardian_email" placeholder="guardian@example.com"
                      class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
                  </div>
                </div>

                <div>
                  <label for="guardianId" class="block text-sm font-medium text-neutral-700 mb-1.5">Form of ID to be presented at appointment *</label>
                  <select id="guardianId" name="guardian_id_type"
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm">
                    <option value="">Select ID type...</option>
                    <option value="drivers-license">Driver's License</option>
                    <option value="state-id">State ID</option>
                    <option value="passport">Passport</option>
                    <option value="birth-certificate">Birth Certificate (with custody papers)</option>
                  </select>
                  <p class="text-xs text-neutral-500 mt-1.5">Valid government-issued photo ID is required to verify guardianship at the appointment.</p>
                </div>

                <div class="bg-white rounded-lg p-3 border border-blue-100 space-y-2">
                  <label class="flex items-start">
                    <input type="checkbox" name="guardian_presence_commitment" value="yes"
                      class="mt-1 w-4 h-4 rounded border-neutral-300 text-primary-600" />
                    <span class="ml-2 text-sm text-neutral-700">I will be <strong>physically present</strong> during my child/ward's entire appointment at Bliss Dermacare.</span>
                  </label>
                </div>

                <div class="bg-white rounded-lg p-3 border border-blue-100 space-y-2">
                  <label class="flex items-start">
                    <input type="checkbox" name="guardian_medical_accuracy" value="yes"
                      class="mt-1 w-4 h-4 rounded border-neutral-300 text-primary-600" />
                    <span class="ml-2 text-sm text-neutral-700">I have provided accurate and complete medical information for my child/ward and will notify the esthetician of any conditions that may affect treatment.</span>
                  </label>
                </div>

                <div class="bg-amber-50 rounded-lg p-3 border border-amber-200 flex items-start gap-2">
                  <svg class="w-4 h-4 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4v2m0 4v2m0-14a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  <p class="text-xs text-amber-800"><strong>Waxing Restriction:</strong> Waxing and hair removal services are available only for clients <strong>21 years of age and older</strong>. Facial and skincare treatments are available for teens 13-20.</p>
                </div>
              </div>
            </div>

            <!-- Adult Confirmation -->
            <div id="adult-section" class="hidden p-4 bg-neutral-50 rounded-xl border border-neutral-200">
              <label class="flex items-start cursor-pointer">
                <input type="checkbox" name="age_confirmation_adult" value="yes"
                  class="mt-1 w-5 h-5 rounded border-neutral-300 text-primary-600 focus:ring-primary-500" />
                <span class="ml-3 text-sm text-neutral-700">I confirm I am <strong>18 years of age or older</strong> and can provide informed consent for this service. *</span>
              </label>
            </div>
          </div>
        </div>

        <!-- Skin Health & Conditions -->
        <div class="space-y-5">
          <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3">Skin Health & Conditions</h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-3">Do you have any active skin conditions? *</label>
              <div class="space-y-2">
                <label class="flex items-center">
                  <input type="checkbox" name="skin_conditions" value="acne" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Acne or active breakouts</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="skin_conditions" value="eczema" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Eczema or dermatitis</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="skin_conditions" value="psoriasis" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Psoriasis</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="skin_conditions" value="rosacea" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Rosacea or sensitivity</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="skin_conditions" value="sunburn" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Sunburn or sun damage</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="skin_conditions" value="open_wounds" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Open wounds or cuts</span>
                </label>
              </div>
            </div>

            <div>
              <label for="skinAllergies" class="block text-sm font-medium text-neutral-700 mb-1.5">Known product allergies or sensitivities *</label>
              <textarea id="skinAllergies" name="allergies" placeholder="e.g., fragrance, specific ingredients, latex"
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm h-20"></textarea>
            </div>
          </div>
        </div>

        <!-- Medical History -->
        <div class="space-y-5">
          <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3">Medical History</h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-3">Do any of these apply to you? *</label>
              <div class="space-y-2">
                <label class="flex items-center">
                  <input type="checkbox" name="medical_history" value="pregnant" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Pregnant or nursing</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="medical_history" value="chemotherapy" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Currently undergoing chemotherapy or radiation</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="medical_history" value="blood_disorder" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Blood clotting disorder or on blood thinners</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="medical_history" value="recent_surgery" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Recent surgery (within 3 months)</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="medical_history" value="epilepsy" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Epilepsy or seizure disorders</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="medical_history" value="none" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">None of the above</span>
                </label>
              </div>
            </div>

            <div>
              <label for="currentMedications" class="block text-sm font-medium text-neutral-700 mb-1.5">Current medications or supplements (especially acne/retinoid medications) *</label>
              <textarea id="currentMedications" name="medications" placeholder="Please list all medications, including Accutane, Retin-A, etc."
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm h-20"></textarea>
            </div>
          </div>
        </div>

        <!-- Recent Treatments -->
        <div class="space-y-5">
          <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3">Recent Treatments</h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-3">Have you had any of these treatments in the past 7 days? *</label>
              <div class="space-y-2">
                <label class="flex items-center">
                  <input type="checkbox" name="recent_treatments" value="other_waxing" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Waxing or hair removal</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="recent_treatments" value="chemical_peel" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Chemical peels or strong exfoliation</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="recent_treatments" value="microdermabrasion" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Microdermabrasion or laser treatments</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="recent_treatments" value="botox" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Botox or injectable treatments</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="recent_treatments" value="retinoid" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">Retinoid or vitamin A products</span>
                </label>
              </div>
            </div>
          </div>
        </div>

        <!-- Pre-Service Preparation -->
        <div class="space-y-5">
          <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3">Pre-Service Preparation</h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-3">Alcohol Consumption *</label>
              <p class="text-xs text-neutral-600 mb-3">Alcohol thins the blood and can affect treatment outcomes. Please avoid alcohol for 24 hours before your appointment.</p>
              <div class="space-y-2">
                <label class="flex items-center">
                  <input type="radio" name="alcohol_consumption" value="none" 
                    class="w-4 h-4 border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">I have not consumed alcohol in the past 24 hours</span>
                </label>
                <label class="flex items-center">
                  <input type="radio" name="alcohol_consumption" value="consumed" 
                    class="w-4 h-4 border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">I have consumed alcohol in the past 24 hours</span>
                </label>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-3">Skin Preparation *</label>
              <p class="text-xs text-neutral-600 mb-3">Please ensure clean, dry skin free of lotions, oils, deodorant, or makeup.</p>
              <div class="space-y-2">
                <label class="flex items-center">
                  <input type="checkbox" name="skin_prep" value="clean_dry" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">My skin is clean and dry</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="skin_prep" value="no_products" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">No lotions, oils, fragrances, or makeup applied</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="skin_prep" value="hygiene" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" />
                  <span class="ml-2 text-sm text-neutral-700">I have practiced proper hygiene before arrival</span>
                </label>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-3">Bodily Fluids & Hygiene Acknowledgment *</label>
              <p class="text-xs text-neutral-600 mb-3">For the health and safety of all clients and our esthetician, we require:</p>
              <div class="space-y-2">
                <label class="flex items-center">
                  <input type="checkbox" name="hygiene_acknowledgment" value="acknowledged" 
                    class="w-4 h-4 rounded border-neutral-300 text-primary-600" required />
                  <span class="ml-2 text-sm text-neutral-700">I understand that if there are any active infections, communicable diseases, open wounds with drainage, or other hygiene concerns, services will be refused. I have no such conditions.</span>
                </label>
              </div>
            </div>
          </div>
        </div>

        <!-- Conduct & Expectations -->
        <div class="space-y-5">
          <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3">Conduct & Appointment Expectations</h2>
          
          <div class="space-y-4">
            <div class="p-4 bg-blue-50 rounded-xl border border-blue-200">
              <p class="text-sm text-neutral-700 mb-3">By proceeding with your appointment, you agree to the following:</p>
              <ul class="space-y-2 text-sm text-neutral-700 list-disc list-inside">
                <li>Respectful conduct toward the esthetician and facility</li>
                <li>Appropriate attire and personal hygiene</li>
                <li>No inappropriate touching or behavior during the treatment</li>
                <li>Compliance with all health and safety protocols</li>
              </ul>
            </div>

            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-3">During & After Appointment *</label>
              <div class="space-y-2">
                <label class="flex items-start">
                  <input type="checkbox" name="appointment_acknowledgment" value="during_after" 
                    class="mt-1 w-4 h-4 rounded border-neutral-300 text-primary-600" required />
                  <span class="ml-2 text-sm text-neutral-700">I understand the treatment area will be exposed during my service. I acknowledge professional draping and boundaries will be maintained. I will inform the esthetician immediately of any discomfort.</span>
                </label>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-3">Post-Treatment Care *</label>
              <div class="space-y-2">
                <label class="flex items-start">
                  <input type="checkbox" name="post_care_acknowledgment" value="post_care" 
                    class="mt-1 w-4 h-4 rounded border-neutral-300 text-primary-600" required />
                  <span class="ml-2 text-sm text-neutral-700">I will follow post-treatment care instructions provided by the esthetician, including avoiding sun exposure, hot water, tight clothing, and strenuous activity for 24-48 hours.</span>
                </label>
              </div>
            </div>
          </div>
        </div>

        <!-- Right to Refuse Service -->
        <div class="space-y-5">
          <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3">Right to Refuse Service</h2>
          
          <div class="p-4 bg-red-50 rounded-xl border border-red-200 space-y-3">
            <p class="text-sm font-medium text-neutral-900">Bliss Dermacare reserves the right to refuse or terminate service for:</p>
