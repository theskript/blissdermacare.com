---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Contact – Bliss Dermacare" description="Get in touch with Bliss Dermacare in Tampa, FL. Call, text, email, or DM us on Instagram. We respond quickly.">

  <!-- Page Header -->
  <section class="py-14 bg-[#faf9f7] border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-4 block">We'd Love to Hear From You</span>
      <h1 class="text-5xl font-serif text-neutral-900 mb-4">Contact Us</h1>
      <p class="text-lg text-neutral-600">Questions, concerns, or just want to say hello — we respond quickly.</p>
    </div>
  </section>

  <!-- Contact Cards + CTA -->
  <section class="py-14 bg-white">
    <div class="max-w-5xl mx-auto px-6">

      <!-- Contact Cards -->
      <div class="grid md:grid-cols-3 gap-6 mb-14">
        <a href="tel:+16093660857"
          class="group block bg-[#faf9f7] rounded-2xl p-8 border border-neutral-200 hover:border-primary-300 hover:shadow-md transition-all text-center">
          <div class="w-14 h-14 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-primary-200 transition-colors">
            <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <h3 class="font-semibold text-neutral-900 mb-1">Call or Text</h3>
          <p class="text-primary-600 font-medium text-lg">(609) 366-0857</p>
          <p class="text-xs text-neutral-500 mt-2">Mon–Fri, 10 AM – 7 PM</p>
        </a>

        <a href="mailto:info@blissdermacare.com"
          class="group block bg-[#faf9f7] rounded-2xl p-8 border border-neutral-200 hover:border-primary-300 hover:shadow-md transition-all text-center">
          <div class="w-14 h-14 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-primary-200 transition-colors">
            <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="font-semibold text-neutral-900 mb-1">Email</h3>
          <p class="text-primary-600 font-medium break-all">info@blissdermacare.com</p>
          <p class="text-xs text-neutral-500 mt-2">We respond within 24 hours</p>
        </a>

        <a href="https://instagram.com/blissdermacare" target="_blank" rel="noopener noreferrer"
          class="group block bg-[#faf9f7] rounded-2xl p-8 border border-neutral-200 hover:border-primary-300 hover:shadow-md transition-all text-center">
          <div class="w-14 h-14 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-primary-200 transition-colors">
            <svg class="w-7 h-7 text-primary-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </div>
          <h3 class="font-semibold text-neutral-900 mb-1">Instagram</h3>
          <p class="text-primary-600 font-medium">@blissdermacare</p>
          <p class="text-xs text-neutral-500 mt-2">DMs welcome — we're active daily</p>
        </a>
      </div>

      <!-- Location Info -->
      <div class="bg-neutral-50 rounded-2xl p-8 border border-neutral-200 mb-10">
        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div>
            <h2 class="text-2xl font-serif text-neutral-900 mb-4">Studio Location</h2>
            <p class="text-neutral-700 font-medium mb-1">Bliss Dermacare</p>
            <p class="text-neutral-600">8905 Regents Park Dr</p>
            <p class="text-neutral-600">Tampa, FL 33647</p>
            <p class="text-sm text-neutral-500 mt-3">We operate as a private studio — appointments required.</p>
          </div>
          <div>
            <h3 class="font-semibold text-neutral-900 mb-4">Hours</h3>
            <div id="contact-hours-list" class="space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-neutral-600">Monday – Friday</span><span class="font-medium text-neutral-900">10:00 AM – 7:00 PM</span></div>
              <div class="flex justify-between"><span class="text-neutral-600">Saturday</span><span class="font-medium text-neutral-900">10:00 AM – 6:00 PM</span></div>
              <div class="flex justify-between"><span class="text-neutral-600">Sunday</span><span class="font-medium text-neutral-900">By request only</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Booking CTA -->
      <div class="bg-neutral-900 rounded-2xl p-10 text-white text-center">
        <h2 class="text-3xl font-serif mb-3">Ready to book?</h2>
        <p class="text-neutral-400 mb-8">Submit a booking request online and we'll confirm within 24 hours.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/book/" class="inline-flex items-center gap-2 bg-primary-600 text-white px-8 py-3.5 rounded-full hover:bg-primary-700 transition-all font-medium">
            Book an Appointment
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="/consultation/" class="inline-flex items-center gap-2 border border-neutral-600 text-neutral-300 px-8 py-3.5 rounded-full hover:border-neutral-400 hover:text-white transition-all font-medium">
            Free Consultation First
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { loadAndRenderHours } from '../../scripts/hoursDisplay.js';
    loadAndRenderHours('contact-hours-list');
  </script>

</Layout>
