---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Partners & Recommended Brands | Bliss Dermacare"
  description="Brands, products, and partners that Bliss Dermacare recommends and uses. Exclusive deals and referral links for skincare, wellness, and beauty."
>
  <!-- Page Header -->
  <section class="bg-[#f6f1eb] border-b border-neutral-200 py-14 lg:py-20">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="max-w-2xl">
        <span class="text-primary-600 uppercase tracking-[0.22em] text-xs font-semibold block mb-4">Trusted Brands</span>
        <h1 class="text-4xl lg:text-5xl font-serif text-neutral-900 leading-tight mb-5">
          Products &amp; Partners<br class="hidden sm:block" /> We Recommend.
        </h1>
        <p class="text-lg text-neutral-600 leading-relaxed">
          These are brands we genuinely use, trust, and recommend to our clients. Some links include exclusive deals negotiated specifically for the Bliss Dermacare community.
        </p>
      </div>
    </div>
  </section>

  <!-- Filter bar + Cards -->
  <section class="py-12 bg-white min-h-[60vh]">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">

      <!-- Category filter tabs -->
      <div id="filter-tabs" class="flex gap-2 overflow-x-auto pb-2 mb-8 -mx-6 px-6 lg:mx-0 lg:px-0 scrollbar-hide">
        <button class="filter-btn active shrink-0 px-4 py-2 rounded-full text-sm font-medium border border-primary-200 bg-primary-600 text-white transition-all" data-cat="all">
          All Partners
        </button>
      </div>

      <!-- Loading skeleton -->
      <div id="cards-loading" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <div class="h-56 rounded-2xl bg-neutral-100 animate-pulse"></div>
        <div class="h-56 rounded-2xl bg-neutral-100 animate-pulse"></div>
        <div class="h-56 rounded-2xl bg-neutral-100 animate-pulse"></div>
      </div>

      <!-- Partners grid — filled by JS -->
      <div id="partners-grid" class="hidden grid sm:grid-cols-2 lg:grid-cols-3 gap-5"></div>

      <!-- Empty state -->
      <div id="no-partners" class="hidden py-16 text-center">
        <div class="w-14 h-14 bg-neutral-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
        </div>
        <p class="text-neutral-500 text-sm">No partners listed yet — check back soon.</p>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="py-10 bg-[#faf9f7] border-t border-neutral-100">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="flex items-start gap-3 text-xs text-neutral-400 max-w-2xl">
        <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p>Some links on this page are affiliate or referral links. Bliss Dermacare may earn a small commission if you purchase through them — at no extra cost to you. We only recommend brands we genuinely trust and use in our practice.</p>
      </div>
    </div>
  </section>

</Layout>

<style>
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .filter-btn { cursor: pointer; }
  .filter-btn:not(.active) { background: white; color: #525252; border-color: #e5e5e5; }
  .filter-btn:not(.active):hover { border-color: #c7a8b5; color: #be185d; background: #fdf2f8; }
</style>

<script>
  const BADGE_COLORS = {
    'Skincare Products':    'bg-rose-100 text-rose-700',
    'Wellness & Supplements': 'bg-emerald-100 text-emerald-700',
    'Beauty Tools':         'bg-violet-100 text-violet-700',
    'Nutrition & Diet':     'bg-amber-100 text-amber-700',
    'Fitness & Health':     'bg-sky-100 text-sky-700',
    'Other':                'bg-neutral-100 text-neutral-600',
  };

  function esc(str: string): string {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function safeUrl(url: string): string {
    try {
      const u = new URL(url);
      return (u.protocol === 'http:' || u.protocol === 'https:') ? url : '#';
    } catch { return '#'; }
  }

  function renderCard(p: Record<string, any>): string {
    const catColor = (BADGE_COLORS as Record<string, string>)[p.category] || BADGE_COLORS['Other'];
    const logo = p.logo_url
      ? `<img src="${esc(p.logo_url)}" alt="${esc(p.name)}" class="max-h-12 max-w-[140px] object-contain" loading="lazy" />`
      : `<div class="w-12 h-12 rounded-xl bg-primary-100 flex items-center justify-center"><span class="text-primary-700 font-bold text-xl">${esc(p.name.charAt(0))}</span></div>`;

    const badge = p.badge_text
      ? `<div class="mt-3 inline-flex items-center gap-1.5 bg-primary-50 border border-primary-100 text-primary-700 text-xs font-semibold px-3 py-1 rounded-full">
           <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-5 5a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 10V5a2 2 0 012-2z"/></svg>
           ${esc(p.badge_text)}
         </div>`
      : '';

    return `
      <a href="${esc(safeUrl(p.url))}" target="_blank" rel="noopener noreferrer sponsored"
         class="group flex flex-col bg-white rounded-2xl border border-neutral-200 hover:border-primary-200 hover:shadow-xl transition-all duration-300 overflow-hidden">
        <!-- Logo area -->
        <div class="h-36 flex items-center justify-center px-8 bg-gradient-to-b from-[#f9f5f2] to-white border-b border-neutral-100">
          ${logo}
        </div>
        <!-- Content -->
        <div class="flex-1 flex flex-col p-5">
          <div class="flex items-start justify-between gap-2 mb-2">
            <h3 class="font-serif text-lg text-neutral-900 leading-snug group-hover:text-primary-700 transition-colors">${esc(p.name)}</h3>
            <svg class="w-4 h-4 text-neutral-300 group-hover:text-primary-500 transition-colors shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </div>
          <span class="inline-block text-[11px] font-semibold uppercase tracking-wide px-2 py-0.5 rounded-full mb-3 w-fit ${catColor}">${esc(p.category)}</span>
          ${p.tagline ? `<p class="text-sm text-neutral-500 leading-relaxed flex-1">${esc(p.tagline)}</p>` : '<div class="flex-1"></div>'}
          ${badge}
        </div>
        <!-- CTA footer -->
        <div class="px-5 pb-5">
          <span class="w-full flex items-center justify-center gap-2 bg-neutral-900 group-hover:bg-primary-600 text-white text-sm font-semibold py-3 rounded-xl transition-colors duration-200">
            Visit Partner
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </span>
        </div>
      </a>
    `;
  }

  let allPartners: any[] = [];
  let activeFilter = 'all';

  async function init() {
    const loading = document.getElementById('cards-loading')!;
    const grid    = document.getElementById('partners-grid')!;
    const empty   = document.getElementById('no-partners')!;
    const tabs    = document.getElementById('filter-tabs')!;

    try {
      const res = await fetch('/.netlify/functions/get-partners');
      if (!res.ok) throw new Error('fetch failed');
      const { records } = await res.json();
      allPartners = records || [];
    } catch (e) {
      allPartners = [];
    }

    loading!.classList.add('hidden');

    if (allPartners.length === 0) {
      empty.classList.remove('hidden');
      return;
    }

    // Build category tabs
    const cats = [...new Set(allPartners.map(p => p.category).filter(Boolean))].sort();
    cats.forEach(cat => {
      const btn = document.createElement('button');
      btn.className = 'filter-btn shrink-0 px-4 py-2 rounded-full text-sm font-medium border transition-all';
      btn.dataset.cat = cat;
      btn.textContent = cat;
      tabs.appendChild(btn);
    });

    // Tab click handler
    tabs.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeFilter = (btn as HTMLElement).dataset.cat ?? 'all';
        tabs.querySelectorAll('.filter-btn').forEach(b => {
          b.classList.toggle('active', b === btn);
          if (b === btn) {
            b.classList.add('bg-primary-600', 'text-white', 'border-primary-200');
            b.classList.remove('bg-white', 'text-neutral-700', 'border-neutral-200');
          } else {
            b.classList.remove('bg-primary-600', 'text-white', 'border-primary-200');
            b.classList.add('bg-white', 'text-neutral-700', 'border-neutral-200');
          }
        });
        renderGrid();
      });
    });

    grid.classList.remove('hidden');
    renderGrid();
  }

  function renderGrid() {
    const grid = document.getElementById('partners-grid')!;
    const filtered = activeFilter === 'all'
      ? allPartners
      : allPartners.filter(p => p.category === activeFilter);

    if (filtered.length === 0) {
      grid.innerHTML = '<div class="col-span-full py-10 text-center text-sm text-neutral-400">No partners in this category yet.</div>';
    } else {
      grid.innerHTML = filtered.map(renderCard).join('');
    }
  }

  init();
</script>
