---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="Pre-Service Forms" activeNav="pre-service-forms">

  <div class="p-6 lg:p-8">
    <div class="mb-6 flex items-start justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-2xl font-serif font-semibold text-neutral-900">Pre-Service Forms</h1>
        <p id="psf-count-label" class="text-sm text-neutral-500 mt-1">Loading…</p>
      </div>
      <a href="/pre-service-form/" target="_blank"
        class="inline-flex items-center gap-2 px-4 py-2.5 bg-white border border-neutral-200 hover:border-neutral-300 text-neutral-700 text-sm font-medium rounded-xl transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
        Public Form
      </a>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap items-center gap-3 mb-5">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input id="psf-search" type="text" placeholder="Search name or email…"
          class="pl-9 pr-4 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm w-56"/>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-xs text-neutral-500">Submitted:</span>
        <input id="psf-since" type="date"
          class="px-3 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm"/>
      </div>
      <button id="psf-load-btn"
        class="px-4 py-2.5 bg-white border border-neutral-300 hover:border-neutral-400 rounded-xl text-sm font-medium text-neutral-700 transition-colors">
        Load
      </button>
    </div>

    <!-- New / Unread badge -->
    <div id="psf-new-badge" class="hidden mb-4 inline-flex items-center gap-2 bg-blue-50 border border-blue-200 text-blue-800 text-xs font-semibold px-3 py-1.5 rounded-full">
      <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
      <span id="psf-new-count"></span> unread
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl border border-neutral-200 overflow-hidden">
      <div id="psf-table-wrap" class="overflow-x-auto">
        <div class="px-6 py-10 text-center text-neutral-400 text-sm">Loading…</div>
      </div>
    </div>
  </div>

  <!-- Detail slide-over -->
  <div id="psf-detail-panel" class="hidden fixed inset-y-0 right-0 w-full sm:w-[480px] bg-white shadow-2xl border-l border-neutral-200 z-50 flex flex-col">
    <div class="flex items-center justify-between px-6 py-4 border-b border-neutral-100 shrink-0">
      <h3 class="font-semibold text-neutral-900">Form Details</h3>
      <button id="psf-close-detail" class="p-1.5 rounded-lg text-neutral-400 hover:bg-neutral-100 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div id="psf-detail-content" class="flex-1 overflow-y-auto p-6 space-y-4 text-sm"></div>
  </div>
  <div id="psf-detail-overlay" class="hidden fixed inset-0 bg-black/20 z-40"></div>

  <script>
    import { requireLogin, apiFetch, getRole } from '../../../scripts/adminAuth.js';
    requireLogin();
    const role = getRole();
    void role;

    let allRecords: any[] = [];
    let fullRecords: any[] = []; // unfiltered source for client-side search
    let currentRecord: any = null;

    function esc(s: unknown) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    function pill(s: string, cls: string) {
      return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${cls}">${esc(s.replace(/_/g,' '))}</span>`;
    }
    const SKIN_COLORS: Record<string,string> = { acne:'bg-amber-100 text-amber-700', eczema:'bg-orange-100 text-orange-700', psoriasis:'bg-purple-100 text-purple-700', rosacea:'bg-rose-100 text-rose-700', sunburn:'bg-yellow-100 text-yellow-700', open_wounds:'bg-red-100 text-red-700' };
    const MED_COLORS:  Record<string,string> = { pregnant:'bg-pink-100 text-pink-700', chemotherapy:'bg-red-100 text-red-700', blood_disorder:'bg-red-100 text-red-700', recent_surgery:'bg-orange-100 text-orange-700', epilepsy:'bg-purple-100 text-purple-700', none:'bg-neutral-100 text-neutral-400' };

    // ── Load ──────────────────────────────────────────────────────────────────
    async function load() {
      const search = (document.getElementById('psf-search') as HTMLInputElement).value.trim().toLowerCase();
      const since  = (document.getElementById('psf-since')  as HTMLInputElement).value;

      const params: Record<string,string> = { limit: '500' };
      if (since) params.since = since + 'T00:00:00Z';

      const wrap = document.getElementById('psf-table-wrap')!;
      wrap.innerHTML = '<div class="px-6 py-10 text-center text-neutral-400 text-sm">Loading…</div>';

      try {
        const data = await apiFetch('admin-pre-service-forms', { params });
        fullRecords = data?.records || [];
        allRecords = fullRecords.filter((r: any) => {
          if (!search) return true;
          return (r.name || '').toLowerCase().includes(search) || (r.email || '').toLowerCase().includes(search);
        });

        document.getElementById('psf-count-label')!.textContent = `${allRecords.length} submission${allRecords.length !== 1 ? 's' : ''}`;

        // Unread badge (null read_at = unread)
        const unreadCount = fullRecords.filter((r: any) => !r.read_at).length;
        const badgeEl = document.getElementById('psf-new-badge')!;
        if (unreadCount > 0) {
          document.getElementById('psf-new-count')!.textContent = String(unreadCount);
          badgeEl.classList.remove('hidden');
          badgeEl.classList.add('inline-flex');
        } else {
          badgeEl.classList.add('hidden');
        }

        render();
      } catch (err: any) {
        wrap.innerHTML = `<div class="px-6 py-6 text-red-500 text-sm">${err.message}</div>`;
      }
    }

    function render() {
      const wrap = document.getElementById('psf-table-wrap')!;
      if (!allRecords.length) {
        wrap.innerHTML = '<div class="px-6 py-12 text-center text-neutral-400 text-sm">No submissions found.</div>';
        return;
      }
      const cutoff = Date.now() - 48 * 3600 * 1000;
      wrap.innerHTML = `
        <table class="min-w-full text-sm">
          <thead>
            <tr class="border-b border-neutral-100 text-xs font-semibold text-neutral-500 uppercase tracking-wide">
              <th class="px-6 py-3 text-left">Name</th>
              <th class="px-6 py-3 text-left hidden sm:table-cell">Contact</th>
              <th class="px-6 py-3 text-left hidden md:table-cell">Appt. Date</th>
              <th class="px-6 py-3 text-left hidden lg:table-cell">Skin / Medical</th>
              <th class="px-6 py-3 text-left">Submitted</th>
              <th class="px-6 py-3 text-center">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-50">
            ${allRecords.map((r: any) => {
              const isUnread = !r.read_at;
              const isNew = r.created_at && new Date(r.created_at).getTime() > cutoff;
              const skinList = (r.skin_conditions || []).slice(0, 2).map((s: string) => pill(s, SKIN_COLORS[s] || 'bg-neutral-100 text-neutral-600')).join(' ');
              const medList  = (r.medical_history  || []).filter((m: string) => m !== 'none').slice(0, 2).map((m: string) => pill(m, MED_COLORS[m] || 'bg-neutral-100 text-neutral-600')).join(' ');
              const submittedLabel = r.created_at ? new Date(r.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—';
              return `
              <tr class="hover:bg-neutral-50 cursor-pointer psf-row transition-colors${isUnread ? ' font-medium' : ''}" data-rec='${JSON.stringify(r).replace(/'/g,"&#39;")}'>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-2">
                    ${isUnread ? '<span class="w-2 h-2 rounded-full bg-blue-500 shrink-0" title="Unread"></span>' : '<span class="w-2 h-2 shrink-0"></span>'}
                    <div class="text-sm text-neutral-900">${esc(r.name || '—')}</div>
                  </div>
                </td>
                <td class="px-6 py-4 hidden sm:table-cell">
                  <div class="text-xs text-neutral-600">${esc(r.email || '—')}</div>
                  <div class="text-xs text-neutral-400">${esc(r.phone || '')}</div>
                </td>
                <td class="px-6 py-4 hidden md:table-cell text-xs text-neutral-700">${esc(r.appointment_date || '—')}</td>
                <td class="px-6 py-4 hidden lg:table-cell">
                  <div class="flex flex-wrap gap-1">${skinList || '<span class="text-neutral-300 text-xs">none</span>'}${medList}</div>
                </td>
                <td class="px-6 py-4 text-xs text-neutral-500">
                  ${submittedLabel}
                  ${isNew ? '<span class="ml-1 text-[10px] font-bold bg-blue-100 text-blue-600 px-1 rounded">NEW</span>' : ''}
                </td>
                <td class="px-6 py-4 text-center">
                  ${isUnread
                    ? '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-blue-100 text-blue-700">Unread</span>'
                    : '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-neutral-100 text-neutral-400">Read</span>'}
                </td>
              </tr>`;
            }).join('')}
          </tbody>
        </table>`;

      wrap.querySelectorAll('.psf-row').forEach(row => {
        row.addEventListener('click', () => {
          const r = JSON.parse((row as HTMLElement).dataset.rec || '{}');
          openDetail(r);
        });
      });
    }

    // ── Detail slide-over ─────────────────────────────────────────────────────
    function openDetail(r: any) {
      currentRecord = r;
      const content = document.getElementById('psf-detail-content')!;
      const submittedLabel = r.created_at ? new Date(r.created_at).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' }) : '—';
      const apptLabel = r.appointment_date ? new Date(r.appointment_date + 'T12:00:00').toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' }) : '—';
      const isUnread = !r.read_at;
      const readLabel = r.read_at ? new Date(r.read_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' } as any) : null;

      function row(label: string, value: string) {
        return `<div class="flex gap-3 py-2.5 border-b border-neutral-50 last:border-0">
          <span class="text-xs text-neutral-400 w-36 shrink-0 pt-0.5 font-medium">${label}</span>
          <span class="text-sm text-neutral-800 flex-1">${value || '<span class="text-neutral-300">—</span>'}</span>
        </div>`;
      }
      const skinPills = (r.skin_conditions || []).map((s: string) => pill(s, SKIN_COLORS[s] || 'bg-neutral-100 text-neutral-600')).join(' ');
      const medPills  = (r.medical_history  || []).map((m: string) => pill(m, MED_COLORS[m]  || 'bg-neutral-100 text-neutral-600')).join(' ');

      content.innerHTML = `
        <!-- Read/Unread action -->
        <div class="flex items-center justify-between pb-4 border-b border-neutral-100">
          <div class="flex items-center gap-2">
            ${isUnread
              ? '<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-700"><span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>Unread</span>'
              : `<span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-neutral-100 text-neutral-500">✓ Read${readLabel ? ' · ' + readLabel : ''}</span>`}
          </div>
          <button id="psf-toggle-read-btn"
            class="px-3 py-1.5 text-xs font-semibold border rounded-lg transition-colors ${isUnread
              ? 'border-emerald-200 text-emerald-700 hover:bg-emerald-50'
              : 'border-neutral-200 text-neutral-500 hover:bg-neutral-50'}">
            ${isUnread ? '✓ Mark as Read' : '↩ Mark as Unread'}
          </button>
        </div>

        <div class="bg-neutral-50 rounded-xl p-4 space-y-0">
          ${row('Name',           esc(r.name  || ''))}
          ${row('Email',          esc(r.email || ''))}
          ${row('Phone',          esc(r.phone || ''))}
          ${row('Appointment',    esc(apptLabel))}
          ${row('Age category',   esc(r.age_category || ''))}
        </div>
        ${r.guardian_name ? `
        <div class="bg-blue-50 rounded-xl p-4 space-y-0">
          <div class="text-xs font-semibold uppercase tracking-widest text-blue-400 mb-2">Guardian</div>
          ${row('Name',         esc(r.guardian_name || ''))}
          ${row('Relationship', esc(r.guardian_relationship || ''))}
          ${row('Phone',        esc(r.guardian_phone || ''))}
          ${row('Email',        esc(r.guardian_email || ''))}
        </div>` : ''}
        <div class="space-y-0">
          ${row('Skin conditions', skinPills || '—')}
          ${row('Allergies',       esc(r.allergies || ''))}
          ${row('Medical history', medPills  || '—')}
          ${row('Medications',     `<span class="whitespace-pre-line">${esc(r.medications || '')}</span>`)}
          ${row('Recent treatments', esc(r.recent_treatments || ''))}
          ${row('Alcohol (24h)',   esc(r.alcohol_consumption || ''))}
          ${row('Skin prep',       (r.skin_prep || []).map((s: string) => esc(s.replace(/_/g,' '))).join(', '))}
        </div>
        <div class="bg-neutral-50 rounded-xl p-4">
          <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-2">Acknowledgements</div>
          <div class="space-y-1 text-xs text-neutral-600">
            <div>Hygiene: <span class="text-emerald-600 font-medium">${esc(r.hygiene_acknowledgment || '—')}</span></div>
            <div>During/After: <span class="text-emerald-600 font-medium">${esc(r.appointment_acknowledgment || '—')}</span></div>
            <div>Post care: <span class="text-emerald-600 font-medium">${esc(r.post_care_acknowledgment || '—')}</span></div>
            <div>Refuse service: <span class="text-emerald-600 font-medium">${esc(r.refuse_service_acknowledgment || '—')}</span></div>
            <div>Refund policy: <span class="text-emerald-600 font-medium">${esc(r.refund_policy_acknowledgment || '—')}</span></div>
            <div>Health agreement: <span class="text-emerald-600 font-medium">${esc(r.health_agreement || '—')}</span></div>
          </div>
        </div>
        <div class="text-xs text-neutral-400 pt-2 space-y-1">
          <div>Submitted: ${esc(submittedLabel)}</div>
          ${r.ip ? `<div>IP: ${esc(r.ip)}</div>` : ''}
          <div class="flex gap-2 flex-wrap mt-3">
            <a href="/admin/clients?email=${encodeURIComponent(r.email || '')}" class="text-xs text-primary-600 hover:underline font-medium">View client profile →</a>
          </div>
        </div>`;

      // Mark as read / unread toggle
      document.getElementById('psf-toggle-read-btn')?.addEventListener('click', async () => {
        const btn = document.getElementById('psf-toggle-read-btn') as HTMLButtonElement;
        btn.disabled = true; btn.textContent = 'Saving…';
        try {
          await apiFetch('admin-pre-service-forms', { method: 'PATCH', body: { id: r.id, read: isUnread } });
          // Update local record and re-open
          r.read_at = isUnread ? new Date().toISOString() : null;
          // Update fullRecords too
          const idx = fullRecords.findIndex(rec => rec.id === r.id);
          if (idx >= 0) fullRecords[idx] = { ...fullRecords[idx], read_at: r.read_at };
          const aidx = allRecords.findIndex(rec => rec.id === r.id);
          if (aidx >= 0) allRecords[aidx] = { ...allRecords[aidx], read_at: r.read_at };
          // Refresh unread badge
          const unreadCount = fullRecords.filter(rec => !rec.read_at).length;
          const badgeEl = document.getElementById('psf-new-badge')!;
          document.getElementById('psf-new-count')!.textContent = String(unreadCount);
          if (unreadCount > 0) { badgeEl.classList.remove('hidden'); badgeEl.classList.add('inline-flex'); }
          else { badgeEl.classList.add('hidden'); }
          render();
          openDetail(r); // re-render the detail panel with updated state
        } catch (err: any) {
          btn.disabled = false;
          btn.textContent = isUnread ? '✓ Mark as Read' : '↩ Mark as Unread';
          alert(`Failed: ${err.message}`);
        }
      });

      document.getElementById('psf-detail-panel')?.classList.remove('hidden');
      document.getElementById('psf-detail-panel')?.classList.add('flex');
      document.getElementById('psf-detail-overlay')?.classList.remove('hidden');
    }

    function closeDetail() {
      document.getElementById('psf-detail-panel')?.classList.add('hidden');
      document.getElementById('psf-detail-panel')?.classList.remove('flex');
      document.getElementById('psf-detail-overlay')?.classList.add('hidden');
    }
    document.getElementById('psf-close-detail')?.addEventListener('click', closeDetail);
    document.getElementById('psf-detail-overlay')?.addEventListener('click', closeDetail);

    // ── Filters ───────────────────────────────────────────────────────────────
    document.getElementById('psf-load-btn')?.addEventListener('click', load);
    let searchTimer: ReturnType<typeof setTimeout>;
    document.getElementById('psf-search')?.addEventListener('input', () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        const search = (document.getElementById('psf-search') as HTMLInputElement).value.trim().toLowerCase();
        allRecords = fullRecords.filter((r: any) =>
          !search || (r.name || '').toLowerCase().includes(search) || (r.email || '').toLowerCase().includes(search));
        document.getElementById('psf-count-label')!.textContent = `${allRecords.length} submission${allRecords.length !== 1 ? 's' : ''}`;
        render();
      }, 350);
    });

    // Init
    load();
  </script>

</AdminLayout>
