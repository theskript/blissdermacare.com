---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="Appointments" activeNav="appointments">

  <div class="p-6 lg:p-8">
    <div class="mb-6 flex items-start justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-2xl font-serif font-semibold text-neutral-900">Appointments</h1>
        <p id="appt-count-label" class="text-sm text-neutral-500 mt-1">Loading…</p>
      </div>
      <a href="/admin/new-appointment"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold rounded-xl transition-colors shadow-sm shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        New Appointment
      </a>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap items-center gap-3 mb-5">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input id="appt-search" type="text" placeholder="Search name, email, phone…"
          class="pl-9 pr-4 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm w-64"/>
      </div>
      <select id="appt-status-filter"
        class="px-3 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm bg-white">
        <option value="">All statuses</option>
        <option value="Pending Confirmation">Pending Confirmation</option>
        <option value="Pending Payment">Pending Payment</option>
        <option value="Confirmed">Confirmed</option>
        <option value="Completed">Completed</option>
        <option value="Cancelled">Cancelled</option>
        <option value="No-Show">No-Show</option>
      </select>
      <input id="appt-start-date" type="date"
        class="px-3 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm"/>
      <input id="appt-end-date" type="date"
        class="px-3 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm"/>
      <button id="appt-filter-btn"
        class="px-4 py-2.5 bg-white border border-neutral-300 hover:border-neutral-400 rounded-xl text-sm font-medium text-neutral-700 transition-colors">
        Filter
      </button>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl border border-neutral-200 overflow-hidden">
      <div id="appt-table-wrap" class="overflow-x-auto">
        <div class="px-6 py-10 text-center text-neutral-400 text-sm">Loading…</div>
      </div>
    </div>
  </div>

  <!-- Edit slide-over -->
  <div id="appt-detail-panel" class="hidden fixed inset-y-0 right-0 w-full sm:w-[440px] bg-white shadow-2xl border-l border-neutral-200 z-50 flex flex-col">
    <div class="flex items-center justify-between px-6 py-4 border-b border-neutral-100 shrink-0">
      <h3 class="font-semibold text-neutral-900">Edit Appointment</h3>
      <button id="appt-close-detail" class="p-1.5 rounded-lg text-neutral-400 hover:bg-neutral-100 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div id="appt-detail-content" class="flex-1 overflow-y-auto p-6 space-y-5"></div>
  </div>
  <div id="appt-detail-overlay" class="hidden fixed inset-0 bg-black/20 z-40"></div>

  <script>
    import { requireLogin, apiFetch, getRole, formatDate } from '../../../scripts/adminAuth.js';
    requireLogin();
    const role = getRole();

    const STATUS_COLORS: Record<string,string> = {
      'Confirmed':            'bg-emerald-100 text-emerald-700',
      'Completed':            'bg-blue-100 text-blue-700',
      'Pending Payment':      'bg-amber-100 text-amber-700',
      'Pending Confirmation': 'bg-orange-100 text-orange-700',
      'Cancelled':            'bg-red-100 text-red-700',
      'No-Show':              'bg-purple-100 text-purple-700',
    };

    let currentRec: any = null;
    let allRecords: any[] = [];

    function esc(s: unknown) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    // ── Load ──────────────────────────────────────────────────────────────────
    async function load() {
      const search    = (document.getElementById('appt-search')       as HTMLInputElement).value.trim();
      const status    = (document.getElementById('appt-status-filter')as HTMLSelectElement).value;
      const startDate = (document.getElementById('appt-start-date')   as HTMLInputElement).value;
      const endDate   = (document.getElementById('appt-end-date')     as HTMLInputElement).value;

      const params: Record<string,string> = {};
      if (search)    params.search    = search;
      if (status)    params.status    = status;
      if (startDate) params.startDate = startDate;
      if (endDate)   params.endDate   = endDate;
      if (!startDate && !endDate) {
        // default: current month
        const now = new Date();
        const y = now.getFullYear(), m = String(now.getMonth()+1).padStart(2,'0');
        params.startDate = `${y}-${m}-01`;
        params.endDate   = `${y}-${m}-${new Date(y, now.getMonth()+1, 0).getDate()}`;
        if (!(document.getElementById('appt-start-date') as HTMLInputElement).value) {
          (document.getElementById('appt-start-date') as HTMLInputElement).value = params.startDate;
          (document.getElementById('appt-end-date')   as HTMLInputElement).value = params.endDate;
        }
      }

      const wrap = document.getElementById('appt-table-wrap')!;
      wrap.innerHTML = '<div class="px-6 py-10 text-center text-neutral-400 text-sm">Loading…</div>';

      try {
        const data = await apiFetch('admin-appointments', { params });
        allRecords = data?.records || [];
        const label = document.getElementById('appt-count-label')!;
        label.textContent = `${allRecords.length} appointment${allRecords.length !== 1 ? 's' : ''}`;
        render();
      } catch (err: any) {
        wrap.innerHTML = `<div class="px-6 py-6 text-red-500 text-sm">${err.message}</div>`;
      }
    }

    function render() {
      const wrap = document.getElementById('appt-table-wrap')!;
      if (!allRecords.length) {
        wrap.innerHTML = '<div class="px-6 py-12 text-center text-neutral-400 text-sm">No appointments found for this period.</div>';
        return;
      }
      const isOwner = role === 'owner';
      wrap.innerHTML = `
        <table class="min-w-full text-sm">
          <thead>
            <tr class="border-b border-neutral-100 text-xs font-semibold text-neutral-500 uppercase tracking-wide">
              <th class="px-6 py-3 text-left">Date / Time</th>
              <th class="px-6 py-3 text-left">Client</th>
              <th class="px-6 py-3 text-left hidden md:table-cell">Services</th>
              <th class="px-6 py-3 text-left">Status</th>
              ${isOwner ? '<th class="px-6 py-3 text-right hidden lg:table-cell">Price</th>' : ''}
              <th class="px-6 py-3 text-left hidden lg:table-cell">Source</th>
              <th class="px-6 py-3 text-center hidden xl:table-cell">PSF</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-50">
            ${allRecords.map(rec => {
              const f = rec.fields;
              const sCls = STATUS_COLORS[f['Status']] || 'bg-neutral-100 text-neutral-600';
              const hasPSF = f['hasPSF'];
              return `
              <tr class="hover:bg-neutral-50 cursor-pointer appt-row transition-colors" data-rec='${JSON.stringify(rec).replace(/'/g,"&#39;")}'>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-neutral-900">${formatDate(f['Date'])}</div>
                  <div class="text-xs text-neutral-400">${esc(f['Time'] || '—')}</div>
                </td>
                <td class="px-6 py-4">
                  <div class="text-sm font-semibold text-neutral-900">${esc(f['Client Name'] || '—')}</div>
                  <div class="text-xs text-neutral-400">${esc(f['Client Phone'] || f['Client Email'] || '')}</div>
                </td>
                <td class="px-6 py-4 hidden md:table-cell max-w-[200px]">
                  <div class="text-xs text-neutral-600 truncate">${esc((f['Services'] || '—').substring(0, 60))}</div>
                </td>
                <td class="px-6 py-4">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold ${sCls}">${esc(f['Status'] || '—')}</span>
                </td>
                ${isOwner ? `<td class="px-6 py-4 text-right text-sm font-semibold text-primary-700 hidden lg:table-cell">${f['Price'] != null ? '$' + Number(f['Price']).toFixed(0) : '—'}</td>` : ''}
                <td class="px-6 py-4 text-xs text-neutral-400 hidden lg:table-cell">${esc(f['Source'] || '—')}</td>
                <td class="px-6 py-4 text-center hidden xl:table-cell">
                  ${hasPSF === false
                    ? '<span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-bold bg-amber-100 text-amber-700">No PSF</span>'
                    : hasPSF === true
                      ? '<span class="text-emerald-500 text-xs">✓</span>'
                      : '<span class="text-neutral-300 text-xs">—</span>'}
                </td>
              </tr>`;
            }).join('')}
          </tbody>
        </table>`;

      wrap.querySelectorAll('.appt-row').forEach(row => {
        row.addEventListener('click', () => {
          const rec = JSON.parse((row as HTMLElement).dataset.rec || '{}');
          openDetail(rec);
        });
      });
    }

    // ── Edit slide-over ───────────────────────────────────────────────────────
    function openDetail(rec: any) {
      currentRec = rec;
      const f = rec.fields;
      const statusOptions = ['Pending Confirmation','Pending Payment','Confirmed','Completed','Cancelled','No-Show'];
      const content = document.getElementById('appt-detail-content')!;
      const isOwner = role === 'owner';

      content.innerHTML = `
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Client</div>
          ${isOwner
            ? `<div class="space-y-2">
                <input id="ap-name"  type="text"  value="${esc(f['Client Name']  || '')}" placeholder="Name"  class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none"/>
                <input id="ap-email" type="email" value="${esc(f['Client Email'] || '')}" placeholder="Email" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none"/>
                <input id="ap-phone" type="tel"   value="${esc(f['Client Phone'] || '')}" placeholder="Phone" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none"/>
              </div>`
            : `<div class="text-sm font-semibold text-neutral-900">${esc(f['Client Name'] || '—')}</div>
               <div class="text-sm text-neutral-500">${esc(f['Client Email'] || '')}</div>
               <div class="text-sm text-neutral-500">${esc(f['Client Phone'] || '')}</div>`}
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Date</div>
            ${isOwner
              ? `<input id="ap-date" type="date" value="${esc(f['Date'] || '')}" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none"/>`
              : `<div class="text-sm text-neutral-800">${formatDate(f['Date'])}</div>`}
          </div>
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Time</div>
            ${isOwner
              ? `<input id="ap-time" type="text" value="${esc(f['Time'] || '')}" placeholder="2:00 PM" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none"/>`
              : `<div class="text-sm text-neutral-800">${esc(f['Time'] || '—')}</div>`}
          </div>
        </div>
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Services</div>
          ${isOwner
            ? `<input id="ap-services" type="text" value="${esc(f['Services'] || '')}" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none"/>`
            : `<div class="text-sm text-neutral-800">${esc(f['Services'] || '—')}</div>`}
        </div>
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-2">Status</div>
          <select id="ap-status" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 outline-none">
            ${statusOptions.map(s => `<option value="${s}" ${f['Status'] === s ? 'selected' : ''}>${s}</option>`).join('')}
          </select>
        </div>
        ${isOwner ? `
        <div class="grid grid-cols-2 gap-4">
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Price ($)</div>
            <input id="ap-price" type="number" step="0.01" value="${f['Price'] ?? ''}" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none"/>
          </div>
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Source</div>
            <input id="ap-source" type="text" value="${esc(f['Source'] || '')}" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none"/>
          </div>
        </div>` : ''}
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Client Notes</div>
          <textarea id="ap-notes" rows="2" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none resize-none">${esc(f['Notes'] || '')}</textarea>
        </div>
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Internal Notes</div>
          <textarea id="ap-internal" rows="2" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none resize-none">${esc(f['Internal Notes'] || '')}</textarea>
        </div>
        <div class="flex gap-3 pt-2">
          <button id="ap-save-btn" class="flex-1 py-2.5 bg-primary-600 hover:bg-primary-700 disabled:opacity-50 text-white text-sm font-semibold rounded-xl">Save</button>
          ${isOwner ? `<button id="ap-del-btn" class="py-2.5 px-4 border border-red-200 text-red-500 hover:bg-red-50 text-sm font-semibold rounded-xl">Delete</button>` : ''}
        </div>
        <div id="ap-msg" class="text-xs text-center hidden"></div>
      `;

      document.getElementById('appt-detail-panel')?.classList.remove('hidden');
      document.getElementById('appt-detail-panel')?.classList.add('flex');
      document.getElementById('appt-detail-overlay')?.classList.remove('hidden');

      const saveBtn = document.getElementById('ap-save-btn') as HTMLButtonElement;
      const msgEl   = document.getElementById('ap-msg')!;

      document.getElementById('ap-save-btn')?.addEventListener('click', async () => {
        saveBtn.disabled = true; saveBtn.textContent = 'Saving…';
        const fields: Record<string, any> = {
          Status:           (document.getElementById('ap-status')   as HTMLSelectElement).value,
          Notes:            (document.getElementById('ap-notes')    as HTMLTextAreaElement).value,
          'Internal Notes': (document.getElementById('ap-internal') as HTMLTextAreaElement).value,
        };
        if (isOwner) {
          fields['Client Name']  = (document.getElementById('ap-name')     as HTMLInputElement).value.trim();
          fields['Client Email'] = (document.getElementById('ap-email')    as HTMLInputElement).value.trim().toLowerCase();
          fields['Client Phone'] = (document.getElementById('ap-phone')    as HTMLInputElement).value.trim();
          fields['Date']         = (document.getElementById('ap-date')     as HTMLInputElement).value;
          fields['Time']         = (document.getElementById('ap-time')     as HTMLInputElement).value;
          fields['Services']     = (document.getElementById('ap-services') as HTMLInputElement).value;
          const priceVal = parseFloat((document.getElementById('ap-price') as HTMLInputElement).value);
          if (!isNaN(priceVal)) fields['Price'] = priceVal;
          fields['Source'] = (document.getElementById('ap-source') as HTMLInputElement).value;
        }
        try {
          await apiFetch('admin-appointments', { method: 'PATCH', body: { id: rec.id, fields } });
          Object.assign(currentRec.fields, fields);
          msgEl.textContent = '✓ Saved'; msgEl.className = 'text-xs text-center text-emerald-600';
          await load();
        } catch (err: any) {
          msgEl.textContent = `Error: ${err.message}`; msgEl.className = 'text-xs text-center text-red-500';
        } finally {
          saveBtn.disabled = false; saveBtn.textContent = 'Save';
        }
      });

      document.getElementById('ap-del-btn')?.addEventListener('click', async () => {
        if (!confirm(`Delete appointment for ${f['Client Name']}?`)) return;
        try {
          await apiFetch('admin-appointments', { method: 'DELETE', body: { id: rec.id } });
          closeDetail();
          await load();
        } catch (err: any) { alert(`Delete failed: ${err.message}`); }
      });
    }

    function closeDetail() {
      document.getElementById('appt-detail-panel')?.classList.add('hidden');
      document.getElementById('appt-detail-panel')?.classList.remove('flex');
      document.getElementById('appt-detail-overlay')?.classList.add('hidden');
    }
    document.getElementById('appt-close-detail')?.addEventListener('click', closeDetail);
    document.getElementById('appt-detail-overlay')?.addEventListener('click', closeDetail);

    // ── Filters ───────────────────────────────────────────────────────────────
    document.getElementById('appt-filter-btn')?.addEventListener('click', load);
    let searchTimer: ReturnType<typeof setTimeout>;
    document.getElementById('appt-search')?.addEventListener('input', () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(load, 400);
    });

    // Init
    load();
  </script>

</AdminLayout>
