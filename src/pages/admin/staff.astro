---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Staff Management" activeNav="staff">

  <div class="p-6 lg:p-8 max-w-3xl">
    <div class="mb-8 flex items-start justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-2xl font-serif font-semibold text-neutral-900">Staff Management</h1>
        <p class="text-sm text-neutral-500 mt-1">Add and manage individual staff accounts. Each person gets their own username and password.</p>
      </div>
      <button id="open-add-modal"
        class="px-4 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold rounded-xl transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add Staff Member
      </button>
    </div>

    <!-- Owner bootstrap notice -->
    <div class="flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 mb-6 text-sm text-amber-800">
      <svg class="w-4 h-4 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <strong>Note:</strong> The <code class="bg-amber-100 px-1 rounded text-xs">owner</code> bootstrap account (via <code class="bg-amber-100 px-1 rounded text-xs">ADMIN_PASSWORD</code> env var) always exists as a fallback. 
        Create a named owner account here to replace it with a proper audited account.
      </div>
    </div>

    <!-- Staff table -->
    <div class="bg-white rounded-2xl border border-neutral-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-neutral-100">
        <h2 class="font-semibold text-neutral-900 text-sm">Accounts</h2>
      </div>
      <div id="staff-list">
        <div class="px-6 py-10 text-center text-neutral-400 text-sm">Loading…</div>
      </div>
    </div>
  </div>

  <!-- Add Staff Modal -->
  <div id="add-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40" id="modal-overlay"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 z-10">
      <h3 class="font-semibold text-neutral-900 mb-5">Add Staff Member</h3>
      <div id="modal-error" class="hidden mb-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-neutral-600 mb-1.5">Full Name *</label>
            <input id="new-name" type="text" placeholder="Jane Smith"
              class="w-full px-3 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none text-sm" />
          </div>
          <div>
            <label class="block text-xs font-medium text-neutral-600 mb-1.5">Username *</label>
            <input id="new-username" type="text" placeholder="jane"
              class="w-full px-3 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none text-sm" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-neutral-600 mb-1.5">Role *</label>
          <select id="new-role"
            class="w-full px-3 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none text-sm">
            <option value="staff">Staff — today's schedule, status updates only</option>
            <option value="owner">Owner — full access including revenue and delete</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-neutral-600 mb-1.5">Password * (min 8 characters)</label>
          <input id="new-password" type="password" placeholder="••••••••"
            class="w-full px-3 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none text-sm" />
        </div>
      </div>
      <div class="flex gap-3 mt-6">
        <button id="cancel-add" class="flex-1 py-2.5 border border-neutral-300 text-neutral-700 text-sm font-semibold rounded-xl hover:bg-neutral-50 transition-colors">Cancel</button>
        <button id="confirm-add" class="flex-1 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold rounded-xl transition-colors">Create Account</button>
      </div>
    </div>
  </div>

  <!-- Reset Password Modal -->
  <div id="reset-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 z-10">
      <h3 class="font-semibold text-neutral-900 mb-1">Reset Password</h3>
      <p id="reset-modal-name" class="text-sm text-neutral-500 mb-5"></p>
      <div id="reset-error" class="hidden mb-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
      <div>
        <label class="block text-xs font-medium text-neutral-600 mb-1.5">New Password * (min 8 characters)</label>
        <input id="reset-password" type="password" placeholder="••••••••"
          class="w-full px-3 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none text-sm" />
      </div>
      <div class="flex gap-3 mt-5">
        <button id="cancel-reset" class="flex-1 py-2.5 border border-neutral-300 text-neutral-700 text-sm font-semibold rounded-xl hover:bg-neutral-50 transition-colors">Cancel</button>
        <button id="confirm-reset" class="flex-1 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold rounded-xl transition-colors">Set Password</button>
      </div>
    </div>
  </div>

  <script>
    import { requireLogin, getRole, apiFetch } from '../../scripts/adminAuth.js';
    requireLogin();
    if (getRole() !== 'owner') window.location.href = '/admin/';

    let resetTargetId = '';

    const ROLE_BADGE: Record<string, string> = {
      owner: 'bg-primary-100 text-primary-700',
      staff: 'bg-neutral-100 text-neutral-600',
    };

    async function loadStaff() {
      try {
        const data = await apiFetch('admin-staff');
        const list = document.getElementById('staff-list')!;
        const records = data?.records || [];

        if (records.length === 0) {
          list.innerHTML = '<div class="px-6 py-10 text-center text-neutral-400 text-sm">No staff accounts yet. Add your first one above.</div>';
          return;
        }

        list.innerHTML = `
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-neutral-100">
                <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">Name</th>
                <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">Username</th>
                <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">Role</th>
                <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">Status</th>
                <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">Last Login</th>
                <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-widest text-neutral-400">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-100">
              ${records.map((rec: any) => {
                const f = rec.fields;
                const active = f['Active'] !== false;
                const lastLogin = f['Last Login']
                  ? new Date(f['Last Login']).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' })
                  : 'Never';
                const roleCls = ROLE_BADGE[f['Role']] || 'bg-neutral-100 text-neutral-600';
                return `
                  <tr class="${active ? '' : 'opacity-50'}">
                    <td class="px-6 py-4 font-medium text-neutral-900">${f['Name'] || '—'}</td>
                    <td class="px-6 py-4 text-neutral-500 font-mono text-xs">${f['Username'] || '—'}</td>
                    <td class="px-6 py-4">
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold capitalize ${roleCls}">${f['Role'] || '—'}</span>
                    </td>
                    <td class="px-6 py-4">
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold ${active ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-600'}">${active ? 'Active' : 'Deactivated'}</span>
                    </td>
                    <td class="px-6 py-4 text-xs text-neutral-400">${lastLogin}</td>
                    <td class="px-6 py-4 text-right">
                      <div class="flex items-center justify-end gap-2">
                        <button class="reset-pw-btn text-xs text-primary-600 hover:text-primary-800 font-medium" data-id="${rec.id}" data-name="${f['Name'] || f['Username']}">
                          Reset PW
                        </button>
                        <button class="toggle-active-btn text-xs ${active ? 'text-red-500 hover:text-red-700' : 'text-emerald-600 hover:text-emerald-800'} font-medium"
                          data-id="${rec.id}" data-active="${active}">
                          ${active ? 'Deactivate' : 'Activate'}
                        </button>
                      </div>
                    </td>
                  </tr>`;
              }).join('')}
            </tbody>
          </table>`;

        // Toggle active
        list.querySelectorAll('.toggle-active-btn').forEach(btn => {
          btn.addEventListener('click', async () => {
            const id = (btn as HTMLElement).dataset.id!;
            const currently = (btn as HTMLElement).dataset.active === 'true';
            if (currently && !confirm('Deactivate this account? They will be immediately logged out on their next request.')) return;
            try {
              await apiFetch('admin-staff', { method: 'PATCH', body: { id, fields: { Active: !currently } } });
              loadStaff();
            } catch (err: any) { alert(`Error: ${err.message}`); }
          });
        });

        // Reset password
        list.querySelectorAll('.reset-pw-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            resetTargetId = (btn as HTMLElement).dataset.id!;
            const name = (btn as HTMLElement).dataset.name!;
            document.getElementById('reset-modal-name')!.textContent = `For: ${name}`;
            (document.getElementById('reset-password') as HTMLInputElement).value = '';
            document.getElementById('reset-error')!.classList.add('hidden');
            document.getElementById('reset-modal')!.classList.remove('hidden');
          });
        });

      } catch (err: any) {
        document.getElementById('staff-list')!.innerHTML =
          `<div class="px-6 py-10 text-center text-red-400 text-sm">Error: ${err.message}</div>`;
      }
    }

    // Add modal
    document.getElementById('open-add-modal')?.addEventListener('click', () => {
      document.getElementById('modal-error')!.classList.add('hidden');
      (document.getElementById('new-name') as HTMLInputElement).value = '';
      (document.getElementById('new-username') as HTMLInputElement).value = '';
      (document.getElementById('new-password') as HTMLInputElement).value = '';
      document.getElementById('add-modal')!.classList.remove('hidden');
    });
    document.getElementById('modal-overlay')?.addEventListener('click', () => document.getElementById('add-modal')!.classList.add('hidden'));
    document.getElementById('cancel-add')?.addEventListener('click', () => document.getElementById('add-modal')!.classList.add('hidden'));

    document.getElementById('confirm-add')?.addEventListener('click', async () => {
      const name     = (document.getElementById('new-name')     as HTMLInputElement).value.trim();
      const username = (document.getElementById('new-username') as HTMLInputElement).value.trim();
      const role     = (document.getElementById('new-role')     as HTMLSelectElement).value;
      const password = (document.getElementById('new-password') as HTMLInputElement).value;
      const errEl    = document.getElementById('modal-error')!;

      if (!name || !username || !password) { errEl.textContent = 'All fields are required.'; errEl.classList.remove('hidden'); return; }
      try {
        await apiFetch('admin-staff', { method: 'POST', body: { name, username, password, role } });
        document.getElementById('add-modal')!.classList.add('hidden');
        loadStaff();
      } catch (err: any) { errEl.textContent = err.message; errEl.classList.remove('hidden'); }
    });

    // Reset modal
    document.getElementById('cancel-reset')?.addEventListener('click', () => document.getElementById('reset-modal')!.classList.add('hidden'));
    document.getElementById('confirm-reset')?.addEventListener('click', async () => {
      const newPw = (document.getElementById('reset-password') as HTMLInputElement).value;
      const errEl = document.getElementById('reset-error')!;
      if (!newPw) { errEl.textContent = 'Please enter a new password.'; errEl.classList.remove('hidden'); return; }
      try {
        await apiFetch('admin-staff', { method: 'PATCH', body: { id: resetTargetId, resetPassword: newPw } });
        document.getElementById('reset-modal')!.classList.add('hidden');
        alert('Password reset successfully.');
      } catch (err: any) { errEl.textContent = err.message; errEl.classList.remove('hidden'); }
    });

    loadStaff();
  </script>

</AdminLayout>
