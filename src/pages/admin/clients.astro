---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Clients" activeNav="clients">

  <div class="p-6 lg:p-8">
    <div class="mb-6 flex items-center justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-2xl font-serif font-semibold text-neutral-900">Clients</h1>
        <p id="client-count-label" class="text-sm text-neutral-500 mt-1">Loading…</p>
      </div>
      <div class="flex items-center gap-3">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input id="search-input" type="text" placeholder="Search name, email, phone…"
            class="pl-9 pr-4 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm w-64" />
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-5 gap-6">

      <!-- Client list -->
      <div class="lg:col-span-2 space-y-1" id="client-list">
        <div class="text-center py-12 text-neutral-400 text-sm">Loading clients…</div>
      </div>

      <!-- Client detail -->
      <div class="lg:col-span-3">
        <div id="client-detail" class="bg-white rounded-2xl border border-neutral-200 overflow-hidden sticky top-6">
          <div class="px-6 py-10 text-center text-neutral-400">
            <svg class="w-10 h-10 mx-auto mb-3 text-neutral-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <p class="text-sm">Select a client to view their history</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script>
    import { requireLogin, apiFetch, getRole, formatDate } from '../../scripts/adminAuth.js';
    requireLogin();

    const role = getRole();

    const STATUS_COLORS: Record<string, string> = {
      'Confirmed':       'bg-emerald-100 text-emerald-700',
      'Completed':       'bg-blue-100 text-blue-700',
      'Pending Payment': 'bg-amber-100 text-amber-700',
      'Cancelled':       'bg-red-100 text-red-700',
      'No-Show':         'bg-purple-100 text-purple-700',
    };

    let allClients: any[] = [];
    let selectedEmail = '';

    // ── Avatar initials ───────────────────────────────────────────────────────
    function initials(name: string) {
      const parts = (name || '?').split(' ').filter(Boolean);
      return (parts[0]?.[0] || '') + (parts[1]?.[0] || '');
    }
    function avatarColor(name: string) {
      const colors = ['bg-rose-200 text-rose-800', 'bg-amber-200 text-amber-800',
        'bg-emerald-200 text-emerald-800', 'bg-blue-200 text-blue-800',
        'bg-purple-200 text-purple-800', 'bg-pink-200 text-pink-800'];
      let hash = 0;
      for (const c of name) hash = (hash * 31 + c.charCodeAt(0)) & 0xffff;
      return colors[hash % colors.length];
    }

    // ── Render client list ────────────────────────────────────────────────────
    function renderList(clients: any[]) {
      const el = document.getElementById('client-list')!;
      const countEl = document.getElementById('client-count-label')!;
      countEl.textContent = `${clients.length} client${clients.length !== 1 ? 's' : ''}`;

      if (clients.length === 0) {
        el.innerHTML = '<div class="text-center py-12 text-neutral-400 text-sm">No clients found.</div>';
        return;
      }

      el.innerHTML = clients.map(c => {
        const avCls = avatarColor(c.name || c.email);
        const isSelected = (c.email || c.name) === selectedEmail;
        const memBadge = c.membership
          ? `<span class="mt-0.5 inline-flex items-center px-1.5 py-0.5 rounded-full text-xs font-semibold ${c.membership.status === 'active' ? 'bg-primary-100 text-primary-700' : 'bg-amber-100 text-amber-700'}">★ ${c.membership.status === 'active' ? 'Member' : c.membership.status}</span>`
          : '';
        return `
          <div class="client-card flex items-center gap-3 px-4 py-3 rounded-xl cursor-pointer hover:bg-white hover:shadow-sm border transition-all ${isSelected ? 'bg-white shadow-sm border-primary-200' : 'bg-transparent border-transparent'}"
            data-email="${c.email}" data-client='${JSON.stringify(c).replace(/'/g, "&#39;")}'>
            <div class="w-10 h-10 rounded-full ${avCls} flex items-center justify-center font-semibold text-sm shrink-0 uppercase">
              ${initials(c.name)}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-1.5 flex-wrap">
                <div class="text-sm font-semibold text-neutral-900 truncate">${c.name || '—'}</div>
                ${memBadge}
              </div>
              <div class="text-xs text-neutral-400 truncate">${c.email || c.phone || '—'}</div>
            </div>
            <div class="text-right shrink-0">
              <div class="text-xs font-bold text-neutral-700">${c.totalVisits}</div>
              <div class="text-xs text-neutral-400">visit${c.totalVisits !== 1 ? 's' : ''}</div>
            </div>
          </div>`;
      }).join('');

      el.querySelectorAll('.client-card').forEach(card => {
        card.addEventListener('click', () => {
          const client = JSON.parse((card as HTMLElement).dataset.client || '{}');
          selectedEmail = (card as HTMLElement).dataset.email || client.name || '';
          renderDetail(client);
          renderList(allClients);
          el.querySelectorAll('.client-card').forEach(c => {
            const isThis = (c as HTMLElement).dataset.email === selectedEmail;
            c.classList.toggle('bg-white', isThis);
            c.classList.toggle('shadow-sm', isThis);
            c.classList.toggle('border-primary-200', isThis);
            c.classList.toggle('bg-transparent', !isThis);
            c.classList.toggle('border-transparent', !isThis);
          });
        });
      });
    }

    // ── Render client detail panel ────────────────────────────────────────────
    function renderDetail(client: any) {
      const el = document.getElementById('client-detail')!;
      const avCls = avatarColor(client.name || client.email);
      const appts = (client.appointments || []).sort((a: any, b: any) => b.date.localeCompare(a.date));

      el.innerHTML = `
        <div class="px-6 py-5 border-b border-neutral-100 flex items-start gap-4">
          <div class="w-14 h-14 rounded-2xl ${avCls} flex items-center justify-center font-bold text-xl shrink-0 uppercase">
            ${initials(client.name)}
          </div>
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <div>
            <h3 class="text-lg font-semibold text-neutral-900">${client.name || '—'}</h3>
            ${client.email ? `<div class="text-sm text-neutral-500">${client.email}</div>` : ''}
            ${client.phone ? `<div class="text-sm text-neutral-500">${client.phone}</div>` : ''}
            ${client.membership ? (() => {
              const m = client.membership;
              const isActive = m.status === 'active';
              const statusCls = isActive ? 'bg-primary-100 text-primary-700' : m.status === 'past_due' ? 'bg-amber-100 text-amber-700' : 'bg-neutral-100 text-neutral-500';
              const renewsLabel = m.renewsAt ? `Renews ${new Date(m.renewsAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}` : '';
              return `<div class="flex items-center gap-2 mt-1.5 flex-wrap">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold ${statusCls}">★ ${m.planLabel || m.plan}</span>
                <span class="text-xs text-neutral-400 capitalize">${m.status}${renewsLabel ? ' · ' + renewsLabel : ''}</span>
              </div>`;
            })() : ''}
          </div>
          ${role === 'owner' ? `
          <div class="flex items-center gap-2 shrink-0">
            <button class="edit-client-btn px-3 py-1.5 text-xs font-medium border border-neutral-200 text-neutral-600 hover:bg-neutral-50 rounded-lg transition-colors"
              data-name="${client.name || ''}" data-email="${client.email || ''}" data-phone="${client.phone || ''}">
              Edit
            </button>
            <button class="delete-client-btn px-3 py-1.5 text-xs font-medium border border-red-200 text-red-500 hover:bg-red-50 rounded-lg transition-colors"
              data-name="${client.name || ''}" data-email="${client.email || ''}">
              Delete
            </button>
          </div>` : ''}
        </div>

        <div class="px-6 py-4 grid grid-cols-3 gap-4 border-b border-neutral-100 bg-neutral-50">
          <div class="text-center">
            <div class="text-xl font-bold text-neutral-900">${client.totalVisits}</div>
            <div class="text-xs text-neutral-400">Total Visits</div>
          </div>
          <div class="text-center">
            <div class="text-sm font-semibold text-neutral-700">${client.firstVisit ? formatDate(client.firstVisit) : '—'}</div>
            <div class="text-xs text-neutral-400">First Visit</div>
          </div>
          <div class="text-center">
            <div class="text-sm font-semibold text-neutral-700">${client.lastVisit ? formatDate(client.lastVisit) : '—'}</div>
            <div class="text-xs text-neutral-400">Last Visit</div>
          </div>
        </div>

        <div class="px-6 py-4 border-b border-neutral-100 flex items-center justify-between">
          <h4 class="text-sm font-semibold text-neutral-900">Appointment History</h4>
          <a href="/admin/new-appointment?email=${encodeURIComponent(client.email || '')}&name=${encodeURIComponent(client.name || '')}&phone=${encodeURIComponent(client.phone || '')}"
            class="text-xs bg-primary-50 text-primary-700 px-3 py-1.5 rounded-full font-medium hover:bg-primary-100 transition-colors">
            + Book Again
          </a>
        </div>

        <div class="divide-y divide-neutral-100 max-h-[420px] overflow-y-auto">
          ${appts.length === 0
            ? '<div class="px-6 py-8 text-center text-neutral-400 text-sm">No appointments found.</div>'
            : appts.map((a: any) => {
              const statusCls = STATUS_COLORS[a.status] || 'bg-neutral-100 text-neutral-600';
              return `
                <div class="px-6 py-4">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <div class="flex items-center gap-2 flex-wrap">
                        <span class="text-sm font-medium text-neutral-800">${formatDate(a.date)}</span>
                        <span class="text-xs text-neutral-400">${a.time || ''}</span>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold ${statusCls}">${a.status || '—'}</span>
                      </div>
                      <div class="text-xs text-neutral-500 mt-0.5">${a.services || '—'}</div>
                      ${a.notes ? `<div class="text-xs text-neutral-400 mt-1 italic">"${a.notes.substring(0, 100)}"</div>` : ''}
                      ${a.internalNotes ? `<div class="text-xs text-primary-600 mt-1">📝 ${a.internalNotes.substring(0, 100)}</div>` : ''}
                    </div>
                    ${role === 'owner' && a.price ? `<div class="text-sm font-semibold text-primary-700 shrink-0">$${Number(a.price).toFixed(2)}</div>` : ''}
                  </div>
                </div>`;
            }).join('')
          }
        </div>

        ${client.questionnaire ? (() => {
          const q = client.questionnaire;
          const submittedDate = q.submittedAt ? new Date(q.submittedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : null;

          function pill(label: string, cls: string) {
            return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${cls}">${label}</span>`;
          }

          const skinPills = (q.skinConditions || []).map((s: string) => {
            const map: Record<string, string> = { acne: 'bg-amber-100 text-amber-700', eczema: 'bg-orange-100 text-orange-700', psoriasis: 'bg-purple-100 text-purple-700', rosacea: 'bg-rose-100 text-rose-700', sunburn: 'bg-yellow-100 text-yellow-700', open_wounds: 'bg-red-100 text-red-700' };
            return pill(s.replace('_', ' '), map[s] || 'bg-neutral-100 text-neutral-600');
          }).join(' ');

          const medPills = (q.medicalHistory || []).map((m: string) => {
            const map: Record<string, string> = { pregnant: 'bg-pink-100 text-pink-700', chemotherapy: 'bg-red-100 text-red-700', blood_disorder: 'bg-red-100 text-red-700', recent_surgery: 'bg-orange-100 text-orange-700', epilepsy: 'bg-purple-100 text-purple-700', none: 'bg-neutral-100 text-neutral-400' };
            return pill(m.replace('_', ' '), map[m] || 'bg-neutral-100 text-neutral-600');
          }).join(' ');

          function row(label: string, content: string) {
            return `<div class="flex gap-2 py-2 border-b border-neutral-50 last:border-0">
              <span class="text-xs text-neutral-400 w-32 shrink-0 pt-0.5">${label}</span>
              <span class="text-xs text-neutral-700 flex-1 flex flex-wrap gap-1">${content || '<span class="text-neutral-300">—</span>'}</span>
            </div>`;
          }

          return `
            <div class="px-6 pt-4 pb-5 border-t border-neutral-100 bg-neutral-50/60">
              <div class="flex items-center justify-between mb-3">
                <h4 class="text-sm font-semibold text-neutral-900">Pre-Service Questionnaire</h4>
                ${submittedDate ? `<span class="text-xs text-neutral-400">Submitted ${submittedDate}</span>` : ''}
              </div>
              <div class="space-y-0">
                ${row('Skin conditions', skinPills)}
                ${row('Allergies', q.allergies ? `<span class="text-xs text-neutral-700">${q.allergies}</span>` : '')}
                ${row('Medical history', medPills)}
                ${row('Medications', q.medications ? `<span class="text-xs text-neutral-700">${q.medications}</span>` : '')}
                ${row('Recent treatments', q.recentTreatments && q.recentTreatments !== 'none' ? q.recentTreatments : '')}
              </div>
            </div>`;
        })() : ''}
        `;
    }

    // ── Search ────────────────────────────────────────────────────────────────
    let searchTimeout: ReturnType<typeof setTimeout>;
    document.getElementById('search-input')?.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        const q = (e.target as HTMLInputElement).value.trim();
        loadClients(q);
      }, 350);
    });

    // ── Load clients ──────────────────────────────────────────────────────────
    async function loadClients(search = '') {
      try {
        const data = await apiFetch('admin-clients', { params: search ? { search } : {} });
        allClients = data?.clients || [];
        renderList(allClients);
      } catch (err: any) {
        document.getElementById('client-list')!.innerHTML =
          `<div class="text-center py-12 text-red-400 text-sm">Error: ${err.message}</div>`;
      }
    }

    // ── Init ──────────────────────────────────────────────────────────────────
    const urlEmail = new URLSearchParams(window.location.search).get('email');
    loadClients().then(() => {
      if (urlEmail) {
        const match = allClients.find(c => c.email === urlEmail);
        if (match) { selectedEmail = urlEmail; renderDetail(match); }
      }
    });

    // ── Edit / Delete client (event delegation on detail panel) ───────────────
    document.getElementById('client-detail')?.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;

      // Edit
      const editBtn = target.closest('.edit-client-btn') as HTMLElement | null;
      if (editBtn) {
        const name  = editBtn.dataset.name  || '';
        const email = editBtn.dataset.email || '';
        const phone = editBtn.dataset.phone || '';
        const newName  = prompt('Name:',  name)?.trim();
        if (newName === undefined) return; // cancelled
        const newEmail = prompt('Email:', email)?.trim().toLowerCase();
        if (newEmail === undefined) return;
        const newPhone = prompt('Phone:', phone)?.trim();
        if (newPhone === undefined) return;
        try {
          await apiFetch('admin-clients', {
            method: 'PATCH',
            body: { oldEmail: email, name: newName, email: newEmail, phone: newPhone },
          });
          await loadClients();
        } catch (err: any) { alert(`Update failed: ${err.message}`); }
        return;
      }

      // Delete
      const delBtn = target.closest('.delete-client-btn') as HTMLElement | null;
      if (delBtn) {
        const name  = delBtn.dataset.name  || 'this client';
        const email = delBtn.dataset.email || '';
        if (!confirm(`Permanently delete ${name} and all their appointments? This cannot be undone.`)) return;
        try {
          await apiFetch('admin-clients', { method: 'DELETE', body: { email } });
          selectedEmail = '';
          document.getElementById('client-detail')!.innerHTML = '<div class="px-6 py-10 text-center text-neutral-400 text-sm">Client deleted.</div>';
          await loadClients();
        } catch (err: any) { alert(`Delete failed: ${err.message}`); }
      }
    });
  </script>

</AdminLayout>
