---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Partners & Affiliates" activeNav="partners">

  <div class="p-6 lg:p-8">
    <div class="mb-8 flex items-start justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-2xl font-serif font-semibold text-neutral-900">Partners & Affiliates</h1>
        <p class="text-sm text-neutral-500 mt-1">Manage partner brands, referral links, and affiliate relationships shown on the website.</p>
      </div>
      <div class="flex items-center gap-3">
        <a href="/partners/" target="_blank"
          class="px-4 py-2.5 bg-white border border-neutral-200 hover:border-neutral-300 text-neutral-700 text-sm font-medium rounded-xl transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
          View Page
        </a>
        <button id="open-add-modal"
          class="px-4 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold rounded-xl transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Add Partner
        </button>
      </div>
    </div>

    <!-- Info banner -->
    <div class="flex items-start gap-3 bg-primary-50 border border-primary-100 rounded-xl px-4 py-3 mb-6 text-sm text-primary-800">
      <svg class="w-4 h-4 text-primary-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <strong>Featured partners</strong> appear in the banner strip on the homepage. All active partners appear on the <a href="/partners/" target="_blank" class="underline font-semibold">public partners page</a>.
        Use <strong>Sort Order</strong> to control display sequence (lower numbers appear first).
      </div>
    </div>

    <!-- Partners table -->
    <div class="bg-white rounded-2xl border border-neutral-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-neutral-100 flex items-center justify-between">
        <h2 class="font-semibold text-neutral-900 text-sm">All Partners</h2>
        <span id="partner-count" class="text-xs text-neutral-400"></span>
      </div>
      <div id="partners-list" class="overflow-x-auto">
        <div class="px-6 py-10 text-center text-neutral-400 text-sm">Loading…</div>
      </div>
    </div>
  </div>

  <!-- Add / Edit Modal -->
  <div id="partner-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40" id="modal-overlay"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg z-10 max-h-[90vh] overflow-y-auto">
      <div class="sticky top-0 bg-white rounded-t-2xl border-b border-neutral-100 px-6 py-5 flex items-center justify-between">
        <h3 id="modal-title" class="font-semibold text-neutral-900">Add Partner</h3>
        <button id="modal-close" class="text-neutral-400 hover:text-neutral-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <div class="p-6">
        <div id="modal-error" class="hidden mb-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>

        <input type="hidden" id="edit-id" />

        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div class="col-span-2">
              <label class="block text-sm font-medium text-neutral-700 mb-1.5">Partner / Brand Name <span class="text-red-500">*</span></label>
              <input id="f-name" type="text" placeholder="e.g. Glow Recipe"
                class="w-full border border-neutral-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary-200 focus:border-primary-400 outline-none transition" />
            </div>

            <div class="col-span-2 sm:col-span-1">
              <label class="block text-sm font-medium text-neutral-700 mb-1.5">Category <span class="text-red-500">*</span></label>
              <select id="f-category"
                class="w-full border border-neutral-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary-200 focus:border-primary-400 outline-none transition bg-white">
                <option value="Skincare Products">Skincare Products</option>
                <option value="Wellness & Supplements">Wellness &amp; Supplements</option>
                <option value="Beauty Tools">Beauty Tools</option>
                <option value="Nutrition & Diet">Nutrition &amp; Diet</option>
                <option value="Fitness & Health">Fitness &amp; Health</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="col-span-2 sm:col-span-1">
              <label class="block text-sm font-medium text-neutral-700 mb-1.5">Sort Order</label>
              <input id="f-sort" type="number" min="0" placeholder="0"
                class="w-full border border-neutral-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary-200 focus:border-primary-400 outline-none transition" />
            </div>

            <div class="col-span-2">
              <label class="block text-sm font-medium text-neutral-700 mb-1.5">Affiliate / Referral URL <span class="text-red-500">*</span></label>
              <input id="f-url" type="url" placeholder="https://example.com/ref/blissdermacare"
                class="w-full border border-neutral-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary-200 focus:border-primary-400 outline-none transition" />
              <p class="text-xs text-neutral-400 mt-1">Include any referral codes or UTM parameters in this URL.</p>
            </div>

            <div class="col-span-2">
              <label class="block text-sm font-medium text-neutral-700 mb-1.5">Tagline <span class="text-neutral-400 font-normal">(short — shown on cards)</span></label>
              <input id="f-tagline" type="text" placeholder="e.g. Korean-inspired skincare essentials"
                class="w-full border border-neutral-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary-200 focus:border-primary-400 outline-none transition" />
            </div>

            <div class="col-span-2">
              <label class="block text-sm font-medium text-neutral-700 mb-1.5">Description <span class="text-neutral-400 font-normal">(shown on partners page)</span></label>
              <textarea id="f-description" rows="3" placeholder="Longer description of what this partner offers and why you recommend them…"
                class="w-full border border-neutral-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary-200 focus:border-primary-400 outline-none transition resize-none"></textarea>
            </div>

            <div class="col-span-2">
              <label class="block text-sm font-medium text-neutral-700 mb-1.5">Logo URL <span class="text-neutral-400 font-normal">(optional)</span></label>
              <input id="f-logo" type="url" placeholder="https://cdn.example.com/logo.png"
                class="w-full border border-neutral-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary-200 focus:border-primary-400 outline-none transition" />
              <p class="text-xs text-neutral-400 mt-1">Direct link to a square or wide logo image. Leave blank to show a letter avatar instead.</p>
            </div>

            <div class="col-span-2">
              <label class="block text-sm font-medium text-neutral-700 mb-1.5">Badge Text <span class="text-neutral-400 font-normal">(optional — e.g. "10% Off", "Exclusive Deal")</span></label>
              <input id="f-badge" type="text" placeholder="10% Off with code BLISS"
                class="w-full border border-neutral-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary-200 focus:border-primary-400 outline-none transition" />
            </div>

            <div class="col-span-2 flex gap-6 pt-1">
              <label class="flex items-center gap-2.5 cursor-pointer select-none">
                <input id="f-featured" type="checkbox" class="w-4 h-4 text-primary-600 rounded border-neutral-300 focus:ring-primary-200 cursor-pointer" />
                <span class="text-sm text-neutral-700">
                  <span class="font-medium">Featured</span>
                  <span class="text-neutral-400 ml-1">— shown on homepage strip</span>
                </span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer select-none">
                <input id="f-active" type="checkbox" class="w-4 h-4 text-primary-600 rounded border-neutral-300 focus:ring-primary-200 cursor-pointer" checked />
                <span class="text-sm font-medium text-neutral-700">Active</span>
              </label>
            </div>
          </div>
        </div>

        <div class="flex gap-3 mt-6 pt-6 border-t border-neutral-100">
          <button id="modal-cancel" class="flex-1 px-4 py-2.5 border border-neutral-200 rounded-xl text-sm font-medium text-neutral-700 hover:bg-neutral-50 transition-colors">Cancel</button>
          <button id="modal-save" class="flex-1 px-4 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold rounded-xl transition-colors">Save Partner</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete confirm modal -->
  <div id="delete-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 z-10">
      <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      </div>
      <h3 class="font-semibold text-neutral-900 mb-2">Delete Partner?</h3>
      <p class="text-sm text-neutral-500 mb-6">This will permanently remove <strong id="delete-name" class="text-neutral-700"></strong> from the website. This cannot be undone.</p>
      <div class="flex gap-3">
        <button id="delete-cancel" class="flex-1 px-4 py-2.5 border border-neutral-200 rounded-xl text-sm font-medium text-neutral-700 hover:bg-neutral-50 transition-colors">Cancel</button>
        <button id="delete-confirm" class="flex-1 px-4 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-xl transition-colors">Delete</button>
      </div>
    </div>
  </div>

<script>
  const API = '/.netlify/functions/admin-partners';
  const token = () => localStorage.getItem('bliss_admin_token') || '';

  // ── State ─────────────────────────────────────────────────────────────────
  let partners: any[] = [];
  let deleteTargetId: string | null = null;

  // ── Elements ──────────────────────────────────────────────────────────────
  const list       = document.getElementById('partners-list')!;
  const count      = document.getElementById('partner-count')!;
  const modal      = document.getElementById('partner-modal')!;
  const modalTitle = document.getElementById('modal-title')!;
  const modalError = document.getElementById('modal-error')!;
  const editId     = document.getElementById('edit-id') as HTMLInputElement;
  const fName      = document.getElementById('f-name') as HTMLInputElement;
  const fCategory  = document.getElementById('f-category') as HTMLSelectElement;
  const fSort      = document.getElementById('f-sort') as HTMLInputElement;
  const fUrl       = document.getElementById('f-url') as HTMLInputElement;
  const fTagline   = document.getElementById('f-tagline') as HTMLInputElement;
  const fDesc      = document.getElementById('f-description') as HTMLTextAreaElement;
  const fLogo      = document.getElementById('f-logo') as HTMLInputElement;
  const fBadge     = document.getElementById('f-badge') as HTMLInputElement;
  const fFeatured  = document.getElementById('f-featured') as HTMLInputElement;
  const fActive    = document.getElementById('f-active') as HTMLInputElement;
  const deleteModal = document.getElementById('delete-modal')!;
  const deleteName  = document.getElementById('delete-name')!;

  // ── Load ──────────────────────────────────────────────────────────────────
  async function load() {
    list.innerHTML = '<div class="px-6 py-10 text-center text-neutral-400 text-sm">Loading…</div>';
    const res = await fetch(API, { headers: { Authorization: `Bearer ${token()}` } });
    const json = await res.json();
    if (!res.ok) { list.innerHTML = `<div class="px-6 py-6 text-sm text-red-600">${json.error}</div>`; return; }
    partners = json.records || [];
    count.textContent = `${partners.length} partner${partners.length !== 1 ? 's' : ''}`;
    render();
  }

  function render() {
    if (partners.length === 0) {
      list.innerHTML = '<div class="px-6 py-12 text-center text-neutral-400 text-sm">No partners yet. Add your first one above.</div>';
      return;
    }
    list.innerHTML = `
      <table class="min-w-full text-sm">
        <thead>
          <tr class="border-b border-neutral-100 text-xs font-semibold text-neutral-500 uppercase tracking-wide">
            <th class="px-6 py-3 text-left">Name</th>
            <th class="px-6 py-3 text-left hidden sm:table-cell">Category</th>
            <th class="px-6 py-3 text-left hidden md:table-cell">Tagline</th>
            <th class="px-6 py-3 text-center hidden lg:table-cell">Featured</th>
            <th class="px-6 py-3 text-center hidden lg:table-cell">Active</th>
            <th class="px-6 py-3 text-center">Sort</th>
            <th class="px-6 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-50">
          ${partners.map(p => {
            const f = p.fields;
            const activeDot = f['Active']
              ? '<span class="inline-block w-2 h-2 bg-emerald-500 rounded-full"></span>'
              : '<span class="inline-block w-2 h-2 bg-neutral-300 rounded-full"></span>';
            return `
            <tr class="hover:bg-neutral-50 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  ${f['Logo URL']
                    ? `<img src="${esc(f['Logo URL'])}" alt="" class="w-8 h-8 rounded-lg object-contain bg-neutral-100 border border-neutral-200 shrink-0" />`
                    : `<div class="w-8 h-8 rounded-lg bg-primary-100 flex items-center justify-center shrink-0 text-primary-700 font-bold text-sm">${esc(f['Name']?.charAt(0) || '?')}</div>`
                  }
                  <div>
                    <p class="font-semibold text-neutral-900 leading-snug">${esc(f['Name'])}</p>
                    ${f['Badge Text'] ? `<span class="text-[11px] bg-primary-100 text-primary-700 font-medium px-1.5 py-0.5 rounded-full">${esc(f['Badge Text'])}</span>` : ''}
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 hidden sm:table-cell text-neutral-500">${esc(f['Category'] || '—')}</td>
              <td class="px-6 py-4 hidden md:table-cell text-neutral-400 max-w-[200px] truncate">${esc(f['Tagline'] || '—')}</td>
              <td class="px-6 py-4 text-center hidden lg:table-cell">
                ${f['Featured']
                  ? '<span class="text-xs font-semibold bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">Yes</span>'
                  : '<span class="text-xs text-neutral-400">—</span>'
                }
              </td>
              <td class="px-6 py-4 text-center hidden lg:table-cell">${activeDot}</td>
              <td class="px-6 py-4 text-center text-neutral-400 text-xs">${f['Sort Order'] ?? '0'}</td>
              <td class="px-6 py-4 text-right">
                <div class="flex items-center justify-end gap-2">
                  <a href="${esc(f['URL'])}" target="_blank" rel="noopener" class="p-1.5 rounded-lg text-neutral-400 hover:text-primary-600 hover:bg-primary-50 transition-colors" title="Visit link">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                  </a>
                  <button data-edit="${p.id}" class="p-1.5 rounded-lg text-neutral-400 hover:text-primary-600 hover:bg-primary-50 transition-colors" title="Edit">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                  </button>
                  <button data-delete="${p.id}" data-name="${esc(f['Name'])}" class="p-1.5 rounded-lg text-neutral-400 hover:text-red-600 hover:bg-red-50 transition-colors" title="Delete">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                </div>
              </td>
            </tr>
            `;
          }).join('')}
        </tbody>
      </table>
    `;

    list.querySelectorAll('[data-edit]').forEach(btn => {
      btn.addEventListener('click', () => openEdit((btn as HTMLElement).dataset.edit!));
    });
    list.querySelectorAll('[data-delete]').forEach(btn => {
      btn.addEventListener('click', () => openDelete((btn as HTMLElement).dataset.delete!, (btn as HTMLElement).dataset.name!));
    });
  }

  function esc(str: unknown): string {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Modal helpers ─────────────────────────────────────────────────────────
  function resetForm() {
    editId.value = '';
    fName.value = '';
    fCategory.value = 'Skincare Products';
    fSort.value = '0';
    fUrl.value = '';
    fTagline.value = '';
    fDesc.value = '';
    fLogo.value = '';
    fBadge.value = '';
    fFeatured.checked = false;
    fActive.checked = true;
    modalError.classList.add('hidden');
    modalError.textContent = '';
  }

  function openAdd() {
    resetForm();
    modalTitle.textContent = 'Add Partner';
    document.getElementById('modal-save')!.textContent = 'Add Partner';
    modal.classList.remove('hidden');
    fName.focus();
  }

  function openEdit(id: string) {
    const p = partners.find(p => p.id === id);
    if (!p) return;
    const f = p.fields;
    resetForm();
    editId.value = id;
    fName.value = f['Name'] || '';
    fCategory.value = f['Category'] || 'Other';
    fSort.value = f['Sort Order'] ?? 0;
    fUrl.value = f['URL'] || '';
    fTagline.value = f['Tagline'] || '';
    fDesc.value = f['Description'] || '';
    fLogo.value = f['Logo URL'] || '';
    fBadge.value = f['Badge Text'] || '';
    fFeatured.checked = Boolean(f['Featured']);
    fActive.checked = f['Active'] !== false;
    modalTitle.textContent = 'Edit Partner';
    document.getElementById('modal-save')!.textContent = 'Save Changes';
    modal.classList.remove('hidden');
    fName.focus();
  }

  function closeModal() {
    modal.classList.add('hidden');
    resetForm();
  }

  function openDelete(id: string, name: string) {
    deleteTargetId = id;
    deleteName.textContent = name;
    deleteModal.classList.remove('hidden');
  }

  function closeDeleteModal() {
    deleteTargetId = null;
    deleteModal.classList.add('hidden');
  }

  // ── Save ──────────────────────────────────────────────────────────────────
  async function save() {
    const name = fName.value.trim();
    const url  = fUrl.value.trim();
    if (!name) { showError('Name is required.'); return; }
    if (!url)  { showError('URL is required.'); return; }

    const fields = {
      'Name': name,
      'Category': fCategory.value,
      'Sort Order': parseInt(fSort.value) || 0,
      'URL': url,
      'Tagline': fTagline.value.trim() || null,
      'Description': fDesc.value.trim() || null,
      'Logo URL': fLogo.value.trim() || null,
      'Badge Text': fBadge.value.trim() || null,
      'Featured': fFeatured.checked,
      'Active': fActive.checked,
    };

    const id = editId.value;
    const btn = document.getElementById('modal-save') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Saving…';

    try {
      const body = id ? JSON.stringify({ id, fields }) : JSON.stringify(fields);
      const method = id ? 'PATCH' : 'POST';
      const res = await fetch(API, {
        method,
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token()}` },
        body,
      });
      const json = await res.json();
      if (!res.ok) { showError(json.error || 'Save failed.'); return; }
      closeModal();
      load();
    } finally {
      btn.disabled = false;
      btn.textContent = id ? 'Save Changes' : 'Add Partner';
    }
  }

  async function deletePartner() {
    if (!deleteTargetId) return;
    const btn = document.getElementById('delete-confirm') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Deleting…';
    try {
      const res = await fetch(`${API}?id=${deleteTargetId}`, {
        method: 'DELETE',
        headers: { Authorization: `Bearer ${token()}` },
      });
      if (!res.ok) { const j = await res.json(); alert(j.error || 'Delete failed'); return; }
      closeDeleteModal();
      load();
    } finally {
      btn.disabled = false;
      btn.textContent = 'Delete';
    }
  }

  function showError(msg: string) {
    modalError.textContent = msg;
    modalError.classList.remove('hidden');
  }

  // ── Event listeners ───────────────────────────────────────────────────────
  document.getElementById('open-add-modal')!.addEventListener('click', openAdd);
  document.getElementById('modal-save')!.addEventListener('click', save);
  document.getElementById('modal-cancel')!.addEventListener('click', closeModal);
  document.getElementById('modal-close')!.addEventListener('click', closeModal);
  document.getElementById('modal-overlay')!.addEventListener('click', closeModal);
  document.getElementById('delete-confirm')!.addEventListener('click', deletePartner);
  document.getElementById('delete-cancel')!.addEventListener('click', closeDeleteModal);

  load();
</script>

</AdminLayout>
