---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Calendar" activeNav="calendar">

  <div class="p-6 lg:p-8">
    <div class="mb-6 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-serif font-semibold text-neutral-900">Calendar</h1>
        <p class="text-sm text-neutral-500 mt-1">Click any day to see appointments</p>
      </div>
      <div class="flex items-center gap-2 flex-wrap">
        <button id="export-ics-btn"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs border border-neutral-300 bg-white text-neutral-600 hover:border-neutral-400 hover:text-neutral-800 font-medium transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Export .ics
        </button>
        <a href="/admin/new-appointment"
          class="text-xs bg-primary-600 text-white px-4 py-2 rounded-full font-semibold hover:bg-primary-700 transition-colors">
          + New Booking
        </a>
      </div>
    </div>

    <div class="grid lg:grid-cols-5 gap-6">

      <!-- Month calendar -->
      <div class="lg:col-span-3 bg-white rounded-2xl border border-neutral-200 overflow-hidden">
        <!-- Month nav -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-neutral-100">
          <button id="prev-month" class="p-2 rounded-lg hover:bg-neutral-100 transition-colors text-neutral-500">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
          </button>
          <h2 id="month-title" class="font-semibold text-neutral-900 text-sm">—</h2>
          <button id="next-month" class="p-2 rounded-lg hover:bg-neutral-100 transition-colors text-neutral-500">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
        <!-- Day-of-week headers -->
        <div class="grid grid-cols-7 border-b border-neutral-100">
          {['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map(d => (
            <div class="py-2 text-center text-xs font-semibold text-neutral-400 uppercase tracking-widest">{d}</div>
          ))}
        </div>
        <!-- Calendar grid -->
        <div id="calendar-grid" class="grid grid-cols-7"></div>
      </div>

      <!-- Day panel -->
      <div class="lg:col-span-2 bg-white rounded-2xl border border-neutral-200 overflow-hidden flex flex-col">
        <div class="px-5 py-4 border-b border-neutral-100 flex items-center justify-between">
          <h3 id="day-panel-title" class="font-semibold text-neutral-900 text-sm">Select a day</h3>
          <span id="day-panel-count" class="hidden text-xs text-neutral-400"></span>
        </div>
        <div id="day-panel-list" class="flex-1 overflow-y-auto divide-y divide-neutral-100">
          <div class="px-5 py-10 text-center text-neutral-400 text-sm">Click a day on the calendar</div>
        </div>
      </div>

    </div>
  </div>

  <!-- Edit appointment slide-over -->
  <div id="cal-detail-panel" class="hidden fixed inset-y-0 right-0 w-full sm:w-[420px] bg-white shadow-2xl border-l border-neutral-200 z-50 flex flex-col">
    <div class="flex items-center justify-between px-6 py-4 border-b border-neutral-100 shrink-0">
      <h3 class="font-semibold text-neutral-900 text-sm">Edit Appointment</h3>
      <button id="cal-close-detail" class="p-1.5 rounded-lg text-neutral-400 hover:bg-neutral-100 hover:text-neutral-600 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div id="cal-detail-content" class="flex-1 overflow-y-auto p-6 space-y-5"></div>
  </div>
  <div id="cal-detail-overlay" class="hidden fixed inset-0 bg-black/20 z-40"></div>

  <script>
    import { requireLogin, apiFetch, getRole, formatDate } from '../../scripts/adminAuth.js';
    requireLogin();
    const role = getRole();

    // ── State ─────────────────────────────────────────────────────────────────
    let currentYear = new Date().getFullYear();
    let currentMonth = new Date().getMonth(); // 0-indexed
    let allAppts: Record<string, any[]> = {};  // keyed by YYYY-MM-DD
    let selectedDate: string | null = null;
    let currentRec: any = null;

    const STATUS_COLORS: Record<string, string> = {
      'Confirmed':       'bg-emerald-100 text-emerald-700',
      'Completed':       'bg-blue-100 text-blue-700',
      'Pending Payment': 'bg-amber-100 text-amber-700',
      'Cancelled':       'bg-red-100 text-red-700',
      'No-Show':         'bg-purple-100 text-purple-700',
      'Pending Confirmation': 'bg-orange-100 text-orange-700',
    };

    // ── Google Calendar helper ────────────────────────────────────────────────
    function buildGCalUrl(f: Record<string,any>): string {
      const date = (f['Date'] || '').replace(/-/g, '');
      if (!date) return '#';
      const timeStr = f['Time'] || '';
      let sh = 9, sm = 0;
      const match = timeStr.match(/(\d{1,2}):(\d{2})\s*(AM|PM)?/i);
      if (match) {
        sh = parseInt(match[1], 10);
        sm = parseInt(match[2], 10);
        const mer = (match[3] || '').toUpperCase();
        if (mer === 'PM' && sh !== 12) sh += 12;
        if (mer === 'AM' && sh === 12) sh = 0;
      }
      const eh = (sh + 1) % 24;
      const pad = (n: number) => String(n).padStart(2, '0');
      const startDT = `${date}T${pad(sh)}${pad(sm)}00`;
      const endDT   = `${date}T${pad(eh)}${pad(sm)}00`;
      const title   = encodeURIComponent(`${f['Client Name'] || 'Client'} — ${f['Services'] || 'Appointment'}`);
      const details = encodeURIComponent([
        f['Services'] ? `Services: ${f['Services']}` : '',
        f['Client Phone'] ? `Phone: ${f['Client Phone']}` : '',
        f['Notes'] ? `Notes: ${f['Notes']}` : '',
      ].filter(Boolean).join('\n'));
      return `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${title}&dates=${startDT}/${endDT}&details=${details}&location=${encodeURIComponent('Bliss Dermacare, Tampa FL')}`;
    }

    // ── ICS export ────────────────────────────────────────────────────────────
    function icsEscape(str: string) {
      return (str || '').replace(/\\/g,'\\\\').replace(/;/g,'\\;').replace(/,/g,'\\,').replace(/\n/g,'\\n');
    }
    function foldLine(line: string) {
      const parts: string[] = [];
      while (line.length > 75) { parts.push(line.substring(0, 75)); line = ' ' + line.substring(75); }
      parts.push(line);
      return parts.join('\r\n');
    }
    function generateICS(appointments: any[]): string {
      const now = new Date().toISOString().replace(/[-:.]/g,'').slice(0,15)+'Z';
      const lines = [
        'BEGIN:VCALENDAR','VERSION:2.0',
        'PRODID:-//Bliss Dermacare//Admin//EN',
        'CALSCALE:GREGORIAN','METHOD:PUBLISH',
        'X-WR-CALNAME:Bliss Dermacare',
      ];
      for (const rec of appointments) {
        const f = rec.fields || rec;
        const date = (f['Date'] || f.date || '').replace(/-/g,'');
        if (!date) continue;
        const timeStr = f['Time'] || f.time || '';
        let sh = 9, sm = 0;
        const tm = timeStr.match(/(\d{1,2}):(\d{2})\s*(AM|PM)?/i);
        if (tm) {
          sh = parseInt(tm[1],10); sm = parseInt(tm[2],10);
          const mer = (tm[3] || '').toUpperCase();
          if (mer==='PM' && sh!==12) sh+=12;
          if (mer==='AM' && sh===12) sh=0;
        }
        const pad = (n: number) => String(n).padStart(2,'0');
        const startDT = `${date}T${pad(sh)}${pad(sm)}00`;
        const endDT   = `${date}T${pad((sh+1)%24)}${pad(sm)}00`;
        const clientName = f['Client Name'] || f.client_name || 'Client';
        const services   = f['Services']    || f.services    || 'Appointment';
        const phone      = f['Client Phone']|| f.client_phone|| '';
        const notes      = f['Notes']       || f.notes       || '';
        const summary    = icsEscape(`${clientName} — ${services}`);
        const descParts  = [services?`Services: ${services}`:'', phone?`Phone: ${phone}`:'', notes?`Notes: ${notes}`:''].filter(Boolean);
        lines.push('BEGIN:VEVENT');
        lines.push(`UID:bliss-appt-${rec.id || date+clientName}@blissdermacare.com`);
        lines.push(`DTSTAMP:${now}`);
        lines.push(`DTSTART;TZID=America/New_York:${startDT}`);
        lines.push(`DTEND;TZID=America/New_York:${endDT}`);
        lines.push(foldLine(`SUMMARY:${summary}`));
        if (descParts.length) lines.push(foldLine(`DESCRIPTION:${icsEscape(descParts.join('\\n'))}`));
        lines.push('LOCATION:Bliss Dermacare\\, Tampa FL');
        lines.push('STATUS:CONFIRMED');
        lines.push('END:VEVENT');
      }
      lines.push('END:VCALENDAR');
      return lines.join('\r\n');
    }

    document.getElementById('export-ics-btn')?.addEventListener('click', () => {
      const allRecs = Object.values(allAppts).flat();
      if (!allRecs.length) { alert('No appointments loaded for the current month.'); return; }
      const ics  = generateICS(allRecs);
      const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
      const url  = URL.createObjectURL(blob);
      const a    = document.createElement('a');
      a.href     = url;
      a.download = 'bliss-appointments.ics';
      a.click();
      setTimeout(() => URL.revokeObjectURL(url), 5000);
    });

    // ── Helpers ──────────────────────────────────────────────────────────────
    function padZ(n: number) { return String(n).padStart(2, '0'); }
    function monthStartEnd(year: number, month: number) {
      const start = `${year}-${padZ(month + 1)}-01`;
      const lastDay = new Date(year, month + 1, 0).getDate();
      const end   = `${year}-${padZ(month + 1)}-${padZ(lastDay)}`;
      return { start, end };
    }

    // ── Fetch appointments for the visible month ──────────────────────────────
    async function fetchMonth(year: number, month: number) {
      const { start, end } = monthStartEnd(year, month);
      const data = await apiFetch('admin-appointments', { params: { startDate: start, endDate: end } });
      allAppts = {};
      for (const rec of (data?.records || [])) {
        const d = rec.fields['Date'];
        if (!d) continue;
        if (!allAppts[d]) allAppts[d] = [];
        allAppts[d].push(rec);
      }
      // Also include today if it's not in range
      const today = new Date().toISOString().split('T')[0];
      if (!allAppts[today]) {
        const todayData = await apiFetch('admin-appointments', { params: { date: today } });
        if (todayData?.records?.length) allAppts[today] = todayData.records;
      }
    }

    // ── Render calendar grid ──────────────────────────────────────────────────
    function renderCalendar() {
      const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      document.getElementById('month-title')!.textContent = `${monthNames[currentMonth]} ${currentYear}`;

      const firstDay = new Date(currentYear, currentMonth, 1).getDay();
      const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
      const today = new Date().toISOString().split('T')[0];
      const grid = document.getElementById('calendar-grid')!;

      let html = '';
      // Empty leading cells
      for (let i = 0; i < firstDay; i++) {
        html += `<div class="min-h-[64px] border-b border-r border-neutral-100 bg-neutral-50/50"></div>`;
      }
      // Day cells
      for (let day = 1; day <= daysInMonth; day++) {
        const dateStr = `${currentYear}-${padZ(currentMonth + 1)}-${padZ(day)}`;
        const isToday = dateStr === today;
        const isSelected = dateStr === selectedDate;
        const count = allAppts[dateStr]?.length || 0;
        const confirmed = allAppts[dateStr]?.filter(r => r.fields['Status'] === 'Confirmed').length || 0;

        html += `
          <div class="min-h-[64px] border-b border-r border-neutral-100 p-1.5 cursor-pointer hover:bg-primary-50 transition-colors day-cell ${isSelected ? 'bg-primary-50 ring-1 ring-primary-300 ring-inset' : ''}"
            data-date="${dateStr}">
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs font-medium ${isToday ? 'w-6 h-6 flex items-center justify-center rounded-full bg-primary-600 text-white' : 'text-neutral-700'}">${day}</span>
              ${count > 0 ? `<span class="text-xs font-bold text-primary-600">${count}</span>` : ''}
            </div>
            ${confirmed > 0 ? `<div class="w-1.5 h-1.5 rounded-full bg-emerald-400 mx-auto"></div>` : ''}
          </div>`;
      }
      // Trailing cells
      const totalCells = firstDay + daysInMonth;
      const trailing = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
      for (let i = 0; i < trailing; i++) {
        html += `<div class="min-h-[64px] border-b border-r border-neutral-100 bg-neutral-50/50"></div>`;
      }

      grid.innerHTML = html;

      // Attach click handlers
      grid.querySelectorAll('.day-cell').forEach(cell => {
        cell.addEventListener('click', () => {
          const date = (cell as HTMLElement).dataset.date!;
          showDayPanel(date);
          // Update selected highlighting
          grid.querySelectorAll('.day-cell').forEach(c => {
            c.classList.remove('bg-primary-50', 'ring-1', 'ring-primary-300', 'ring-inset');
          });
          cell.classList.add('bg-primary-50', 'ring-1', 'ring-primary-300', 'ring-inset');
          selectedDate = date;
        });
      });
    }

    // ── Day panel ─────────────────────────────────────────────────────────────
    async function showDayPanel(dateStr: string) {
      selectedDate = dateStr;
      const title = document.getElementById('day-panel-title')!;
      const count = document.getElementById('day-panel-count')!;
      const list  = document.getElementById('day-panel-list')!;
      const d = new Date(dateStr + 'T12:00:00');
      title.textContent = d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' });

      if (!allAppts[dateStr]) {
        list.innerHTML = '<div class="px-5 py-8 text-center text-neutral-400 text-sm">Loading…</div>';
        const data = await apiFetch('admin-appointments', { params: { date: dateStr } });
        allAppts[dateStr] = data?.records || [];
      }

      const recs = allAppts[dateStr] || [];
      if (recs.length === 0) {
        count.classList.add('hidden');
        list.innerHTML = `<div class="px-5 py-10 text-center">
          <div class="text-neutral-400 text-sm mb-3">No appointments this day.</div>
          <a href="/admin/new-appointment?date=${dateStr}" class="text-xs text-primary-600 hover:text-primary-700 font-semibold border border-primary-200 rounded-full px-4 py-1.5 hover:bg-primary-50 transition-colors">+ Add appointment</a>
        </div>`;
        return;
      }

      count.textContent = `${recs.length} appointment${recs.length !== 1 ? 's' : ''}`;
      count.classList.remove('hidden');

      list.innerHTML = recs.map((rec: any) => {
        const f = rec.fields;
        const statusCls = STATUS_COLORS[f['Status']] || 'bg-neutral-100 text-neutral-600';
        const noPsf = f['hasPSF'] === false
          ? `<span class="ml-1 text-[10px] font-bold bg-amber-100 text-amber-700 border border-amber-200 px-1.5 py-0.5 rounded-full">No PSF</span>`
          : '';
        return `
          <div class="px-5 py-4 appt-day-row cursor-pointer hover:bg-neutral-50 transition-colors" data-id="${rec.id}" data-rec='${JSON.stringify(rec).replace(/'/g, "&#39;")}'>
            <div class="flex items-start justify-between gap-2">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-1.5 flex-wrap">
                  <span class="text-sm font-semibold text-neutral-900">${f['Client Name'] || '—'}</span>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold ${statusCls}">${f['Status'] || '—'}</span>
                  ${noPsf}
                </div>
                <div class="text-xs text-neutral-500 mt-0.5">${f['Time'] || '—'} · ${(f['Services'] || '—').substring(0, 45)}</div>
                ${f['Client Phone'] ? `<div class="text-xs text-neutral-400 mt-0.5">${f['Client Phone']}</div>` : ''}
              </div>
              <svg class="w-4 h-4 text-neutral-300 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
          </div>`;
      }).join('');

      list.querySelectorAll('.appt-day-row').forEach(row => {
        row.addEventListener('click', () => {
          const rec = JSON.parse((row as HTMLElement).dataset.rec || '{}');
          openDetail(rec);
        });
      });
    }

    // ── Edit slide-over ───────────────────────────────────────────────────────
    function openDetail(rec: any) {
      currentRec = rec;
      const f = rec.fields;
      const content = document.getElementById('cal-detail-content')!;
      const statusOptions = ['Pending Confirmation','Pending Payment','Confirmed','Completed','Cancelled','No-Show'];

      content.innerHTML = `
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Client</div>
          <div class="text-base font-semibold text-neutral-900">${f['Client Name'] || '—'}</div>
          <div class="text-sm text-neutral-500">${f['Client Email'] || ''}</div>
          <div class="text-sm text-neutral-500">${f['Client Phone'] || ''}</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Date</div>
            ${role === 'owner'
              ? `<input id="cal-f-date" type="date" value="${f['Date'] || ''}" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none"/>`
              : `<div class="text-sm text-neutral-800">${formatDate(f['Date'])}</div>`}
          </div>
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Time</div>
            ${role === 'owner'
              ? `<input id="cal-f-time" type="text" value="${f['Time'] || ''}" placeholder="e.g. 2:00 PM" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none"/>`
              : `<div class="text-sm text-neutral-800">${f['Time'] || '—'}</div>`}
          </div>
        </div>
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Services</div>
          ${role === 'owner'
            ? `<input id="cal-f-services" type="text" value="${(f['Services'] || '').replace(/"/g,'&quot;')}" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none"/>`
            : `<div class="text-sm text-neutral-800">${f['Services'] || '—'}</div>`}
        </div>
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-2">Status</div>
          <select id="cal-f-status" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 outline-none">
            ${statusOptions.map(s => `<option value="${s}" ${f['Status'] === s ? 'selected' : ''}>${s}</option>`).join('')}
          </select>
        </div>
        ${role === 'owner' ? `
        <div class="grid grid-cols-2 gap-4">
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Price ($)</div>
            <input id="cal-f-price" type="number" step="0.01" value="${f['Price'] ?? ''}" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none"/>
          </div>
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Source</div>
            <input id="cal-f-source" type="text" value="${f['Source'] || ''}" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none"/>
          </div>
        </div>` : ''}
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Client Notes</div>
          <textarea id="cal-f-notes" rows="2" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none resize-none">${f['Notes'] || ''}</textarea>
        </div>
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Internal Notes</div>
          <textarea id="cal-f-internal" rows="2" class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 outline-none resize-none">${f['Internal Notes'] || ''}</textarea>
        </div>
        <div class="flex gap-3 pt-2">
          <button id="cal-save-btn" class="flex-1 py-2.5 bg-primary-600 hover:bg-primary-700 disabled:opacity-50 text-white text-sm font-semibold rounded-xl transition-colors">Save</button>
          ${role === 'owner' ? `<button id="cal-del-btn" class="py-2.5 px-4 border border-red-200 text-red-500 hover:bg-red-50 text-sm font-semibold rounded-xl transition-colors">Delete</button>` : ''}
        </div>
        <div class="flex gap-2 flex-wrap">
          <a href="${buildGCalUrl(f)}" target="_blank" rel="noopener"
            class="inline-flex items-center gap-1.5 px-3 py-2 rounded-xl border border-neutral-200 hover:border-primary-300 text-xs font-medium text-neutral-600 hover:text-primary-700 transition-colors bg-white">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.5 3H18V1.5a.75.75 0 00-1.5 0V3h-9V1.5a.75.75 0 00-1.5 0V3H4.5A1.5 1.5 0 003 4.5v15A1.5 1.5 0 004.5 21h15a1.5 1.5 0 001.5-1.5v-15A1.5 1.5 0 0019.5 3zm0 16.5h-15V9h15v10.5zm0-12h-15V4.5H6V6a.75.75 0 001.5 0V4.5h9V6a.75.75 0 001.5 0V4.5h1.5v3z"/></svg>
            Add to Google Calendar
          </a>
          ${f['hasPSF'] === true ? `
          <button id="cal-fill-psf-btn"
            class="inline-flex items-center gap-1.5 px-3 py-2 rounded-xl border border-emerald-200 hover:border-emerald-400 text-xs font-medium text-emerald-700 hover:text-emerald-800 transition-colors bg-emerald-50">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Fill from PSF
          </button>` : ''}
        </div>
        <div id="cal-save-msg" class="text-xs text-center hidden text-neutral-400"></div>
      `;

      document.getElementById('cal-detail-panel')?.classList.remove('hidden');
      document.getElementById('cal-detail-panel')?.classList.add('flex');
      document.getElementById('cal-detail-overlay')?.classList.remove('hidden');

      document.getElementById('cal-save-btn')?.addEventListener('click', async () => {
        const btn = document.getElementById('cal-save-btn') as HTMLButtonElement;
        const msg = document.getElementById('cal-save-msg')!;
        btn.disabled = true; btn.textContent = 'Saving…';
        const fields: Record<string, any> = {
          Status:          (document.getElementById('cal-f-status') as HTMLSelectElement).value,
          'Internal Notes':(document.getElementById('cal-f-internal') as HTMLTextAreaElement).value,
          Notes:           (document.getElementById('cal-f-notes') as HTMLTextAreaElement).value,
        };
        if (role === 'owner') {
          fields['Date']    = (document.getElementById('cal-f-date')     as HTMLInputElement)?.value || f['Date'];
          fields['Time']    = (document.getElementById('cal-f-time')     as HTMLInputElement)?.value || f['Time'];
          fields['Services']= (document.getElementById('cal-f-services') as HTMLInputElement)?.value || f['Services'];
          fields['Price']   = parseFloat((document.getElementById('cal-f-price') as HTMLInputElement)?.value) || f['Price'];
          fields['Source']  = (document.getElementById('cal-f-source')   as HTMLInputElement)?.value || f['Source'];
        }
        try {
          await apiFetch('admin-appointments', { method: 'PATCH', body: { id: rec.id, fields } });
          // Update local cache
          Object.assign(currentRec.fields, fields);
          if (selectedDate && allAppts[selectedDate]) {
            const idx = allAppts[selectedDate].findIndex((r: any) => r.id === rec.id);
            if (idx >= 0) allAppts[selectedDate][idx] = currentRec;
          }
          msg.textContent = '✓ Saved'; msg.className = 'text-xs text-center text-emerald-600';
          renderCalendar();
          if (selectedDate) showDayPanel(selectedDate);
        } catch (err: any) {
          msg.textContent = `Error: ${err.message}`; msg.className = 'text-xs text-center text-red-500';
        } finally {
          btn.disabled = false; btn.textContent = 'Save';
        }
      });

      document.getElementById('cal-del-btn')?.addEventListener('click', async () => {
        if (!confirm(`Delete appointment for ${f['Client Name']}? This cannot be undone.`)) return;
        try {
          await apiFetch('admin-appointments', { method: 'DELETE', body: { id: rec.id } });
          closeDetail();
          if (selectedDate) {
            allAppts[selectedDate] = (allAppts[selectedDate] || []).filter((r: any) => r.id !== rec.id);
            renderCalendar();
            showDayPanel(selectedDate);
          }
        } catch (err: any) { alert(`Delete failed: ${err.message}`); }
      });

      // ── Fill from PSF ───────────────────────────────────────────────────────
      document.getElementById('cal-fill-psf-btn')?.addEventListener('click', async () => {
        const fillBtn = document.getElementById('cal-fill-psf-btn') as HTMLButtonElement;
        const msg     = document.getElementById('cal-save-msg')!;
        fillBtn.textContent = 'Loading…';
        fillBtn.setAttribute('disabled', '');
        try {
          const email = f['Client Email'];
          const date  = f['Date'];
          if (!email || !date) throw new Error('No email or date on this appointment');

          const data = await apiFetch('admin-pre-service-forms', { params: { email, date } });
          const psf  = data?.record;
          if (!psf) throw new Error('No pre-service form found');

          const timeEl     = document.getElementById('cal-f-time')     as HTMLInputElement | null;
          const servicesEl = document.getElementById('cal-f-services') as HTMLInputElement | null;
          const notesEl    = document.getElementById('cal-f-notes')    as HTMLTextAreaElement | null;

          if (timeEl && !timeEl.value && psf.appointment_time) {
            const [hh, mm] = psf.appointment_time.split(':').map(Number);
            const ampm = hh >= 12 ? 'PM' : 'AM';
            const h12  = hh % 12 || 12;
            timeEl.value = `${h12}:${String(mm).padStart(2,'0')} ${ampm}`;
          }
          if (servicesEl && !servicesEl.value && psf.service_requested) {
            servicesEl.value = psf.service_requested;
          }

          const skinList  = (psf.skin_conditions || []).filter((s: string) => s !== 'none').join(', ');
          const medList   = (psf.medical_history  || []).filter((m: string) => m !== 'none').join(', ');
          const healthNote = [
            skinList ? `Skin: ${skinList}` : '',
            medList  ? `Medical: ${medList}` : '',
            psf.medications ? `Meds: ${psf.medications}` : '',
            psf.allergies   ? `Allergies: ${psf.allergies}` : '',
          ].filter(Boolean).join(' | ');

          if (notesEl && healthNote) {
            const existing = notesEl.value.trim();
            notesEl.value = existing ? `${existing}\n[PSF] ${healthNote}` : `[PSF] ${healthNote}`;
          }

          msg.textContent = '✓ PSF data applied';
          msg.className = 'text-xs text-center text-emerald-600';
          msg.classList.remove('hidden');
        } catch (err: any) {
          msg.textContent = `PSF fill failed: ${err.message}`;
          msg.className = 'text-xs text-center text-red-500';
          msg.classList.remove('hidden');
        } finally {
          fillBtn.textContent = 'Fill from PSF';
          fillBtn.removeAttribute('disabled');
        }
      });
    }

    function closeDetail() {
      document.getElementById('cal-detail-panel')?.classList.add('hidden');
      document.getElementById('cal-detail-panel')?.classList.remove('flex');
      document.getElementById('cal-detail-overlay')?.classList.add('hidden');
      currentRec = null;
    }

    document.getElementById('cal-close-detail')?.addEventListener('click', closeDetail);
    document.getElementById('cal-detail-overlay')?.addEventListener('click', closeDetail);

    // ── Month navigation ──────────────────────────────────────────────────────
    async function changeMonth(delta: number) {
      currentMonth += delta;
      if (currentMonth > 11) { currentMonth = 0; currentYear++; }
      if (currentMonth < 0)  { currentMonth = 11; currentYear--; }
      await fetchMonth(currentYear, currentMonth);
      renderCalendar();
    }

    document.getElementById('prev-month')?.addEventListener('click', () => changeMonth(-1));
    document.getElementById('next-month')?.addEventListener('click', () => changeMonth(+1));

    // ── Init ──────────────────────────────────────────────────────────────────
    (async () => {
      await fetchMonth(currentYear, currentMonth);
      renderCalendar();
      // Auto-open today
      const today = new Date().toISOString().split('T')[0];
      showDayPanel(today);
    })();
  </script>

</AdminLayout>
