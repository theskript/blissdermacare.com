---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Audit Log" activeNav="audit">

  <div class="p-6 lg:p-8">
    <div class="mb-6 flex items-start justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-2xl font-serif font-semibold text-neutral-900">Audit Log</h1>
        <p class="text-sm text-neutral-500 mt-1">Every action taken in the admin panel — logins, changes, deletions.</p>
      </div>
      <div class="flex items-center gap-3 flex-wrap">
        <input id="filter-username" type="text" placeholder="Filter by username…"
          class="px-3 py-2 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none text-sm w-44" />
        <select id="filter-action"
          class="px-3 py-2 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none text-sm">
          <option value="">All actions</option>
          <option value="Login">Login</option>
          <option value="Failed Login">Failed Login</option>
          <option value="Create Appointment">Create Appointment</option>
          <option value="Update Appointment">Update Appointment</option>
          <option value="Delete Appointment">Delete Appointment</option>
          <option value="Create Staff">Create Staff</option>
          <option value="Activate Staff">Activate Staff</option>
          <option value="Deactivate Staff">Deactivate Staff</option>
          <option value="Reset Password">Reset Password</option>
          <option value="SMS Sent">SMS Sent</option>
          <option value="SMS Failed">SMS Failed</option>
          <option value="Email Sent">Email Sent</option>
          <option value="Email Failed">Email Failed</option>
        </select>
        <button id="apply-filter"
          class="px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold rounded-xl transition-colors">
          Apply
        </button>
      </div>
    </div>

    <div class="bg-white rounded-2xl border border-neutral-200 overflow-hidden">
      <div id="audit-table-wrap" class="overflow-x-auto">
        <div class="px-6 py-10 text-center text-neutral-400 text-sm">Loading audit log…</div>
      </div>
      <div class="px-6 py-4 border-t border-neutral-100 flex items-center justify-between text-xs text-neutral-400">
        <span id="audit-count">—</span>
        <span>Showing most recent 200 entries</span>
      </div>
    </div>
  </div>

  <!-- Details modal -->
  <div id="detail-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40" id="detail-modal-overlay"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg z-10 overflow-hidden flex flex-col max-h-[80vh]">
      <div class="flex items-center justify-between px-6 py-4 border-b border-neutral-100 shrink-0">
        <div>
          <span id="modal-action-badge" class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold"></span>
          <span id="modal-ts" class="ml-3 text-xs text-neutral-400 font-mono"></span>
        </div>
        <button id="detail-modal-close" class="p-1.5 rounded-lg text-neutral-400 hover:bg-neutral-100 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="overflow-y-auto p-6 space-y-3 text-sm">
        <div id="modal-meta" class="text-xs text-neutral-500 space-y-1"></div>
        <div class="border-t border-neutral-100 pt-3">
          <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-2">Details</p>
          <pre id="modal-details" class="whitespace-pre-wrap break-words text-neutral-700 text-sm font-sans leading-relaxed"></pre>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { requireLogin, getRole, apiFetch } from '../../scripts/adminAuth.js';
    requireLogin();
    if (getRole() !== 'owner') window.location.href = '/admin/';

    const ACTION_COLORS: Record<string, string> = {
      'Login':                'bg-emerald-100 text-emerald-700',
      'Failed Login':         'bg-red-100 text-red-700',
      'Create Appointment':   'bg-blue-100 text-blue-700',
      'Update Appointment':   'bg-amber-100 text-amber-700',
      'Delete Appointment':   'bg-red-100 text-red-700',
      'Create Staff':         'bg-purple-100 text-purple-700',
      'Activate Staff':       'bg-emerald-100 text-emerald-700',
      'Deactivate Staff':     'bg-orange-100 text-orange-700',
      'Reset Password':       'bg-amber-100 text-amber-700',
      'Update Staff':         'bg-neutral-100 text-neutral-600',
      'SMS Sent':             'bg-sky-100 text-sky-700',
      'SMS Failed':           'bg-red-100 text-red-700',
      'Email Sent':           'bg-violet-100 text-violet-700',
      'Email Failed':         'bg-red-100 text-red-700',
    };

    // ── Modal ────────────────────────────────────────────────────────────────
    const modal        = document.getElementById('detail-modal')!;
    const modalOverlay = document.getElementById('detail-modal-overlay')!;
    const modalClose   = document.getElementById('detail-modal-close')!;
    const modalBadge   = document.getElementById('modal-action-badge')!;
    const modalTs      = document.getElementById('modal-ts')!;
    const modalMeta    = document.getElementById('modal-meta')!;
    const modalDetails = document.getElementById('modal-details')!;

    function openModal(rec: any) {
      const f  = rec.fields;
      const ts = f['Timestamp']
        ? new Date(f['Timestamp']).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit', second: '2-digit' })
        : '—';
      const actionCls = ACTION_COLORS[f['Action']] || 'bg-neutral-100 text-neutral-600';

      modalBadge.className = `inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold ${actionCls}`;
      modalBadge.textContent = f['Action'] || '—';
      modalTs.textContent = ts;

      const metaLines = [];
      if (f['Username']) metaLines.push(`<span class="font-medium text-neutral-700">User:</span> ${f['Username']}`);
      if (f['Role'])     metaLines.push(`<span class="font-medium text-neutral-700">Role:</span> ${f['Role']}`);
      if (f['IP Address']) metaLines.push(`<span class="font-medium text-neutral-700">IP:</span> ${f['IP Address']}`);
      if (rec.id)        metaLines.push(`<span class="font-medium text-neutral-700">Log ID:</span> ${rec.id}`);
      modalMeta.innerHTML = metaLines.join('<br>');

      modalDetails.textContent = f['Details'] || '—';
      modal.classList.remove('hidden');
    }

    function closeModal() { modal.classList.add('hidden'); }
    modalClose.addEventListener('click', closeModal);
    modalOverlay.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    // ── Table ────────────────────────────────────────────────────────────────
    async function loadAudit() {
      const username = (document.getElementById('filter-username') as HTMLInputElement).value.trim();
      const action   = (document.getElementById('filter-action')   as HTMLSelectElement).value;

      const wrap = document.getElementById('audit-table-wrap')!;
      wrap.innerHTML = '<div class="px-6 py-10 text-center text-neutral-400 text-sm">Loading…</div>';

      try {
        const params: Record<string, string> = {};
        if (username) params.username = username;
        if (action)   params.action   = action;

        const data = await apiFetch('admin-audit', { params });
        const records = data?.records || [];

        document.getElementById('audit-count')!.textContent = `${records.length} entries`;

        if (records.length === 0) {
          wrap.innerHTML = '<div class="px-6 py-10 text-center text-neutral-400 text-sm">No log entries match your filter.</div>';
          return;
        }

        wrap.innerHTML = `
          <table class="w-full text-sm min-w-[700px]">
            <thead>
              <tr class="border-b border-neutral-100 bg-neutral-50">
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400 whitespace-nowrap">Timestamp</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">Action</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">User</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">Details</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">IP</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-100" id="audit-tbody">
            </tbody>
          </table>`;

        const tbody = document.getElementById('audit-tbody')!;
        records.forEach((rec: any, i: number) => {
          const f = rec.fields;
          const ts = f['Timestamp']
            ? new Date(f['Timestamp']).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit', second: '2-digit' })
            : '—';
          const actionCls = ACTION_COLORS[f['Action']] || 'bg-neutral-100 text-neutral-600';
          const hasDetails = f['Details'] && f['Details'] !== '—';
          const tr = document.createElement('tr');
          tr.className = `hover:bg-neutral-50 transition-colors ${hasDetails ? 'cursor-pointer' : ''}`;
          tr.dataset.idx = String(i);
          tr.innerHTML = `
            <td class="px-5 py-3 text-xs text-neutral-400 whitespace-nowrap font-mono">${ts}</td>
            <td class="px-5 py-3 whitespace-nowrap">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold ${actionCls}">${f['Action'] || '—'}</span>
            </td>
            <td class="px-5 py-3 font-mono text-xs text-neutral-700">${f['Username'] || '—'}</td>
            <td class="px-5 py-3 text-xs text-neutral-600 max-w-xs">
              <span class="line-clamp-2">${(f['Details'] || '—').substring(0, 120)}${(f['Details'] || '').length > 120 ? '…' : ''}</span>
              ${hasDetails ? '<span class="text-primary-500 text-xs font-medium">View full ›</span>' : ''}
            </td>
            <td class="px-5 py-3 text-xs text-neutral-400 font-mono">${f['IP Address'] || '—'}</td>`;
          if (hasDetails) {
            tr.addEventListener('click', () => openModal(rec));
          }
          tbody.appendChild(tr);
        });

      } catch (err: any) {
        wrap.innerHTML = `<div class="px-6 py-10 text-center text-red-400 text-sm">Error: ${err.message}</div>`;
      }
    }

    document.getElementById('apply-filter')?.addEventListener('click', loadAudit);
    document.getElementById('filter-username')?.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter') loadAudit();
    });

    loadAudit();
  </script>

</AdminLayout>

        if (records.length === 0) {
          wrap.innerHTML = '<div class="px-6 py-10 text-center text-neutral-400 text-sm">No log entries match your filter.</div>';
          return;
        }

        wrap.innerHTML = `
          <table class="w-full text-sm min-w-[700px]">
            <thead>
              <tr class="border-b border-neutral-100 bg-neutral-50">
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400 whitespace-nowrap">Timestamp</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">Action</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">User</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">Role</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">Details</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest text-neutral-400">IP</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-100">
              ${records.map((rec: any) => {
                const f = rec.fields;
                const ts = f['Timestamp']
                  ? new Date(f['Timestamp']).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit', second: '2-digit' })
                  : '—';
                const actionCls = ACTION_COLORS[f['Action']] || 'bg-neutral-100 text-neutral-600';
                return `
                  <tr class="hover:bg-neutral-50 transition-colors">
                    <td class="px-5 py-3 text-xs text-neutral-400 whitespace-nowrap font-mono">${ts}</td>
                    <td class="px-5 py-3 whitespace-nowrap">
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold ${actionCls}">${f['Action'] || '—'}</span>
                    </td>
                    <td class="px-5 py-3 font-mono text-xs text-neutral-700">${f['Username'] || '—'}</td>
                    <td class="px-5 py-3 text-xs text-neutral-500 capitalize">${f['Role'] || '—'}</td>
                    <td class="px-5 py-3 text-xs text-neutral-600 max-w-xs truncate" title="${(f['Details'] || '').replace(/"/g, '&quot;')}">${f['Details'] || '—'}</td>
                    <td class="px-5 py-3 text-xs text-neutral-400 font-mono">${f['IP Address'] || '—'}</td>
                  </tr>`;
              }).join('')}
            </tbody>
          </table>`;
      } catch (err: any) {
        wrap.innerHTML = `<div class="px-6 py-10 text-center text-red-400 text-sm">Error: ${err.message}</div>`;
      }
    }

    document.getElementById('apply-filter')?.addEventListener('click', loadAudit);
    document.getElementById('filter-username')?.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter') loadAudit();
    });

    loadAudit();
  </script>

</AdminLayout>
