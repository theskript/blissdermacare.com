---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="Consultation Requests" activeNav="consultations">

  <div class="p-6 lg:p-8">
    <div class="mb-6 flex items-start justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-2xl font-serif font-semibold text-neutral-900">Consultation Requests</h1>
        <p id="cr-count-label" class="text-sm text-neutral-500 mt-1">Loading…</p>
      </div>
      <div class="flex items-center gap-3 flex-wrap">
        <button id="cr-mark-all-btn"
          class="hidden px-4 py-2.5 bg-emerald-600 hover:bg-emerald-700 disabled:opacity-50 text-white text-sm font-semibold rounded-xl transition-colors">
          ✓ Mark All as Read
        </button>
        <a href="/consultation/" target="_blank"
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-white border border-neutral-200 hover:border-neutral-300 text-neutral-700 text-sm font-medium rounded-xl transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
          Public Form
        </a>
      </div>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap items-center gap-3 mb-5">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input id="cr-search" type="text" placeholder="Search name or email…"
          class="pl-9 pr-4 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm w-56"/>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-xs text-neutral-500">Since:</span>
        <input id="cr-since" type="date"
          class="px-3 py-2.5 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm"/>
      </div>
      <button id="cr-load-btn"
        class="px-4 py-2.5 bg-white border border-neutral-300 hover:border-neutral-400 rounded-xl text-sm font-medium text-neutral-700 transition-colors">
        Load
      </button>
    </div>

    <div id="cr-new-badge" class="hidden mb-4 inline-flex items-center gap-2 bg-blue-50 border border-blue-200 text-blue-800 text-xs font-semibold px-3 py-1.5 rounded-full">
      <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
      <span id="cr-new-count"></span> unread
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl border border-neutral-200 overflow-hidden">
      <div id="cr-table-wrap" class="overflow-x-auto">
        <div class="px-6 py-10 text-center text-neutral-400 text-sm">Loading…</div>
      </div>
    </div>
  </div>

  <!-- Detail slide-over -->
  <div id="cr-detail-panel" class="hidden fixed inset-y-0 right-0 w-full sm:w-[500px] bg-white shadow-2xl border-l border-neutral-200 z-50 flex flex-col">
    <div class="flex items-center justify-between px-6 py-4 border-b border-neutral-100 shrink-0">
      <h3 class="font-semibold text-neutral-900">Consultation Details</h3>
      <button id="cr-close-detail" class="p-1.5 rounded-lg text-neutral-400 hover:bg-neutral-100 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div id="cr-detail-content" class="flex-1 overflow-y-auto p-6 space-y-4 text-sm"></div>
  </div>
  <div id="cr-detail-overlay" class="hidden fixed inset-0 bg-black/20 z-40"></div>

  <script>
    import { requireLogin, apiFetch, getRole } from '../../../scripts/adminAuth.js';
    requireLogin();
    const role = getRole();
    void role;

    let allRecords: any[] = [];
    let fullRecords: any[] = [];

    function esc(s: unknown) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    const CONTACT_LABELS: Record<string,string> = {
      'phone-call': 'Phone Call',
      'text': 'Text Message',
      'email': 'Email',
      'instagram': 'Instagram DM',
    };

    async function load() {
      const search = (document.getElementById('cr-search') as HTMLInputElement).value.trim().toLowerCase();
      const since  = (document.getElementById('cr-since')  as HTMLInputElement).value;
      const params: Record<string,string> = { limit: '500' };
      if (since) params.since = since + 'T00:00:00Z';

      const wrap = document.getElementById('cr-table-wrap')!;
      wrap.innerHTML = '<div class="px-6 py-10 text-center text-neutral-400 text-sm">Loading…</div>';

      try {
        const data = await apiFetch('admin-consultations', { params });
        fullRecords = data?.records || [];
        allRecords = search
          ? fullRecords.filter((r: any) =>
              (r.name || '').toLowerCase().includes(search) ||
              (r.email || '').toLowerCase().includes(search))
          : fullRecords;

        const label = document.getElementById('cr-count-label')!;
        label.textContent = `${allRecords.length} request${allRecords.length !== 1 ? 's' : ''}`;

        const unread = fullRecords.filter((r: any) => !r.read_at).length;
        const badge  = document.getElementById('cr-new-badge')!;
        const markAllBtn = document.getElementById('cr-mark-all-btn')!;
        if (unread > 0) {
          document.getElementById('cr-new-count')!.textContent = String(unread);
          badge.classList.remove('hidden');
          markAllBtn.classList.remove('hidden');
        } else {
          badge.classList.add('hidden');
          markAllBtn.classList.add('hidden');
        }
        render();
      } catch (err: any) {
        wrap.innerHTML = `<div class="px-6 py-6 text-red-500 text-sm">${err.message}</div>`;
      }
    }

    function render() {
      const wrap = document.getElementById('cr-table-wrap')!;
      if (!allRecords.length) {
        wrap.innerHTML = '<div class="px-6 py-12 text-center text-neutral-400 text-sm">No consultation requests found.</div>';
        return;
      }
      wrap.innerHTML = `
        <table class="min-w-full text-sm">
          <thead>
            <tr class="border-b border-neutral-100 text-xs font-semibold text-neutral-500 uppercase tracking-wide">
              <th class="px-6 py-3 text-left">Client</th>
              <th class="px-6 py-3 text-left hidden md:table-cell">Skin Type</th>
              <th class="px-6 py-3 text-left hidden md:table-cell">Concerns</th>
              <th class="px-6 py-3 text-left hidden lg:table-cell">Contact Pref.</th>
              <th class="px-6 py-3 text-left">Submitted</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-50">
            ${allRecords.map((r: any) => `
              <tr class="hover:bg-neutral-50 cursor-pointer cr-row transition-colors" data-rec='${JSON.stringify(r).replace(/'/g,"&#39;")}'>
                <td class="px-6 py-4">
                  <div class="text-sm font-medium text-neutral-900 ${!r.read_at ? 'font-bold' : ''}">${esc(r.name)}</div>
                  <div class="text-xs text-neutral-400">${esc(r.email)}</div>
                  <div class="text-xs text-neutral-400">${esc(r.phone || '')}</div>
                </td>
                <td class="px-6 py-4 text-xs text-neutral-600 hidden md:table-cell capitalize">${esc(r.skin_type || '—')}</td>
                <td class="px-6 py-4 hidden md:table-cell">
                  <div class="flex flex-wrap gap-1">
                    ${(r.concerns || []).slice(0, 3).map((c: string) => `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-primary-100 text-primary-700">${esc(c.replace(/-/g,' '))}</span>`).join('')}
                    ${(r.concerns || []).length > 3 ? `<span class="text-xs text-neutral-400">+${(r.concerns || []).length - 3}</span>` : ''}
                  </div>
                </td>
                <td class="px-6 py-4 text-xs text-neutral-600 hidden lg:table-cell">${esc(CONTACT_LABELS[r.contact_preference] || r.contact_preference || '—')}</td>
                <td class="px-6 py-4 text-xs text-neutral-400 whitespace-nowrap">${new Date(r.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</td>
              </tr>`).join('')}
          </tbody>
        </table>`;

      wrap.querySelectorAll('.cr-row').forEach(row => {
        row.addEventListener('click', () => {
          const rec = JSON.parse((row as HTMLElement).dataset.rec || '{}');
          openDetail(rec);
        });
      });
    }

    function openDetail(rec: any) {
      const content = document.getElementById('cr-detail-content')!;
      const concernPills = (rec.concerns || []).map((c: string) =>
        `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-primary-100 text-primary-700">${esc(c.replace(/-/g,' '))}</span>`
      ).join(' ');

      content.innerHTML = `
        <div class="space-y-4">
          <div><span class="text-xs font-bold uppercase tracking-widest text-neutral-400">Name</span><p class="mt-1 text-neutral-900 font-semibold text-base">${esc(rec.name)}</p></div>
          <div class="grid grid-cols-2 gap-4">
            <div><span class="text-xs font-bold uppercase tracking-widest text-neutral-400">Email</span><p class="mt-1 text-neutral-800 text-sm break-all">${esc(rec.email)}</p></div>
            <div><span class="text-xs font-bold uppercase tracking-widest text-neutral-400">Phone</span><p class="mt-1 text-neutral-800 text-sm">${esc(rec.phone || '—')}</p></div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div><span class="text-xs font-bold uppercase tracking-widest text-neutral-400">Skin Type</span><p class="mt-1 text-neutral-800 text-sm capitalize">${esc(rec.skin_type || '—')}</p></div>
            <div><span class="text-xs font-bold uppercase tracking-widest text-neutral-400">Contact Pref.</span><p class="mt-1 text-neutral-800 text-sm">${esc(CONTACT_LABELS[rec.contact_preference] || rec.contact_preference || '—')}</p></div>
          </div>
          ${concernPills ? `<div><span class="text-xs font-bold uppercase tracking-widest text-neutral-400">Concerns</span><div class="mt-2 flex flex-wrap gap-1.5">${concernPills}</div></div>` : ''}
          ${rec.current_routine ? `<div><span class="text-xs font-bold uppercase tracking-widest text-neutral-400">Current Routine</span><p class="mt-1 text-neutral-700 text-sm leading-relaxed whitespace-pre-wrap">${esc(rec.current_routine)}</p></div>` : ''}
          ${rec.goals ? `<div><span class="text-xs font-bold uppercase tracking-widest text-neutral-400">Goals</span><p class="mt-1 text-neutral-700 text-sm leading-relaxed whitespace-pre-wrap">${esc(rec.goals)}</p></div>` : ''}
          <div><span class="text-xs font-bold uppercase tracking-widest text-neutral-400">Submitted</span><p class="mt-1 text-neutral-500 text-xs">${new Date(rec.created_at).toLocaleString('en-US')}</p></div>
        </div>
        <div class="flex gap-3 pt-4 border-t border-neutral-100">
          <button id="cr-toggle-read" class="flex-1 py-2.5 px-4 bg-neutral-100 hover:bg-neutral-200 text-neutral-700 text-sm font-semibold rounded-xl transition-colors">
            ${rec.read_at ? 'Mark as Unread' : 'Mark as Read'}
          </button>
          <button id="cr-del-btn" class="py-2.5 px-4 border border-red-200 text-red-500 hover:bg-red-50 text-sm font-semibold rounded-xl transition-colors">Delete</button>
        </div>
      `;

      document.getElementById('cr-detail-panel')?.classList.remove('hidden');
      document.getElementById('cr-detail-panel')?.classList.add('flex');
      document.getElementById('cr-detail-overlay')?.classList.remove('hidden');

      document.getElementById('cr-toggle-read')?.addEventListener('click', async () => {
        try {
          await apiFetch('admin-consultations', { method: 'PATCH', body: { id: rec.id, read: !rec.read_at } });
          closeDetail();
          await load();
        } catch (err: any) { alert(err.message); }
      });

      document.getElementById('cr-del-btn')?.addEventListener('click', async () => {
        if (!confirm(`Delete consultation request from ${rec.name}?`)) return;
        try {
          await apiFetch('admin-consultations', { method: 'DELETE', body: { id: rec.id } });
          closeDetail();
          await load();
        } catch (err: any) { alert(`Delete failed: ${err.message}`); }
      });
    }

    function closeDetail() {
      document.getElementById('cr-detail-panel')?.classList.add('hidden');
      document.getElementById('cr-detail-panel')?.classList.remove('flex');
      document.getElementById('cr-detail-overlay')?.classList.add('hidden');
    }
    document.getElementById('cr-close-detail')?.addEventListener('click', closeDetail);
    document.getElementById('cr-detail-overlay')?.addEventListener('click', closeDetail);

    document.getElementById('cr-mark-all-btn')?.addEventListener('click', async () => {
      if (!confirm('Mark all requests as read?')) return;
      try {
        await apiFetch('admin-consultations', { method: 'PATCH', body: { readAll: true } });
        await load();
      } catch (err: any) { alert(err.message); }
    });

    document.getElementById('cr-load-btn')?.addEventListener('click', load);
    let searchTimer: ReturnType<typeof setTimeout>;
    document.getElementById('cr-search')?.addEventListener('input', () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        const search = (document.getElementById('cr-search') as HTMLInputElement).value.trim().toLowerCase();
        allRecords = search
          ? fullRecords.filter((r: any) =>
              (r.name || '').toLowerCase().includes(search) ||
              (r.email || '').toLowerCase().includes(search))
          : fullRecords;
        render();
      }, 300);
    });

    load();
  </script>

</AdminLayout>
