---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Seasonal Packages – Bliss Dermacare" description="Seasonal face & body packages at Bliss Dermacare: Bronze & Bare Glow, Lash & Body Smooth, Brow Lash & Wax Ritual, Glow & Smooth Escape, Mix & Match Escape in Tampa, FL.">

  <section class="py-14 bg-gradient-to-br from-rose-50 via-primary-50 to-amber-50 border-b border-primary-100">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="flex items-center justify-center gap-2 text-sm text-neutral-500 mb-4">
        <a href="/services/" class="hover:text-primary-600 transition-colors">All Services</a>
        <span>/</span>
        <span class="text-neutral-900 font-medium">Seasonal Packages</span>
      </div>
      <span class="inline-flex items-center gap-2 bg-primary-100 text-primary-700 text-xs font-bold uppercase tracking-[0.2em] px-4 py-1.5 rounded-full mb-4">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707"/></svg>
        Summer 2026
      </span>
      <h1 class="text-5xl font-serif text-neutral-900 mb-4">Seasonal Packages</h1>
      <p class="text-lg text-neutral-600 max-w-xl mx-auto">Two full services in one visit. Each package is approximately a 2-hour experience — 60 min per service with a 15-minute break. Limited seasonal availability.</p>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Featured: Bronze & Bare Glow -->
      <div class="mb-8 rounded-2xl overflow-hidden border-2 border-amber-300 hover:border-amber-500 hover:shadow-2xl transition-all group relative bg-white">
        <div class="absolute top-4 right-4 z-10 flex gap-2">
          <span class="bg-amber-500 text-white text-xs font-bold px-3 py-1 rounded-full">NEW</span>
          <span class="bg-rose-500 text-white text-xs font-bold px-3 py-1 rounded-full">SEASONAL</span>
        </div>
        <div class="grid md:grid-cols-[2fr_3fr]">
          <div class="h-56 md:h-auto overflow-hidden relative">
            <img src="/images/bronze-bare-glow-package.jpg" alt="Bronze & Bare Glow — Body Waxing and Custom Airbrush Spray Tan Package" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent md:bg-gradient-to-r md:from-transparent md:to-transparent"></div>
          </div>
          <div class="p-6 md:p-8">
            <span class="inline-block text-xs font-bold uppercase tracking-[0.15em] text-amber-600 mb-2">Summer's Hottest Combo</span>
            <h2 class="text-2xl font-bold font-serif text-neutral-900 mb-1">Bronze &amp; Bare Glow</h2>
            <p class="text-xs text-primary-600 font-semibold uppercase tracking-wide mb-3">Body Waxing + Custom Airbrush Spray Tan</p>
            <p class="text-sm text-neutral-600 mb-4 max-w-lg">Silky smooth skin meets a flawless, streak-free bronze. Get waxed for the ultimate exfoliated canvas, then receive a custom airbrush spray tan tailored to your skin tone — the perfect pre-event prep in one visit.</p>
            <div class="flex items-baseline gap-2 mb-4">
              <span class="text-3xl font-bold text-neutral-900">$110</span>
              <span class="text-sm text-neutral-400 line-through">$130</span>
              <span class="text-xs font-bold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded-full">Save $20</span>
            </div>
            <ul class="grid sm:grid-cols-2 gap-x-4 gap-y-1.5 text-sm text-neutral-600 mb-5">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Full body waxing (arms, legs, underarms)</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Custom airbrush spray tan application</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Personalized shade matching</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Vegan, paraben-free DHA formula</li>
            </ul>
            <div class="flex items-center justify-between flex-wrap gap-4">
              <span class="flex items-center gap-1 text-xs text-neutral-400"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>~1 hr 45 min &middot; Waxing: Age 21+</span>
              <a href="/book/" data-service-id="bronze-bare-glow" class="bg-amber-500 text-white px-6 py-2.5 rounded-full hover:bg-amber-600 transition-colors text-sm font-semibold shadow-md">Book This Package</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Other packages grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-2 gap-6">

        <div class="bg-white rounded-2xl overflow-hidden border-2 border-primary-200 hover:border-primary-400 hover:shadow-xl transition-all group relative">
          <div class="absolute top-4 right-4"><span class="bg-rose-500 text-white text-xs font-bold px-3 py-1 rounded-full">SEASONAL</span></div>
          <div class="h-44 overflow-hidden relative"><img src="https://images.pexels.com/photos/5128234/pexels-photo-5128234.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Lash Extensions and Body Waxing Package" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /><div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div></div>
          <div class="p-6">
            <h3 class="text-xl font-bold font-serif text-neutral-900 mb-1">Lash &amp; Body Smooth</h3>
            <p class="text-xs text-primary-600 font-semibold uppercase tracking-wide mb-3">Lash Extensions + Body Waxing</p>
            <div class="flex items-baseline gap-2 mb-4"><span class="text-3xl font-bold text-neutral-900">$185</span><span class="text-sm text-neutral-400 line-through">$212</span><span class="text-xs font-bold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded-full">Save $27</span></div>
            <ul class="space-y-2 text-sm text-neutral-600 mb-5">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Classic, hybrid, volume or mega lash set</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Full body &amp; face waxing · Age 21+</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>2 sessions · 60 min each · 15 min break</li>
            </ul>
            <div class="flex items-center justify-between"><span class="text-xs text-neutral-400">~2 hrs 15 min</span><a href="/book/" data-service-id="lash-body-smooth" class="block text-center bg-primary-600 text-white px-5 py-2.5 rounded-full hover:bg-primary-700 transition-colors text-sm font-medium">Book This Package</a></div>
          </div>
        </div>

        <div class="bg-white rounded-2xl overflow-hidden border-2 border-primary-200 hover:border-primary-400 hover:shadow-xl transition-all group relative">
          <div class="absolute top-4 right-4"><span class="bg-rose-500 text-white text-xs font-bold px-3 py-1 rounded-full">SEASONAL</span></div>
          <div class="h-44 overflow-hidden relative"><img src="https://images.pexels.com/photos/5178001/pexels-photo-5178001.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Brow Lamination and Waxing Package" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /><div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div></div>
          <div class="p-6">
            <h3 class="text-xl font-bold font-serif text-neutral-900 mb-1">Brow, Lash &amp; Wax Ritual</h3>
            <p class="text-xs text-primary-600 font-semibold uppercase tracking-wide mb-3">Lash Lift + Brow Lamination + Waxing</p>
            <div class="flex items-baseline gap-2 mb-4"><span class="text-3xl font-bold text-neutral-900">$115</span><span class="text-sm text-neutral-400 line-through">$131</span><span class="text-xs font-bold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded-full">Save $16</span></div>
            <ul class="space-y-2 text-sm text-neutral-600 mb-5">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Lash lift &amp; brow lamination (lasts 6–8 wks)</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Brow tinting &amp; waxing included · Age 21+</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>2 sessions · 60 min each · 15 min break</li>
            </ul>
            <div class="flex items-center justify-between"><span class="text-xs text-neutral-400">~2 hrs 15 min</span><a href="/book/" data-service-id="brow-lash-wax-ritual" class="block text-center bg-primary-600 text-white px-5 py-2.5 rounded-full hover:bg-primary-700 transition-colors text-sm font-medium">Book This Package</a></div>
          </div>
        </div>

        <div class="bg-white rounded-2xl overflow-hidden border-2 border-primary-200 hover:border-primary-400 hover:shadow-xl transition-all group relative">
          <div class="absolute top-4 right-4"><span class="bg-rose-500 text-white text-xs font-bold px-3 py-1 rounded-full">SEASONAL</span></div>
          <div class="h-44 overflow-hidden relative"><img src="https://images.pexels.com/photos/3997993/pexels-photo-3997993.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Dermaplane Facial and Body Waxing Package" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /><div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div></div>
          <div class="p-6">
            <h3 class="text-xl font-bold font-serif text-neutral-900 mb-1">Glow &amp; Smooth Escape</h3>
            <p class="text-xs text-primary-600 font-semibold uppercase tracking-wide mb-3">Dermaplane Facial + Body Waxing</p>
            <div class="flex items-baseline gap-2 mb-4"><span class="text-3xl font-bold text-neutral-900">$135</span><span class="text-sm text-neutral-400 line-through">$158</span><span class="text-xs font-bold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded-full">Save $23</span></div>
            <ul class="space-y-2 text-sm text-neutral-600 mb-5">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Dermaplaning exfoliation &amp; peach fuzz removal</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Full body &amp; face waxing · Age 21+</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Custom serum &amp; hydration mask included</li>
            </ul>
            <div class="flex items-center justify-between"><span class="text-xs text-neutral-400">~2 hrs 15 min</span><a href="/book/" data-service-id="glow-smooth-escape" class="block text-center bg-primary-600 text-white px-5 py-2.5 rounded-full hover:bg-primary-700 transition-colors text-sm font-medium">Book This Package</a></div>
          </div>
        </div>

        <div class="bg-white rounded-2xl overflow-hidden border-2 border-primary-200 hover:border-primary-400 hover:shadow-xl transition-all group relative">
          <div class="absolute top-4 right-4"><span class="bg-primary-600 text-white text-xs font-bold px-3 py-1 rounded-full">NEW</span></div>
          <div class="h-44 overflow-hidden relative"><img src="https://images.pexels.com/photos/3757942/pexels-photo-3757942.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Mix and Match Seasonal Spa Package" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /><div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div></div>
          <div class="p-6">
            <h3 class="text-xl font-bold font-serif text-neutral-900 mb-1">Mix &amp; Match Escape</h3>
            <p class="text-xs text-primary-600 font-semibold uppercase tracking-wide mb-3">Waxing + Your Choice of Service</p>
            <div class="flex items-baseline gap-2 mb-4"><span class="text-3xl font-bold text-neutral-900">From $129</span><span class="text-xs font-bold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded-full">Save up to $25</span></div>
            <ul class="space-y-1.5 text-sm text-neutral-600 mb-4">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Session 1: Body or Face Waxing (60 min)</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Session 2: Facial, lash or wax — your choice</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>$15 package discount applied</li>
            </ul>
            <div class="flex items-center justify-between"><span class="text-xs text-neutral-400">~2 hrs 15 min</span><a href="/book/" data-service-id="mix-match-package" class="block text-center bg-primary-600 text-white px-5 py-2.5 rounded-full hover:bg-primary-700 transition-colors text-sm font-medium">Book This Package</a></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-10 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-neutral-400 mb-4">Also Explore</p>
      <div class="flex flex-wrap gap-3">
        <a href="/services/facials/" class="px-4 py-2 bg-white border border-neutral-200 rounded-full text-sm text-neutral-700 hover:border-primary-300 hover:text-primary-600 transition-colors">Facials</a>
        <a href="/services/lash-brow-body/" class="px-4 py-2 bg-white border border-neutral-200 rounded-full text-sm text-neutral-700 hover:border-primary-300 hover:text-primary-600 transition-colors">Lash, Brow &amp; Body</a>
        <a href="/services/advanced-treatments/" class="px-4 py-2 bg-white border border-neutral-200 rounded-full text-sm text-neutral-700 hover:border-primary-300 hover:text-primary-600 transition-colors">Advanced Treatments</a>
        <a href="/services/semipermanent-makeup/" class="px-4 py-2 bg-white border border-neutral-200 rounded-full text-sm text-neutral-700 hover:border-primary-300 hover:text-primary-600 transition-colors">Semipermanent Makeup</a>
        <a href="/services/ancillary/" class="px-4 py-2 bg-white border border-neutral-200 rounded-full text-sm text-neutral-700 hover:border-primary-300 hover:text-primary-600 transition-colors">Ancillary Services</a>
      </div>
    </div>
  </section>

  <section class="py-14 bg-neutral-900 text-white text-center">
    <div class="max-w-xl mx-auto px-6">
      <h2 class="text-3xl font-serif mb-4">Ready to book a package?</h2>
      <p class="text-neutral-400 mb-8">All packages are standalone bookings. Limited seasonal availability.</p>
      <a href="/book/" class="inline-flex items-center gap-2 bg-primary-600 text-white px-8 py-4 rounded-full hover:bg-primary-700 transition-all font-medium shadow-lg">Request Booking <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></a>
    </div>
  </section>

</Layout>
