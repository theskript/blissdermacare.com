---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Services – Bliss Dermacare" description="Browse all skincare treatments and packages at Bliss Dermacare in Pebble Creek, FL. Facials, PRP, waxing, lash extensions, scalp therapy & more.">

  <!-- Page Header -->
  <section class="py-14 bg-[#faf9f7] border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-4 block">Treatments & Packages</span>
      <h1 class="text-5xl font-serif text-neutral-900 mb-4">Our Services</h1>
      <p class="text-lg text-neutral-600">Every treatment is personalized. Browse what we offer, then book your appointment below.</p>
    </div>
  </section>

  <!-- Treatment Packages -->
  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-10">
        <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-3 block">Packages</span>
        <h2 class="text-3xl font-serif text-neutral-900">Treatment Packages</h2>
        <p class="text-neutral-600 mt-2">Save with curated packages designed for consistency and visible results.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="border-2 border-neutral-200 rounded-2xl p-8 hover:border-primary-300 transition-all">
          <h3 class="text-xl font-bold text-neutral-900 mb-1">Fresh Start Collection</h3>
          <p class="text-neutral-500 text-sm mb-5">Perfect for trying our services</p>
          <div class="mb-5">
            <span class="text-4xl font-bold text-neutral-900">$280</span>
            <span class="text-neutral-500 text-sm ml-1">/ 3 sessions</span>
            <p class="text-sm text-primary-600 mt-1">Save $25</p>
          </div>
          <ul class="space-y-2 mb-7 text-sm text-neutral-600">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>3 Signature Radiance Facials</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Complimentary Skin Analysis</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>10% Off Skincare Products</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Valid 6 months</li>
          </ul>
          <a href="/book/" class="block text-center bg-neutral-900 text-white px-5 py-2.5 rounded-full hover:bg-neutral-800 transition-colors text-sm font-medium">Get Started</a>
        </div>

        <div class="border-2 border-primary-500 rounded-2xl p-8 relative bg-primary-50/50">
          <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-primary-600 text-white px-4 py-1 rounded-full text-xs font-semibold">Most Popular</div>
          <h3 class="text-xl font-bold text-neutral-900 mb-1">Radiant Glow Ritual</h3>
          <p class="text-neutral-500 text-sm mb-5">Best value for regular care</p>
          <div class="mb-5">
            <span class="text-4xl font-bold text-neutral-900">$665</span>
            <span class="text-neutral-500 text-sm ml-1">/ 6 sessions</span>
            <p class="text-sm text-primary-600 mt-1">Save $102+</p>
          </div>
          <ul class="space-y-2 mb-7 text-sm text-neutral-600">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>6 Mix &amp; Match Treatments</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Priority Booking Access</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>15% Off All Products</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Free LED Light Therapy Add-on</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Valid 9 months</li>
          </ul>
          <a href="/book/" class="block text-center bg-primary-600 text-white px-5 py-2.5 rounded-full hover:bg-primary-700 transition-colors text-sm font-medium">Choose Package</a>
        </div>

        <div class="border-2 border-neutral-200 rounded-2xl p-8 hover:border-primary-300 transition-all">
          <h3 class="text-xl font-bold text-neutral-900 mb-1">Ultimate Transformation</h3>
          <p class="text-neutral-500 text-sm mb-5">Ultimate skincare experience</p>
          <div class="mb-5">
            <span class="text-4xl font-bold text-neutral-900">$1,425</span>
            <span class="text-neutral-500 text-sm ml-1">/ 12 sessions</span>
            <p class="text-sm text-primary-600 mt-1">Save $272+</p>
          </div>
          <ul class="space-y-2 mb-7 text-sm text-neutral-600">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>12 Premium Treatments</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>VIP Priority &amp; Flexible Scheduling</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>20% Off All Products &amp; Services</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>2 Free Treatment Upgrades</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Deluxe Home Care Kit</li>
