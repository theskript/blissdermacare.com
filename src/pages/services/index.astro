          </ul>
          <a href="/book/" class="block text-center bg-neutral-900 text-white px-5 py-2.5 rounded-full hover:bg-neutral-800 transition-colors text-sm font-medium">Get Premium</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Individual Services Grid -->
  <section class="py-14 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-10">
        <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-3 block">Individual Sessions</span>
        <h2 class="text-3xl font-serif text-neutral-900">All Treatments</h2>
      </div>

      <!-- Featured 3 -->
      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <div class="group bg-white rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 border-2 border-primary-100 hover:border-primary-300 relative">
          <div class="absolute top-4 right-4 z-10"><span class="bg-primary-600 text-white text-xs font-bold px-3 py-1 rounded-full">BESTSELLER</span></div>
          <div class="relative h-52 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=600&h=400&fit=crop&q=80" alt="Signature Radiance Facial" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold font-serif text-neutral-900 mb-2">Signature Radiance Facial</h3>
            <p class="text-neutral-600 text-sm mb-4">Deep cleansing, exfoliation, steam, extractions, custom mask & facial massage. All skin types.</p>
            <div class="flex items-center justify-between">
              <div><p class="text-2xl font-bold text-primary-600">$99</p><p class="text-xs text-neutral-500">60 minutes</p></div>
              <a href="/book/" class="px-4 py-2 bg-primary-600 text-white text-sm font-semibold rounded-full hover:bg-primary-700 transition-colors">Book</a>
            </div>
          </div>
        </div>

        <div class="group bg-white rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 border-2 border-primary-100 hover:border-primary-300 relative">
          <div class="absolute top-4 right-4 z-10"><span class="bg-amber-500 text-white text-xs font-bold px-3 py-1 rounded-full">PREMIUM</span></div>
          <div class="relative h-52 overflow-hidden">
            <img src="https://images.pexels.com/photos/29648626/pexels-photo-29648626.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Vampire Facial PRP" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold font-serif text-neutral-900 mb-2">Vampire Facial (PRP)</h3>
            <p class="text-neutral-600 text-sm mb-4">Advanced PRP + microneedling. Reduces fine lines, scars & improves overall texture.</p>
            <div class="flex items-center justify-between">
              <div><p class="text-2xl font-bold text-primary-600">$380</p><p class="text-xs text-neutral-500">75 min | Series of 3</p></div>
              <a href="/book/" class="px-4 py-2 bg-primary-600 text-white text-sm font-semibold rounded-full hover:bg-primary-700 transition-colors">Book</a>
            </div>
          </div>
        </div>

        <div class="group bg-white rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 border-2 border-primary-100 hover:border-primary-300 relative">
          <div class="absolute top-4 right-4 z-10"><span class="bg-rose-500 text-white text-xs font-bold px-3 py-1 rounded-full">TRENDING</span></div>
          <div class="relative h-52 overflow-hidden">
            <img src="https://images.pexels.com/photos/5178001/pexels-photo-5178001.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Lash Lift & Brow Lamination" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold font-serif text-neutral-900 mb-2">Lash Lift &amp; Brow Lamination</h3>
            <p class="text-neutral-600 text-sm mb-4">Professional lift and definition for your natural lashes and brows. Lasts 6–8 weeks.</p>
            <div class="flex items-center justify-between">
              <div><p class="text-2xl font-bold text-primary-600">$72</p><p class="text-xs text-neutral-500">60 minutes</p></div>
              <a href="/book/" class="px-4 py-2 bg-primary-600 text-white text-sm font-semibold rounded-full hover:bg-primary-700 transition-colors">Book</a>
            </div>
          </div>
        </div>
      </div>

      <!-- More Services -->
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all border border-neutral-200">
          <div class="relative h-32 overflow-hidden"><img src="https://images.pexels.com/photos/3997993/pexels-photo-3997993.jpeg?auto=compress&cs=tinysrgb&w=400" alt="Body & Face Waxing" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /><div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div></div>
          <div class="p-4">
            <h3 class="text-base font-bold text-neutral-900 mb-1">Body &amp; Face Waxing</h3>
            <p class="text-neutral-500 text-xs mb-3">Facial, arms, legs &amp; underarms. Smooth, hair-free results.</p>
            <div class="flex items-center justify-between"><div><p class="text-lg font-bold text-primary-600">$59</p><p class="text-xs text-neutral-400">45–60 min</p></div><a href="/book/" class="px-3 py-1.5 bg-primary-600 text-white text-xs font-medium rounded-full hover:bg-primary-700 transition-colors">Book</a></div>
          </div>
        </div>
        <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all border border-neutral-200">
          <div class="relative h-32 overflow-hidden"><img src="https://res.cloudinary.com/liaison-inc/image/upload/f_auto/q_auto,w_1200/v1762764980/content/thervo/thervo-brazilian-wax-cost-beautician-applying-wax-on-client-as-part-of-hair-removal-treatment.jpg" alt="Brazilian Wax" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /><div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div></div>
          <div class="p-4">
            <h3 class="text-base font-bold text-neutral-900 mb-1">Brazilian Wax</h3>
            <p class="text-neutral-500 text-xs mb-3">Complete bikini area hair removal. Smooth &amp; long-lasting.</p>
            <div class="flex items-center justify-between"><div><p class="text-lg font-bold text-primary-600">$85</p><p class="text-xs text-neutral-400">45–60 min</p></div><a href="/book/" class="px-3 py-1.5 bg-primary-600 text-white text-xs font-medium rounded-full hover:bg-primary-700 transition-colors">Book</a></div>
          </div>
        </div>
        <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all border border-neutral-200">
          <div class="relative h-32 overflow-hidden"><img src="https://images.unsplash.com/photo-1646457417455-77a66a9fcf34?w=400&h=300&fit=crop&q=80" alt="Age-Defying Renewal" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /><div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div></div>
          <div class="p-4">
            <h3 class="text-base font-bold text-neutral-900 mb-1">Age-Defying Renewal</h3>
            <p class="text-neutral-500 text-xs mb-3">Peptide serums, LED therapy &amp; firming mask.</p>
            <div class="flex items-center justify-between"><div><p class="text-lg font-bold text-primary-600">$149</p><p class="text-xs text-neutral-400">75 min</p></div><a href="/book/" class="px-3 py-1.5 bg-primary-600 text-white text-xs font-medium rounded-full hover:bg-primary-700 transition-colors">Book</a></div>
          </div>
        </div>
        <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all border border-neutral-200">
          <div class="relative h-32 overflow-hidden"><img src="https://images.pexels.com/photos/5069454/pexels-photo-5069454.jpeg?auto=compress&cs=tinysrgb&w=400" alt="Brightening Peel" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /><div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div></div>
          <div class="p-4">
            <h3 class="text-base font-bold text-neutral-900 mb-1">Brightening Peel</h3>
            <p class="text-neutral-500 text-xs mb-3">Medical-grade chemical exfoliation for texture &amp; hyperpigmentation.</p>
            <div class="flex items-center justify-between"><div><p class="text-lg font-bold text-primary-600">$128</p><p class="text-xs text-neutral-400">45 min</p></div><a href="/book/" class="px-3 py-1.5 bg-primary-600 text-white text-xs font-medium rounded-full hover:bg-primary-700 transition-colors">Book</a></div>
          </div>
        </div>
        <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all border border-neutral-200">
          <div class="relative h-32 overflow-hidden"><img src="/images/diamond-glow.jpg" alt="Diamond Glow" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /><div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div></div>
          <div class="p-4">
            <h3 class="text-base font-bold text-neutral-900 mb-1">Diamond Glow</h3>
            <p class="text-neutral-500 text-xs mb-3">Diamond-tip microdermabrasion for instant glow.</p>
            <div class="flex items-center justify-between"><div><p class="text-lg font-bold text-primary-600">$115</p><p class="text-xs text-neutral-400">50 min</p></div><a href="/book/" class="px-3 py-1.5 bg-primary-600 text-white text-xs font-medium rounded-full hover:bg-primary-700 transition-colors">Book</a></div>
          </div>
        </div>
        <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all border border-neutral-200">
          <div class="relative h-32 overflow-hidden"><img src="https://images.pexels.com/photos/6476078/pexels-photo-6476078.jpeg?auto=compress&cs=tinysrgb&w=400" alt="Clear Skin Treatment" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /><div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div></div>
          <div class="p-4">
            <h3 class="text-base font-bold text-neutral-900 mb-1">Clear Skin Treatment</h3>
            <p class="text-neutral-500 text-xs mb-3">Deep-pore cleansing with high-frequency &amp; LED.</p>
            <div class="flex items-center justify-between"><div><p class="text-lg font-bold text-primary-600">$111</p><p class="text-xs text-neutral-400">75 min</p></div><a href="/book/" class="px-3 py-1.5 bg-primary-600 text-white text-xs font-medium rounded-full hover:bg-primary-700 transition-colors">Book</a></div>
