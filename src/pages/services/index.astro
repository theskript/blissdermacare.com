---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Services – Bliss Dermacare" description="Browse all skincare, aesthetic, and wellness services at Bliss Dermacare in Pebble Creek, FL — facials, lash, brow, body, advanced treatments, semipermanent makeup, ancillary wellness, and seasonal packages.">

  <!-- Page Header -->
  <section class="py-14 bg-[#faf9f7] border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-4 block">Treatments &amp; Packages</span>
      <h1 class="text-5xl font-serif text-neutral-900 mb-4">Our Services</h1>
      <p class="text-lg text-neutral-600 max-w-xl mx-auto">Every treatment is personalized. Browse by category to find what's right for you, then book your appointment.</p>
    </div>
  </section>

  <!-- Service Category Hub -->
  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Facials -->
        <a href="/services/facials/" class="group block rounded-2xl overflow-hidden border-2 border-primary-100 hover:border-primary-400 hover:shadow-xl transition-all">
          <div class="h-52 overflow-hidden relative">
            <img src="/images/dermaplane-glow-facial.jpg" alt="Facials at Bliss Dermacare" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-neutral-900/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 text-white">
              <h2 class="text-xl font-serif font-bold mb-0.5">Facials</h2>
              <p class="text-xs text-neutral-300">Dermaplaning · Enzyme Facials · Peels · PRP · &amp; more</p>
            </div>
          </div>
          <div class="p-5 flex items-center justify-between">
            <div><p class="text-sm font-semibold text-neutral-800">12 treatments</p><p class="text-xs text-neutral-500">From $64</p></div>
            <span class="inline-flex items-center gap-1 text-sm font-semibold text-primary-600 group-hover:gap-2 transition-all">Explore <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
          </div>
        </a>

        <!-- Lash, Brow & Body -->
        <a href="/services/lash-brow-body/" class="group block rounded-2xl overflow-hidden border-2 border-primary-100 hover:border-primary-400 hover:shadow-xl transition-all">
          <div class="h-52 overflow-hidden relative">
            <img src="https://images.pexels.com/photos/5128234/pexels-photo-5128234.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Lash, Brow & Body at Bliss Dermacare" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-neutral-900/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 text-white">
              <h2 class="text-xl font-serif font-bold mb-0.5">Lash, Brow &amp; Body</h2>
              <p class="text-xs text-neutral-300">Lash Extensions · Waxing · Spray Tan · Scalp Therapy</p>
            </div>
          </div>
          <div class="p-5 flex items-center justify-between">
            <div><p class="text-sm font-semibold text-neutral-800">7 treatments</p><p class="text-xs text-neutral-500">From $43</p></div>
            <span class="inline-flex items-center gap-1 text-sm font-semibold text-primary-600 group-hover:gap-2 transition-all">Explore <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
          </div>
        </a>

        <!-- Advanced Treatments -->
        <a href="/services/advanced-treatments/" class="group block rounded-2xl overflow-hidden border-2 border-primary-100 hover:border-primary-400 hover:shadow-xl transition-all">
          <div class="h-52 overflow-hidden relative">
            <img src="/images/collagen-induction-therapy.jpg" alt="Advanced Treatments — medical-grade injectables and skin procedures at Bliss Dermacare" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-neutral-900/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 text-white">
              <h2 class="text-xl font-serif font-bold mb-0.5">Advanced Treatments</h2>
              <p class="text-xs text-neutral-300">PRP · Lip Filler · Injectables · CIT · Weight Loss</p>
            </div>
          </div>
          <div class="p-5 flex items-center justify-between">
            <div><p class="text-sm font-semibold text-neutral-800">5 treatments</p><p class="text-xs text-neutral-500">From $299</p></div>
            <span class="inline-flex items-center gap-1 text-sm font-semibold text-primary-600 group-hover:gap-2 transition-all">Explore <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
          </div>
        </a>

        <!-- Semipermanent Makeup -->
        <a href="/services/semipermanent-makeup/" class="group block rounded-2xl overflow-hidden border-2 border-primary-100 hover:border-primary-400 hover:shadow-xl transition-all">
          <div class="h-52 overflow-hidden relative">
            <img src="/images/eyebrow-permanent-makeup.jpg" alt="Semipermanent Makeup — brows, lip blush, scalp micropigmentation at Bliss Dermacare" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-neutral-900/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 text-white">
              <h2 class="text-xl font-serif font-bold mb-0.5">Semipermanent Makeup</h2>
              <p class="text-xs text-neutral-300">Nano Brows · Powder Brows · Lip Blush · Scalp SMP</p>
            </div>
          </div>
          <div class="p-5 flex items-center justify-between">
            <div><p class="text-sm font-semibold text-neutral-800">6 treatments</p><p class="text-xs text-neutral-500">From $250</p></div>
            <span class="inline-flex items-center gap-1 text-sm font-semibold text-primary-600 group-hover:gap-2 transition-all">Explore <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
          </div>
        </a>

        <!-- Ancillary Services -->
        <a href="/services/ancillary/" class="group block rounded-2xl overflow-hidden border-2 border-primary-100 hover:border-primary-400 hover:shadow-xl transition-all">
          <div class="h-52 overflow-hidden relative">
            <img src="/images/ancillary-services-hub.jpg" alt="Ancillary Services — medical lab, IV therapy and wellness at Bliss Dermacare" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-neutral-900/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 text-white">
              <h2 class="text-xl font-serif font-bold mb-0.5">Ancillary Services</h2>
              <p class="text-xs text-neutral-300">IV Hydration · Lab Collection · Hormone Panel · Regenerative</p>
            </div>
          </div>
          <div class="p-5 flex items-center justify-between">
            <div><p class="text-sm font-semibold text-neutral-800">4 services</p><p class="text-xs text-neutral-500">From $149</p></div>
            <span class="inline-flex items-center gap-1 text-sm font-semibold text-primary-600 group-hover:gap-2 transition-all">Explore <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
          </div>
        </a>

        <!-- Seasonal Packages -->
        <a href="/services/packages/" class="group block rounded-2xl overflow-hidden border-2 border-amber-200 hover:border-amber-400 hover:shadow-xl transition-all relative">
          <div class="absolute top-3 right-3 z-10"><span class="bg-amber-500 text-white text-xs font-bold px-2.5 py-1 rounded-full">SUMMER 2026</span></div>
          <div class="h-52 overflow-hidden relative">
            <img src="/images/bronze-bare-glow-package.jpg" alt="Seasonal Packages at Bliss Dermacare" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-neutral-900/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 text-white">
              <h2 class="text-xl font-serif font-bold mb-0.5">Seasonal Packages</h2>
              <p class="text-xs text-neutral-300">Two services · One visit · Up to $27 savings</p>
            </div>
          </div>
          <div class="p-5 flex items-center justify-between">
            <div><p class="text-sm font-semibold text-neutral-800">5 packages</p><p class="text-xs text-neutral-500">From $110</p></div>
            <span class="inline-flex items-center gap-1 text-sm font-semibold text-amber-600 group-hover:gap-2 transition-all">Explore <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Membership Upsell -->
  <section class="py-14 bg-gradient-to-br from-primary-600 to-rose-600 text-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <span class="inline-flex items-center gap-2 bg-white/20 text-white text-xs font-bold uppercase tracking-[0.18em] px-3 py-1.5 rounded-full mb-5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
            Member Plans
          </span>
          <h2 class="text-3xl font-serif mb-4">Love these services?<br/>Get them on a monthly plan.</h2>
          <p class="text-rose-100 mb-6">Our membership plans lock in monthly credits for your favorite services at a fraction of the regular price — with priority booking, exclusive discounts, and no long-term commitment.</p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/memberships/" class="inline-block bg-white text-primary-700 px-7 py-3 rounded-full hover:bg-rose-50 transition-colors font-semibold text-sm shadow-md">View Membership Plans</a>
            <a href="/book/" class="inline-block border border-white/40 text-white px-7 py-3 rounded-full hover:bg-white/10 transition-colors font-medium text-sm">Book Single Appointment</a>
          </div>
        </div>
        <div class="grid grid-cols-3 gap-3">
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-4 text-center border border-white/20">
            <p class="text-2xl font-bold font-serif mb-1">$89</p>
            <p class="text-xs text-rose-200 font-semibold uppercase tracking-wide mb-2">/month</p>
            <p class="text-xs text-rose-100">Glow Ritual</p>
            <p class="text-[10px] text-rose-200 mt-1">1 facial/mo</p>
          </div>
          <div class="bg-white/20 backdrop-blur-sm rounded-2xl p-4 text-center border-2 border-white/50 relative">
            <span class="absolute -top-2.5 left-1/2 -translate-x-1/2 text-[9px] font-bold bg-white text-primary-700 px-2 py-0.5 rounded-full whitespace-nowrap">Most Popular</span>
            <p class="text-2xl font-bold font-serif mb-1">$159</p>
            <p class="text-xs text-rose-200 font-semibold uppercase tracking-wide mb-2">/month</p>
            <p class="text-xs text-rose-100">Radiance Plan</p>
            <p class="text-[10px] text-rose-200 mt-1">2 services/mo</p>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-4 text-center border border-white/20">
            <p class="text-2xl font-bold font-serif mb-1">$249</p>
            <p class="text-xs text-rose-200 font-semibold uppercase tracking-wide mb-2">/month</p>
            <p class="text-xs text-rose-100">Bliss VIP</p>
            <p class="text-[10px] text-rose-200 mt-1">3 services/mo</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Book CTA -->
  <section class="py-14 bg-neutral-900 text-white text-center">
    <div class="max-w-xl mx-auto px-6">
      <h2 class="text-3xl font-serif mb-4">Ready to book?</h2>
      <p class="text-neutral-400 mb-8">Choose your service and request a time that works for you. We'll confirm shortly.</p>
      <a href="/book/" class="inline-flex items-center gap-2 bg-primary-600 text-white px-8 py-4 rounded-full hover:bg-primary-700 transition-all font-medium shadow-lg">
        Request Booking
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
  </section>

</Layout>
