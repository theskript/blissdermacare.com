---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bliss Dermacare - Professional Aesthetician Services">
  <!-- Upcoming Events Banner -->
  <section class="bg-gradient-to-r from-primary-600 via-primary-500 to-primary-600 text-white py-3 md:py-4">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-center gap-2 md:gap-6 text-center">
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-6 h-6 bg-white/20 rounded-full">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </span>
          <span class="font-semibold text-sm md:text-base">Upcoming Events</span>
        </div>
        <div class="hidden md:block w-px h-6 bg-white/30"></div>
        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-1 text-sm md:text-base">
          <span class="flex items-center gap-1.5">
            <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
            <strong>March 16:</strong> Spring Glow Facial Event
          </span>
          <span class="hidden sm:inline text-white/50">|</span>
          <span class="flex items-center gap-1.5">
            <span class="w-2 h-2 bg-yellow-400 rounded-full"></span>
            <strong>March 22:</strong> Free Skin Consultation Day
          </span>
        </div>
        <a href="#consultation" class="mt-2 md:mt-0 inline-flex items-center text-sm font-medium bg-white/20 hover:bg-white/30 px-4 py-1.5 rounded-full transition-colors">
          Reserve Your Spot
          <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Simple Hero Section -->
  <section class="bg-[#f6f1eb] py-12 md:py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="grid items-center gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:gap-16">
        <div class="order-2 lg:order-1">
          <span class="mb-4 block text-xs font-semibold uppercase tracking-[0.24em] text-primary-600">Pebble Creek, Florida</span>
          <h1 class="mb-6 max-w-3xl text-4xl font-serif leading-tight text-neutral-900 md:text-5xl lg:text-6xl">
            Clinical skincare with a softer, more personal approach.
          </h1>
          <p class="mb-8 max-w-2xl text-lg leading-relaxed text-neutral-600 md:text-xl">
            Bliss Dermacare offers customized facials and skin-focused treatments designed to restore clarity, calm, and confidence without the rushed feel of a typical medspa visit.
          </p>
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
            <a href="#booking"
               class="group inline-flex items-center justify-center gap-2 bg-neutral-900 px-6 py-3 font-medium text-white transition-colors hover:bg-neutral-800 md:px-8 md:py-4">
              Reserve Your Appointment
              <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            <a href="#treatments" class="inline-flex items-center justify-center gap-2 font-medium text-primary-700 transition-colors hover:text-primary-800">
              View Treatment Options
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <figure class="mx-auto max-w-md">
            <div class="overflow-hidden rounded-sm bg-[#e8ddd2] p-3 shadow-[0_24px_70px_rgba(38,31,24,0.10)]">
              <img
                src="/hero-blissdermacare.jpg"
                alt="Bliss Dermacare Aesthetician Services"
                class="block w-full h-auto"
                width="600"
                height="400"
                loading="eager"
              />
            </div>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- Booking Process -->
  <section class="py-14 bg-[#faf9f7]">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="max-w-3xl mb-10">
        <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-4 block">How Booking Works</span>
        <h2 class="text-4xl lg:text-5xl font-serif text-neutral-900 leading-[1.1] mb-4">Simple, direct, and easy to confirm.</h2>
        <p class="text-lg text-neutral-600 leading-relaxed">Choose the service you want, request a time that works for you, and receive a confirmed appointment after review. No third-party widget, no extra tabs, no confusion.</p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-primary-100 text-primary-700 font-semibold">1</div>
          <h3 class="mb-2 text-xl font-serif text-neutral-900">Pick your treatment</h3>
          <p class="text-neutral-600">Review packages and services first so your booking request matches the care you actually want.</p>
        </div>
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-primary-100 text-primary-700 font-semibold">2</div>
          <h3 class="mb-2 text-xl font-serif text-neutral-900">Choose a time slot</h3>
          <p class="text-neutral-600">Select your preferred day and appointment window from the booking form below.</p>
        </div>
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-primary-100 text-primary-700 font-semibold">3</div>
          <h3 class="mb-2 text-xl font-serif text-neutral-900">Receive confirmation</h3>
          <p class="text-neutral-600">Bliss Dermacare follows up promptly to confirm your timeslot and any pre-appointment details.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Treatments Section -->
  <section id="treatments" class="py-12 md:py-16 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold font-serif text-neutral-900 mb-4">Treatment Packages</h2>
        <p class="text-xl text-neutral-600 max-w-2xl mx-auto">
          Save with curated packages designed for consistency, visible results, and easier maintenance.
        </p>
      </div>

      <div class="grid md:grid-cols-4 gap-8 max-w-7xl mx-auto">
        <div class="border-2 border-neutral-200 rounded-2xl p-8 hover:border-primary-600 transition-all">
          <h3 class="text-2xl font-bold text-neutral-900 mb-2">Fresh Start Collection</h3>
          <p class="text-neutral-600 mb-6">Perfect for trying our services</p>
          <div class="mb-6">
            <span class="text-5xl font-bold text-neutral-900">$280</span>
            <span class="text-neutral-600 ml-2">/ 3 sessions</span>
            <div class="text-sm text-primary-600 mt-1">Save $25</div>
          </div>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>3 Signature Radiance Facials</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Complimentary Skin Analysis</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>10% Off Skincare Products</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Valid 6 months</span></li>
          </ul>
          <a href="#booking" class="block text-center bg-neutral-900 text-white px-6 py-3 rounded-full hover:bg-neutral-800 transition-colors font-medium">Get Started</a>
        </div>

        <div class="border-2 border-primary-600 rounded-2xl p-8 relative bg-primary-50/50">
          <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-primary-600 text-white px-4 py-1 rounded-full text-sm font-medium">Most Popular</div>
          <h3 class="text-2xl font-bold text-neutral-900 mb-2">Radiant Glow Ritual</h3>
          <p class="text-neutral-600 mb-6">Best value for regular care</p>
          <div class="mb-6">
            <span class="text-5xl font-bold text-neutral-900">$665</span>
            <span class="text-neutral-600 ml-2">/ 6 sessions</span>
            <div class="text-sm text-primary-600 mt-1">Save $102+</div>
          </div>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>6 Treatments (Mix & Match: Signature Radiance, Diamond Glow, Clear Skin Purifying)</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Priority booking access</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>15% Off All Skincare Products</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Complimentary LED Light Therapy Add-on</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Valid 9 months</span></li>
          </ul>
          <a href="#booking" class="block text-center bg-primary-600 text-white px-6 py-3 rounded-full hover:bg-primary-700 transition-colors font-medium shadow-lg">Choose Package</a>
        </div>

        <div class="border-2 border-neutral-200 rounded-2xl p-8 hover:border-primary-600 transition-all">
          <h3 class="text-2xl font-bold text-neutral-900 mb-2">Ultimate Transformation</h3>
          <p class="text-neutral-600 mb-6">Ultimate skincare experience</p>
          <div class="mb-6">
            <span class="text-5xl font-bold text-neutral-900">$1,425</span>
            <span class="text-neutral-600 ml-2">/ 12 sessions</span>
            <div class="text-sm text-primary-600 mt-1">Save $272+</div>
          </div>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>12 Premium Treatments (Platinum Hydrafacial MD, Age-Defying Renewal, Brightening Resurfacing)</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>VIP Priority Booking & Flexible Scheduling</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>20% Off All Products & Services</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>2 Free Treatment Upgrades ($100 value)</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Deluxe Home Care Kit ($150 value)</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Valid 12 months</span></li>
          </ul>
          <a href="#booking" class="block text-center bg-neutral-900 text-white px-6 py-3 rounded-full hover:bg-neutral-800 transition-colors font-medium">Get Premium</a>
        </div>

        <div class="border-2 border-primary-600 rounded-2xl p-8 bg-gradient-to-br from-primary-50 to-white hover:shadow-xl transition-all">
          <div class="inline-block bg-primary-600 text-white px-3 py-1 rounded-full text-xs font-semibold mb-4">MOBILE SPA</div>
          <h3 class="text-2xl font-bold text-neutral-900 mb-2">Luxury In-Home Experience</h3>
          <p class="text-neutral-600 mb-6">We bring the spa to you</p>
          <div class="mb-6">
            <span class="text-5xl font-bold text-neutral-900">$170</span>
            <span class="text-neutral-600 ml-2">/ per visit</span>
            <div class="text-sm text-primary-600 mt-1">+ $30 travel fee (within 10 miles)</div>
          </div>
          <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 mb-6">
            <p class="text-sm text-amber-900"><strong>Required:</strong> Complimentary consultation & screening call before first booking. Service area limited to 10-mile radius.</p>
          </div>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Any 90-Minute Signature Treatment</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Professional Equipment Brought to Your Home</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Luxurious Linens & Premium Products Included</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Complete Setup & Cleanup Service</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Flexible Scheduling (Evenings & Weekends Available)</span></li>
            <li class="flex items-start"><svg class="w-6 h-6 text-primary-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Perfect for Spa Parties (3+ guests, special rates)</span></li>
          </ul>
          <a href="#booking" class="block text-center bg-primary-600 text-white px-6 py-3 rounded-full hover:bg-primary-700 transition-colors font-medium shadow-lg">Book Mobile Service</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-12 md:py-16 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-8">
        <span class="text-primary-600 font-semibold text-sm uppercase tracking-wider">Treatments</span>
        <h2 class="text-4xl md:text-5xl font-bold font-serif text-neutral-900 mt-2 mb-4">Our Services</h2>
        <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
          Expert treatments designed to address your specific concerns and enhance your natural radiance.
        </p>
      </div>

      <!-- Featured Services Section -->
      <div class="mb-10">
        <div class="flex items-center justify-center gap-3 mb-8">
          <div class="h-px bg-gradient-to-r from-transparent to-primary-200 flex-1 max-w-[100px]"></div>
          <span class="inline-flex items-center gap-2 bg-primary-50 text-primary-700 px-4 py-2 rounded-full text-sm font-semibold">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            Most Popular
          </span>
          <div class="h-px bg-gradient-to-l from-transparent to-primary-200 flex-1 max-w-[100px]"></div>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <!-- Featured Service 1: Signature Radiance Facial -->
          <div class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all duration-300 border-2 border-primary-100 hover:border-primary-300 relative">
            <div class="absolute top-4 right-4 z-10">
              <span class="bg-primary-600 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">BESTSELLER</span>
            </div>
            <div class="relative h-56 overflow-hidden">
              <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=600&h=400&fit=crop&q=80" alt="Relaxing signature facial treatment with cleansing and mask application" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
            </div>
            <div class="p-8">
              <h3 class="text-2xl font-bold font-serif text-neutral-900 mb-3">Signature Radiance Facial</h3>
              <p class="text-neutral-600 mb-4">
                Personalized deep cleansing treatment with double cleanse, exfoliation, steam therapy, professional extractions, custom mask, serums, and therapeutic facial massage. Perfect for all skin types.
              </p>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-3xl font-bold text-primary-600">$99</p>
                  <p class="text-sm text-neutral-500">60 minutes</p>
                </div>
                <a href="#booking" class="px-5 py-2.5 bg-primary-600 text-white text-sm font-semibold rounded-full hover:bg-primary-700 transition-colors shadow-md hover:shadow-lg">Book Now</a>
              </div>
            </div>
          </div>

          <!-- Featured Service 2: Vampire Facial (PRP) -->
          <div class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all duration-300 border-2 border-primary-100 hover:border-primary-300 relative">
            <div class="absolute top-4 right-4 z-10">
              <span class="bg-amber-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">PREMIUM</span>
            </div>
            <div class="relative h-56 overflow-hidden">
              <img src="https://images.pexels.com/photos/29648626/pexels-photo-29648626.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Professional PRP Vampire Facial microneedling treatment" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
            </div>
            <div class="p-8">
              <h3 class="text-2xl font-bold font-serif text-neutral-900 mb-3">Vampire Facial (PRP)</h3>
              <p class="text-neutral-600 mb-4">
                Advanced platelet-rich plasma facial combining microneedling with your body's own growth factors. Reduces fine lines, acne scars, hyperpigmentation, and improves overall skin texture.
              </p>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-3xl font-bold text-primary-600">$380</p>
                  <p class="text-sm text-neutral-500">75 min | Series of 3</p>
                </div>
                <a href="#booking" class="px-5 py-2.5 bg-primary-600 text-white text-sm font-semibold rounded-full hover:bg-primary-700 transition-colors shadow-md hover:shadow-lg">Book Now</a>
              </div>
            </div>
          </div>

          <!-- Featured Service 3: Lash Lift & Brow Lamination -->
          <div class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all duration-300 border-2 border-primary-100 hover:border-primary-300 relative">
            <div class="absolute top-4 right-4 z-10">
              <span class="bg-rose-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">TRENDING</span>
            </div>
            <div class="relative h-56 overflow-hidden">
              <img src="https://images.pexels.com/photos/5178001/pexels-photo-5178001.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Professional brow and lash lamination treatment" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
            </div>
            <div class="p-8">
              <h3 class="text-2xl font-bold font-serif text-neutral-900 mb-3">Lash Lift & Brow Lamination</h3>
              <p class="text-neutral-600 mb-4">
                Professional eyebrow and lash lift treatment that straightens and sets hairs into a lifted, defined shape for 6-8 weeks. Great for natural-looking enhancement and low-maintenance beauty.
              </p>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-3xl font-bold text-primary-600">$72</p>
