---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bliss Dermacare - Professional Aesthetician Services">
  <!-- Hero Section -->
  <section class="bg-[#f6f1eb] py-12 md:py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="grid items-center gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:gap-16">
        <div class="order-2 lg:order-1">
          <span class="mb-4 block text-xs font-semibold uppercase tracking-[0.24em] text-primary-600">Tampa, Florida</span>
          <h1 class="mb-6 max-w-3xl text-4xl font-serif leading-tight text-neutral-900 md:text-5xl lg:text-6xl">
            Clinical skincare with a softer, more personal approach.
          </h1>
          <p class="mb-8 max-w-2xl text-lg leading-relaxed text-neutral-600 md:text-xl">
            Bliss Dermacare offers customized facials and skin-focused treatments designed to restore clarity, calm, and confidence without the rushed feel of a typical medspa visit.
          </p>
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
            <a href="/book/"
               class="group inline-flex items-center justify-center gap-2 bg-neutral-900 px-6 py-3 font-medium text-white transition-colors hover:bg-neutral-800 md:px-8 md:py-4">
              Book an Appointment
              <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            <a href="/services/" class="inline-flex items-center justify-center gap-2 font-medium text-primary-700 transition-colors hover:text-primary-800">
              View Services
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </a>
          </div>
          <a href="/memberships/" class="inline-flex items-center gap-2 text-sm text-neutral-500 hover:text-primary-600 transition-colors mt-1">
            <svg class="w-3.5 h-3.5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
            Or save monthly &mdash; member plans from <span class="font-semibold text-primary-600">$89/mo</span> &rarr;
          </a>
        </div>

        <div class="order-1 lg:order-2">
          <figure class="mx-auto max-w-md">
            <div class="overflow-hidden rounded-sm bg-[#e8ddd2] p-3 shadow-[0_24px_70px_rgba(38,31,24,0.10)]">
              <img
                src="/hero-blissdermacare.jpg"
                alt="Bliss Dermacare Aesthetician Services"
                class="block w-full h-auto"
                width="600"
                height="400"
                loading="eager"
              />
            </div>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- Booking Process -->
  <section class="py-14 bg-[#faf9f7]">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="max-w-3xl mb-10">
        <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-4 block">How Booking Works</span>
        <h2 class="text-4xl lg:text-5xl font-serif text-neutral-900 leading-[1.1] mb-4">Simple, direct, and easy to confirm.</h2>
        <p class="text-lg text-neutral-600 leading-relaxed">Choose the service you want, request a time that works for you, and receive a confirmed appointment after review. No third-party widget, no extra tabs, no confusion.</p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-primary-100 text-primary-700 font-semibold">1</div>
          <h3 class="mb-2 text-xl font-serif text-neutral-900">Browse & save services</h3>
          <p class="text-neutral-600">Explore our services, click <strong class="font-semibold text-neutral-800">Add</strong> on any treatment you want, and view your saved list anytime using the calendar icon in the menu.</p>
        </div>
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-primary-100 text-primary-700 font-semibold">2</div>
          <h3 class="mb-2 text-xl font-serif text-neutral-900">Choose a time slot</h3>
          <p class="text-neutral-600">Select your preferred day and time slot from the booking page. Your saved services are pre-filled automatically.</p>
        </div>
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-primary-100 text-primary-700 font-semibold">3</div>
          <h3 class="mb-2 text-xl font-serif text-neutral-900">Receive confirmation</h3>
          <p class="text-neutral-600">Bliss Dermacare follows up promptly to confirm your timeslot and any pre-appointment details.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="py-14 bg-white">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="flex items-end justify-between mb-10">
        <div>
          <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-3 block">What We Offer</span>
          <h2 class="text-4xl font-serif text-neutral-900">Popular treatments.</h2>
        </div>
        <a href="/services/" class="hidden sm:inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">
          View all services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="group rounded-2xl overflow-hidden border border-neutral-100 hover:border-primary-200 hover:shadow-lg transition-all duration-300">
          <div class="h-48 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=600&h=400&fit=crop&q=80" alt="Signature Radiance Facial" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-serif text-neutral-900 mb-2">Signature Radiance Facial</h3>
            <p class="text-neutral-500 text-sm mb-4">Deep cleansing, exfoliation, extractions & custom mask. Tailored to your skin every visit.</p>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-bold text-primary-600">$99</span>
              <a href="/book/" data-service-id="signature-radiance-facial" class="text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">Book &rarr;</a>
            </div>
          </div>
        </div>
        <div class="group rounded-2xl overflow-hidden border border-neutral-100 hover:border-primary-200 hover:shadow-lg transition-all duration-300">
          <div class="h-48 overflow-hidden">
            <img src="https://images.pexels.com/photos/29648626/pexels-photo-29648626.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Vampire Facial PRP" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-serif text-neutral-900 mb-2">Vampire Facial (PRP)</h3>
            <p class="text-neutral-500 text-sm mb-4">Advanced PRP + microneedling for fine lines, scars & overall skin texture improvement.</p>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-bold text-primary-600">$380</span>
              <a href="/book/" data-service-id="vampire-facial-prp" class="text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">Book &rarr;</a>
            </div>
          </div>
        </div>
        <div class="group rounded-2xl overflow-hidden border border-neutral-100 hover:border-primary-200 hover:shadow-lg transition-all duration-300">
          <div class="h-48 overflow-hidden">
            <img src="https://images.pexels.com/photos/5178001/pexels-photo-5178001.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Lash Lift & Brow Lamination" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-serif text-neutral-900 mb-2">Lash Lift & Brow Lamination</h3>
            <p class="text-neutral-500 text-sm mb-4">Define and lift your natural brows and lashes — no extensions required. Lasts 6–8 weeks.</p>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-bold text-primary-600">$79</span>
              <a href="/book/" data-service-id="lash-lift-brow-lamination" class="text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">Book &rarr;</a>
            </div>
          </div>
        </div>
      </div>
      <div class="mt-8 text-center sm:hidden">
        <a href="/services/" class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">
          View all services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ✨ NEW: Spray Tan Spotlight -->
  <section class="py-14 bg-gradient-to-br from-amber-50 via-[#fdf6ec] to-rose-50">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-flex items-center gap-2 bg-amber-100 text-amber-700 text-xs font-bold uppercase tracking-[0.2em] px-4 py-1.5 rounded-full mb-5">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            Just Added &middot; Summer 2026
          </span>
          <h2 class="text-4xl lg:text-5xl font-serif text-neutral-900 leading-tight mb-4">Custom Airbrush<br/>Spray Tan</h2>
          <p class="text-lg text-neutral-600 mb-6 leading-relaxed">Look effortlessly sun-kissed all summer — without the UV damage. Our new professional airbrush spray tan is customized to your skin tone for a flawless, streak-free bronze that develops beautifully in hours and lasts over a week.</p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-center gap-3 text-neutral-700"><div class="w-6 h-6 bg-amber-100 rounded-full flex items-center justify-center shrink-0"><svg class="w-3.5 h-3.5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></div>Custom shade matching — light, medium, dark &amp; ultra dark</li>
            <li class="flex items-center gap-3 text-neutral-700"><div class="w-6 h-6 bg-amber-100 rounded-full flex items-center justify-center shrink-0"><svg class="w-3.5 h-3.5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></div>Vegan, paraben-free DHA — no orange cast, no streaks</li>
            <li class="flex items-center gap-3 text-neutral-700"><div class="w-6 h-6 bg-amber-100 rounded-full flex items-center justify-center shrink-0"><svg class="w-3.5 h-3.5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></div>Results last 7–10 days with proper aftercare</li>
            <li class="flex items-center gap-3 text-neutral-700"><div class="w-6 h-6 bg-amber-100 rounded-full flex items-center justify-center shrink-0"><svg class="w-3.5 h-3.5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></div>Also available as the <strong class="text-neutral-900">Bronze &amp; Bare Glow</strong> package with body waxing</li>
          </ul>
          <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
            <div class="bg-white rounded-xl px-5 py-3 border border-amber-200 shadow-sm">
              <p class="text-2xl font-bold text-neutral-900">$65</p>
              <p class="text-xs text-neutral-500">30–45 min &middot; individual service</p>
            </div>
            <a href="/book/" data-service-id="spray-tan" class="inline-flex items-center gap-2 bg-amber-500 text-white px-7 py-3.5 rounded-full font-semibold hover:bg-amber-600 transition-colors shadow-md hover:shadow-lg">
              Book Spray Tan
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="/services/" class="text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">See all services &rarr;</a>
          </div>
        </div>
        <div class="relative">
          <div class="absolute -top-6 -right-6 w-24 h-24 bg-amber-200 rounded-full opacity-50 blur-2xl"></div>
          <div class="absolute -bottom-8 -left-8 w-36 h-36 bg-rose-200 rounded-full opacity-30 blur-3xl"></div>
          <figure class="relative rounded-2xl overflow-hidden shadow-2xl border-2 border-amber-100">
            <img src="/images/spray-tan-service.jpg" alt="Custom Airbrush Spray Tan at Bliss Dermacare — Sun-kissed glow without UV" class="w-full h-auto" loading="lazy" />
          </figure>
          <div class="absolute bottom-4 left-4 right-4 bg-white/95 backdrop-blur-sm rounded-xl p-4 shadow-lg border border-amber-100">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-amber-500 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold text-neutral-900">Newest service — Summer 2026</p>
                <p class="text-xs text-neutral-500 truncate">Also available: Bronze &amp; Bare Glow Package ($110 &mdash; save $20)</p>
              </div>
              <a href="/services/" class="ml-auto text-xs font-semibold text-amber-600 hover:text-amber-700 transition-colors whitespace-nowrap shrink-0">View &rarr;</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- New Service Categories: Advanced Treatments & Semipermanent Makeup -->
  <section class="py-14 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="flex items-end justify-between mb-8">
        <div>
          <span class="inline-flex items-center gap-2 bg-amber-100 text-amber-700 text-xs font-bold uppercase tracking-[0.2em] px-4 py-1.5 rounded-full mb-4">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707"/></svg>
            New Service Categories
          </span>
          <h2 class="text-4xl font-serif text-neutral-900">Advanced Treatments &amp; Semipermanent Makeup.</h2>
          <p class="text-neutral-500 mt-2 max-w-xl">Two new service lines — medical-grade aesthetic procedures and precision permanent makeup, now available at Bliss Dermacare.</p>
        </div>
        <a href="/services/" class="hidden sm:inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors shrink-0 ml-6">See all &rarr;</a>
      </div>
      <div class="grid md:grid-cols-2 gap-6">

        <a href="/services/advanced-treatments/" class="group block rounded-2xl overflow-hidden border-2 border-primary-100 hover:border-primary-300 hover:shadow-xl transition-all relative">
          <div class="h-56 overflow-hidden relative">
            <img src="/images/collagen-induction-therapy.jpg" alt="Advanced Treatments — PRP, Lip Filler, Injectables at Bliss Dermacare" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-neutral-900/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
              <h3 class="text-2xl font-serif font-bold mb-1">Advanced Treatments</h3>
              <p class="text-sm text-neutral-300 mb-3">PRP &middot; Lip Filler &middot; ED Injectables &middot; Collagen Induction &middot; Weight Loss Program</p>
              <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-amber-300 group-hover:text-amber-200 transition-colors">
                Explore treatments
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </span>
            </div>
          </div>
        </a>

        <a href="/services/semipermanent-makeup/" class="group block rounded-2xl overflow-hidden border-2 border-primary-100 hover:border-primary-300 hover:shadow-xl transition-all relative">
          <div class="h-56 overflow-hidden relative">
            <img src="/images/eyebrow-permanent-makeup.jpg" alt="Semipermanent Makeup — Brows, Lip Blush, Scalp Micropigmentation at Bliss Dermacare" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-neutral-900/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
              <h3 class="text-2xl font-serif font-bold mb-1">Semipermanent Makeup</h3>
              <p class="text-sm text-neutral-300 mb-3">Nano Brows &middot; Powder Brows &middot; Lip Blush &middot; Scalp Micropigmentation &middot; More</p>
              <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-amber-300 group-hover:text-amber-200 transition-colors">
                Explore treatments
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </span>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- New This Season -->
  <section class="py-14 bg-[#faf9f7] border-y border-neutral-100">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="flex items-end justify-between mb-8">
        <div>
          <span class="inline-flex items-center gap-2 bg-primary-100 text-primary-700 text-xs font-bold uppercase tracking-[0.18em] px-4 py-1.5 rounded-full mb-4">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707"/></svg>
            Summer 2026
          </span>
          <h2 class="text-4xl font-serif text-neutral-900">Advanced Treatments, Semipermanent Makeup, new facials &amp; seasonal packages.</h2>
          <p class="text-neutral-500 mt-2 max-w-lg">Two new treatment categories — Advanced Treatments and Semipermanent Makeup — plus enzyme facials, Dermaplane Glow, Smooth Canvas Facial, custom airbrush spray tan, and seasonal face &amp; body packages.</p>
        </div>
        <a href="/services/" class="hidden sm:inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors shrink-0 ml-6">
          See all &rarr;
        </a>
      </div>

      <!-- New Facials Row -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
        <div class="group bg-white rounded-2xl overflow-hidden border border-amber-200 hover:border-amber-400 hover:shadow-md transition-all relative">
          <div class="absolute top-2 right-2 z-10"><span class="text-[10px] font-bold bg-amber-500 text-white px-1.5 py-0.5 rounded-full">NEW</span></div>
          <div class="h-32 overflow-hidden"><img src="/images/smooth-canvas-facial.jpg" alt="Smooth Canvas Facial" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /></div>
          <div class="p-4">
            <p class="font-semibold text-sm text-neutral-900 leading-snug mb-1">Smooth Canvas Facial</p>
            <div class="flex items-center justify-between mt-2">
              <span class="font-bold text-primary-600">$89</span>
              <a href="/book/" data-service-id="smooth-canvas-facial" class="text-xs text-primary-600 hover:text-primary-700 font-medium transition-colors">Book &rarr;</a>
            </div>
          </div>
        </div>
        <div class="group bg-white rounded-2xl overflow-hidden border border-amber-200 hover:border-amber-400 hover:shadow-md transition-all relative">
          <div class="absolute top-2 right-2 z-10"><span class="text-[10px] font-bold bg-amber-500 text-white px-1.5 py-0.5 rounded-full">NEW</span></div>
          <div class="h-32 overflow-hidden"><img src="/images/dermaplane-glow-facial.jpg" alt="Dermaplane Glow Facial" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /></div>
          <div class="p-4">
            <p class="font-semibold text-sm text-neutral-900 leading-snug mb-1">Dermaplane Glow Facial</p>
            <div class="flex items-center justify-between mt-2">
              <span class="font-bold text-primary-600">$105</span>
              <a href="/book/" data-service-id="dermaplane-glow-facial" class="text-xs text-primary-600 hover:text-primary-700 font-medium transition-colors">Book &rarr;</a>
            </div>
