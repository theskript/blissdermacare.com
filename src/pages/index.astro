  <script>
    (async () => {
      function esc(s: string) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
      function safeUrl(u: string) { try { const x=new URL(u); return (x.protocol==='http:'||x.protocol==='https:') ? u : '#'; } catch{return '#';} }
      try {
        const res = await fetch('/.netlify/functions/get-partners?featured=true');
        if (!res.ok) return;
        const { records } = await res.json();
        if (!records || records.length === 0) return;
        const container = document.getElementById('partners-hp-cards')!;
        container.innerHTML = records.map((p: any) => {
          const logo = p.logo_url
            ? `<img src="${esc(p.logo_url)}" alt="${esc(p.name)}" class="max-h-8 max-w-[100px] object-contain" loading="lazy" />`
            : `<div class="w-9 h-9 rounded-full bg-primary-100 flex items-center justify-center"><span class="text-primary-700 font-bold text-base">${esc(p.name.charAt(0))}</span></div>`;
          const badge = p.badge_text
            ? `<span class="text-[10px] font-bold bg-primary-100 text-primary-700 px-2 py-0.5 rounded-full mt-1 leading-tight text-center">${esc(p.badge_text)}</span>`
            : '';
          return `<a href="${esc(safeUrl(p.url))}" target="_blank" rel="noopener noreferrer sponsored"
            class="group relative flex flex-col items-center justify-center gap-2 bg-white rounded-2xl border border-neutral-200 hover:border-primary-300 hover:shadow-lg transition-all shrink-0 snap-start w-36 min-h-[108px] p-4">
            <div class="flex items-center justify-center h-9 w-full">${logo}</div>
            <p class="text-xs font-semibold text-neutral-800 text-center leading-snug">${esc(p.name)}</p>
            ${badge}
            <svg class="absolute top-2.5 right-2.5 w-3 h-3 text-neutral-300 group-hover:text-primary-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>`;
        }).join('');
        document.getElementById('partners-strip')!.classList.remove('hidden');
      } catch(_) { /* silent fail — section stays hidden */ }
    })();
  </script>

