---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bliss Dermacare - Professional Aesthetician Services">
  <!-- Hero Section -->
  <section class="bg-[#f6f1eb] py-12 md:py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="grid items-center gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:gap-16">
        <div class="order-2 lg:order-1">
          <span class="mb-4 block text-xs font-semibold uppercase tracking-[0.24em] text-primary-600">Pebble Creek, Florida</span>
          <h1 class="mb-6 max-w-3xl text-4xl font-serif leading-tight text-neutral-900 md:text-5xl lg:text-6xl">
            Clinical skincare with a softer, more personal approach.
          </h1>
          <p class="mb-8 max-w-2xl text-lg leading-relaxed text-neutral-600 md:text-xl">
            Bliss Dermacare offers customized facials and skin-focused treatments designed to restore clarity, calm, and confidence without the rushed feel of a typical medspa visit.
          </p>
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
            <a href="/book/"
               class="group inline-flex items-center justify-center gap-2 bg-neutral-900 px-6 py-3 font-medium text-white transition-colors hover:bg-neutral-800 md:px-8 md:py-4">
              Book an Appointment
              <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            <a href="/services/" class="inline-flex items-center justify-center gap-2 font-medium text-primary-700 transition-colors hover:text-primary-800">
              View Services
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <figure class="mx-auto max-w-md">
            <div class="overflow-hidden rounded-sm bg-[#e8ddd2] p-3 shadow-[0_24px_70px_rgba(38,31,24,0.10)]">
              <img
                src="/hero-blissdermacare.jpg"
                alt="Bliss Dermacare Aesthetician Services"
                class="block w-full h-auto"
                width="600"
                height="400"
                loading="eager"
              />
            </div>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Strip -->
  <section class="py-14 bg-[#faf9f7]">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-5">
        <a href="/book/" class="group rounded-2xl bg-neutral-900 text-white p-8 flex flex-col hover:bg-neutral-800 transition-colors">
          <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Book an Appointment</h3>
          <p class="text-neutral-400 text-sm mb-5 flex-1">Choose your service, pick a date and time, and submit your request. We'll confirm shortly.</p>
          <span class="text-sm font-medium flex items-center gap-2 group-hover:gap-3 transition-all">Request Booking <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
        </a>
        <a href="/consultation/" class="group rounded-2xl bg-primary-50 border border-primary-100 text-neutral-900 p-8 flex flex-col hover:bg-primary-100 transition-colors">
          <div class="w-10 h-10 bg-primary-200 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Free Consultation</h3>
          <p class="text-neutral-600 text-sm mb-5 flex-1">Not sure where to start? Tell us about your skin and we'll reach out with a personalized plan.</p>
          <span class="text-sm font-medium text-primary-600 flex items-center gap-2 group-hover:gap-3 transition-all">Get Started <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
        </a>
        <a href="/demo-model/" class="group rounded-2xl bg-white border border-neutral-200 text-neutral-900 p-8 flex flex-col hover:border-primary-300 hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-neutral-100 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Demo Model Program</h3>
          <p class="text-neutral-600 text-sm mb-5 flex-1">Get professional treatments at 50–80% off. Same products, same care — reduced pricing in exchange for your feedback.</p>
          <span class="text-sm font-medium text-neutral-700 flex items-center gap-2 group-hover:gap-3 transition-all">Apply Now <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
