---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bliss Dermacare - Professional Aesthetician Services">
  <!-- Hero Section -->
  <section class="bg-[#f6f1eb] py-12 md:py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="grid items-center gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:gap-16">
        <div class="order-2 lg:order-1">
          <span class="mb-4 block text-xs font-semibold uppercase tracking-[0.24em] text-primary-600">Pebble Creek, Florida</span>
          <h1 class="mb-6 max-w-3xl text-4xl font-serif leading-tight text-neutral-900 md:text-5xl lg:text-6xl">
            Clinical skincare with a softer, more personal approach.
          </h1>
          <p class="mb-8 max-w-2xl text-lg leading-relaxed text-neutral-600 md:text-xl">
            Bliss Dermacare offers customized facials and skin-focused treatments designed to restore clarity, calm, and confidence without the rushed feel of a typical medspa visit.
          </p>
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
            <a href="/book/"
               class="group inline-flex items-center justify-center gap-2 bg-neutral-900 px-6 py-3 font-medium text-white transition-colors hover:bg-neutral-800 md:px-8 md:py-4">
              Book an Appointment
              <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            <a href="/services/" class="inline-flex items-center justify-center gap-2 font-medium text-primary-700 transition-colors hover:text-primary-800">
              View Services
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <figure class="mx-auto max-w-md">
            <div class="overflow-hidden rounded-sm bg-[#e8ddd2] p-3 shadow-[0_24px_70px_rgba(38,31,24,0.10)]">
              <img
                src="/hero-blissdermacare.jpg"
                alt="Bliss Dermacare Aesthetician Services"
                class="block w-full h-auto"
                width="600"
                height="400"
                loading="eager"
              />
            </div>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- Booking Process -->
  <section class="py-14 bg-[#faf9f7]">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="max-w-3xl mb-10">
        <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-4 block">How Booking Works</span>
        <h2 class="text-4xl lg:text-5xl font-serif text-neutral-900 leading-[1.1] mb-4">Simple, direct, and easy to confirm.</h2>
        <p class="text-lg text-neutral-600 leading-relaxed">Choose the service you want, request a time that works for you, and receive a confirmed appointment after review. No third-party widget, no extra tabs, no confusion.</p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-primary-100 text-primary-700 font-semibold">1</div>
          <h3 class="mb-2 text-xl font-serif text-neutral-900">Browse & save services</h3>
          <p class="text-neutral-600">Explore our services, click <strong class="font-semibold text-neutral-800">Add</strong> on any treatment you want, and view your saved list anytime using the calendar icon in the menu.</p>
        </div>
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-primary-100 text-primary-700 font-semibold">2</div>
          <h3 class="mb-2 text-xl font-serif text-neutral-900">Choose a time slot</h3>
          <p class="text-neutral-600">Select your preferred day and time slot from the booking page. Your saved services are pre-filled automatically.</p>
        </div>
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-primary-100 text-primary-700 font-semibold">3</div>
          <h3 class="mb-2 text-xl font-serif text-neutral-900">Receive confirmation</h3>
          <p class="text-neutral-600">Bliss Dermacare follows up promptly to confirm your timeslot and any pre-appointment details.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="py-14 bg-white">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="flex items-end justify-between mb-10">
        <div>
          <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-3 block">What We Offer</span>
          <h2 class="text-4xl font-serif text-neutral-900">Popular treatments.</h2>
        </div>
        <a href="/services/" class="hidden sm:inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">
          View all services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="group rounded-2xl overflow-hidden border border-neutral-100 hover:border-primary-200 hover:shadow-lg transition-all duration-300">
          <div class="h-48 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=600&h=400&fit=crop&q=80" alt="Signature Radiance Facial" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-serif text-neutral-900 mb-2">Signature Radiance Facial</h3>
            <p class="text-neutral-500 text-sm mb-4">Deep cleansing, exfoliation, extractions & custom mask. Tailored to your skin every visit.</p>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-bold text-primary-600">$99</span>
              <a href="/book/" data-service-id="signature-radiance-facial" class="text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">Book &rarr;</a>
            </div>
          </div>
        </div>
        <div class="group rounded-2xl overflow-hidden border border-neutral-100 hover:border-primary-200 hover:shadow-lg transition-all duration-300">
          <div class="h-48 overflow-hidden">
            <img src="https://images.pexels.com/photos/29648626/pexels-photo-29648626.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Vampire Facial PRP" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-serif text-neutral-900 mb-2">Vampire Facial (PRP)</h3>
            <p class="text-neutral-500 text-sm mb-4">Advanced PRP + microneedling for fine lines, scars & overall skin texture improvement.</p>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-bold text-primary-600">$380</span>
              <a href="/book/" data-service-id="vampire-facial-prp" class="text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">Book &rarr;</a>
            </div>
          </div>
        </div>
        <div class="group rounded-2xl overflow-hidden border border-neutral-100 hover:border-primary-200 hover:shadow-lg transition-all duration-300">
          <div class="h-48 overflow-hidden">
            <img src="https://images.pexels.com/photos/5178001/pexels-photo-5178001.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Lash Lift & Brow Lamination" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-serif text-neutral-900 mb-2">Lash Lift & Brow Lamination</h3>
            <p class="text-neutral-500 text-sm mb-4">Define and lift your natural brows and lashes — no extensions required. Lasts 6–8 weeks.</p>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-bold text-primary-600">$79</span>
              <a href="/book/" data-service-id="lash-lift-brow-lamination" class="text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">Book &rarr;</a>
            </div>
          </div>
        </div>
      </div>
      <div class="mt-8 text-center sm:hidden">
        <a href="/services/" class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">
          View all services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- New This Season -->
  <section class="py-14 bg-[#faf9f7] border-y border-neutral-100">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="flex items-end justify-between mb-8">
        <div>
          <span class="inline-flex items-center gap-2 bg-primary-100 text-primary-700 text-xs font-bold uppercase tracking-[0.18em] px-4 py-1.5 rounded-full mb-4">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707"/></svg>
            Summer 2026
          </span>
          <h2 class="text-4xl font-serif text-neutral-900">New facials & seasonal packages.</h2>
          <p class="text-neutral-500 mt-2 max-w-lg">Four new enzyme facials just added, plus limited-time seasonal packages combining two full services in one visit.</p>
        </div>
        <a href="/services/" class="hidden sm:inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors shrink-0 ml-6">
          See all &rarr;
        </a>
      </div>

      <!-- New Facials Row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="group bg-white rounded-2xl overflow-hidden border border-neutral-200 hover:border-primary-300 hover:shadow-md transition-all">
          <div class="h-32 overflow-hidden"><img src="/images/pumpkin-enzyme-facial.jpg" alt="Pumpkin Enzyme Facial" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /></div>
          <div class="p-4">
            <p class="font-semibold text-sm text-neutral-900 leading-snug mb-1">Pumpkin Enzyme Facial</p>
            <div class="flex items-center justify-between mt-2">
              <span class="font-bold text-primary-600">$85</span>
              <a href="/book/" data-service-id="pumpkin-enzyme-facial" class="text-xs text-primary-600 hover:text-primary-700 font-medium transition-colors">Book →</a>
            </div>
          </div>
        </div>
        <div class="group bg-white rounded-2xl overflow-hidden border border-neutral-200 hover:border-primary-300 hover:shadow-md transition-all">
          <div class="h-32 overflow-hidden"><img src="/images/chlorophyll-skin-tightening-facial.jpg" alt="Chlorophyll Skin Tightening Facial" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /></div>
          <div class="p-4">
            <p class="font-semibold text-sm text-neutral-900 leading-snug mb-1">Chlorophyll Skin Tightening</p>
            <div class="flex items-center justify-between mt-2">
              <span class="font-bold text-primary-600">$105</span>
              <a href="/book/" data-service-id="chlorophyll-skin-tightening-facial" class="text-xs text-primary-600 hover:text-primary-700 font-medium transition-colors">Book →</a>
            </div>
          </div>
        </div>
        <div class="group bg-white rounded-2xl overflow-hidden border border-neutral-200 hover:border-primary-300 hover:shadow-md transition-all">
          <div class="h-32 overflow-hidden"><img src="/images/pineapple-enzyme-facial.jpg" alt="Pineapple Enzyme Facial" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /></div>
          <div class="p-4">
            <p class="font-semibold text-sm text-neutral-900 leading-snug mb-1">Pineapple Enzyme Facial</p>
            <div class="flex items-center justify-between mt-2">
              <span class="font-bold text-primary-600">$88</span>
              <a href="/book/" data-service-id="pineapple-enzyme-facial" class="text-xs text-primary-600 hover:text-primary-700 font-medium transition-colors">Book →</a>
            </div>
          </div>
        </div>
        <div class="group bg-white rounded-2xl overflow-hidden border border-neutral-200 hover:border-primary-300 hover:shadow-md transition-all">
          <div class="h-32 overflow-hidden"><img src="/images/skin-recovery-facial.jpg" alt="Skin Recovery Facial" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /></div>
          <div class="p-4">
            <p class="font-semibold text-sm text-neutral-900 leading-snug mb-1">Skin Recovery Facial</p>
            <div class="flex items-center justify-between mt-2">
              <span class="font-bold text-primary-600">$92</span>
              <a href="/book/" data-service-id="skin-recovery-facial" class="text-xs text-primary-600 hover:text-primary-700 font-medium transition-colors">Book →</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Seasonal Packages Strip -->
      <div class="bg-gradient-to-r from-rose-50 via-primary-50 to-amber-50 rounded-2xl border border-primary-100 p-6">
        <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-5">
          <div class="flex-1">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-primary-600 mb-1">Limited Seasonal Availability</p>
            <h3 class="text-xl font-serif text-neutral-900">Summer face & body packages — two services, one visit.</h3>
          </div>
          <a href="/services/" class="shrink-0 text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors flex items-center gap-1">
            View all packages <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
          <div class="bg-white rounded-xl p-4 border border-primary-100">
            <p class="font-semibold text-sm text-neutral-900 mb-0.5">Lash & Body Smooth</p>
            <p class="text-xs text-neutral-500 mb-2">Lash Extensions + Body Waxing</p>
            <div class="flex items-center justify-between">
              <div><span class="font-bold text-primary-600">$185</span> <span class="text-xs text-neutral-400 line-through">$212</span></div>
              <a href="/book/" data-service-id="lash-body-smooth" class="text-xs font-semibold text-primary-600 hover:text-primary-700 transition-colors block">Book →</a>
            </div>
          </div>
          <div class="bg-white rounded-xl p-4 border border-primary-100">
            <p class="font-semibold text-sm text-neutral-900 mb-0.5">Brow, Lash & Wax Ritual</p>
            <p class="text-xs text-neutral-500 mb-2">Lash Lift + Brow Lam + Waxing</p>
            <div class="flex items-center justify-between">
              <div><span class="font-bold text-primary-600">$115</span> <span class="text-xs text-neutral-400 line-through">$131</span></div>
              <a href="/book/" data-service-id="brow-lash-wax-ritual" class="text-xs font-semibold text-primary-600 hover:text-primary-700 transition-colors block">Book →</a>
            </div>
          </div>
          <div class="bg-white rounded-xl p-4 border border-primary-100">
            <p class="font-semibold text-sm text-neutral-900 mb-0.5">Glow & Smooth Escape</p>
            <p class="text-xs text-neutral-500 mb-2">Dermaplane Facial + Body Waxing</p>
            <div class="flex items-center justify-between">
              <div><span class="font-bold text-primary-600">$135</span> <span class="text-xs text-neutral-400 line-through">$158</span></div>
              <a href="/book/" data-service-id="glow-smooth-escape" class="text-xs font-semibold text-primary-600 hover:text-primary-700 transition-colors block">Book →</a>
            </div>
          </div>
          <div class="bg-white rounded-xl p-4 border border-primary-100">
            <p class="font-semibold text-sm text-neutral-900 mb-0.5">Mix & Match Escape</p>
            <p class="text-xs text-neutral-500 mb-2">Waxing + Your Choice of Service</p>
            <div class="flex items-center justify-between">
              <div><span class="font-bold text-primary-600">From $129</span></div>
              <a href="/book/" data-service-id="mix-match-package" class="text-xs font-semibold text-primary-600 hover:text-primary-700 transition-colors block">Book →</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Strip -->
  <section class="py-14 bg-[#faf9f7]">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-5">
        <a href="/book/" class="group rounded-2xl bg-neutral-900 text-white p-8 flex flex-col hover:bg-neutral-800 transition-colors">
          <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Book an Appointment</h3>
          <p class="text-neutral-400 text-sm mb-5 flex-1">Choose your service, pick a date and time, and submit your request. We'll confirm shortly.</p>
          <span class="text-sm font-medium flex items-center gap-2 group-hover:gap-3 transition-all">Request Booking <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
        </a>
        <a href="/consultation/" class="group rounded-2xl bg-primary-50 border border-primary-100 text-neutral-900 p-8 flex flex-col hover:bg-primary-100 transition-colors">
          <div class="w-10 h-10 bg-primary-200 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Free Consultation</h3>
          <p class="text-neutral-600 text-sm mb-5 flex-1">Not sure where to start? Tell us about your skin and we'll reach out with a personalized plan.</p>
          <span class="text-sm font-medium text-primary-600 flex items-center gap-2 group-hover:gap-3 transition-all">Get Started <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
        </a>
        <a href="/demo-model/" class="group rounded-2xl bg-white border border-neutral-200 text-neutral-900 p-8 flex flex-col hover:border-primary-300 hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-neutral-100 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Demo Model Program</h3>
          <p class="text-neutral-600 text-sm mb-5 flex-1">Get professional treatments at 50–80% off. Same products, same care — reduced pricing in exchange for your feedback.</p>
          <span class="text-sm font-medium text-neutral-700 flex items-center gap-2 group-hover:gap-3 transition-all">Apply Now <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
