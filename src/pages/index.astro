---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bliss Dermacare - Professional Aesthetician Services">
  <!-- Upcoming Events Banner -->
  <section class="bg-gradient-to-r from-primary-600 via-primary-500 to-primary-600 text-white py-3 md:py-4">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-center gap-2 md:gap-6 text-center">
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-6 h-6 bg-white/20 rounded-full">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </span>
          <span class="font-semibold text-sm md:text-base">Upcoming Events</span>
        </div>
        <div class="hidden md:block w-px h-6 bg-white/30"></div>
        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-1 text-sm md:text-base">
          <span class="flex items-center gap-1.5">
            <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
            <strong>March 15:</strong> Spring Glow Facial Event
          </span>
          <span class="hidden sm:inline text-white/50">|</span>
          <span class="flex items-center gap-1.5">
            <span class="w-2 h-2 bg-yellow-400 rounded-full"></span>
            <strong>March 22:</strong> Free Skin Consultation Day
          </span>
        </div>
        <a href="#consultation" class="mt-2 md:mt-0 inline-flex items-center text-sm font-medium bg-white/20 hover:bg-white/30 px-4 py-1.5 rounded-full transition-colors">
          Reserve Your Spot
          <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Hero Section - Luxury Editorial (inspired by Augustinus Bader, Aesop) -->
  <section class="relative min-h-[100svh] flex items-end bg-neutral-900 overflow-hidden">
    <!-- Background Image with Ken Burns Effect -->
    <div class="absolute inset-0">
      <img 
        src="/hero-blissdermacare.jpg" 
        alt="Bliss Dermacare" 
        class="w-full h-full object-cover scale-105 animate-slow-zoom"
        loading="eager" 
      />
      <div class="absolute inset-0 bg-gradient-to-t from-neutral-900 via-neutral-900/40 to-neutral-900/20"></div>
    </div>
    
    <!-- Content -->
    <div class="relative z-10 w-full">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 pb-16 lg:pb-24">
        <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-end">
          
          <!-- Main Content -->
          <div class="lg:col-span-7 xl:col-span-6">
            <!-- Eyebrow -->
            <div class="flex items-center gap-4 mb-6">
              <span class="w-12 h-px bg-primary-400"></span>
              <span class="text-primary-300 uppercase tracking-[0.3em] text-xs font-medium">Wesley Chapel, Florida</span>
            </div>
            
            <!-- Headline -->
            <h1 class="text-white mb-6">
              <span class="block text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-serif font-light leading-[0.9] tracking-tight">
                Your Skin,
              </span>
              <span class="block text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-serif italic font-light leading-[0.9] tracking-tight text-primary-300">
                Elevated.
              </span>
            </h1>
            
            <!-- Subtext -->
            <p class="text-white/70 text-lg lg:text-xl max-w-lg leading-relaxed mb-8 font-light">
              Bespoke facial artistry by Iateaka Lizardo. Where clinical precision meets the transformative power of touch.
            </p>
            
            <!-- CTA Row -->
            <div class="flex flex-wrap items-center gap-4">
              <a href="https://blissdermacare.setmore.com/" target="_blank" rel="noopener noreferrer" 
                 class="group inline-flex items-center gap-3 bg-white text-neutral-900 px-8 py-4 font-medium tracking-wide hover:bg-primary-50 transition-colors">
                Book Your Experience
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
              <a href="#services" class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors font-medium">
                Explore Treatments
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </a>
            </div>
          </div>
          
          <!-- Stats Card -->
          <div class="lg:col-span-5 xl:col-span-4 xl:col-start-9">
            <div class="bg-white/10 backdrop-blur-md border border-white/20 p-8 lg:p-10">
              <div class="grid grid-cols-3 gap-6 text-center">
                <div>
                  <div class="text-3xl lg:text-4xl font-serif text-white mb-1">7+</div>
                  <div class="text-xs text-white/60 uppercase tracking-wider">Years</div>
                </div>
                <div class="border-x border-white/20">
                  <div class="text-3xl lg:text-4xl font-serif text-white mb-1">500+</div>
                  <div class="text-xs text-white/60 uppercase tracking-wider">Clients</div>
                </div>
                <div>
                  <div class="flex items-center justify-center gap-1 text-3xl lg:text-4xl font-serif text-white mb-1">
                    5.0
                    <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  </div>
                  <div class="text-xs text-white/60 uppercase tracking-wider">Rating</div>
                </div>
              </div>
              <div class="mt-6 pt-6 border-t border-white/20">
                <p class="text-sm text-white/70 text-center">Florida State Licensed Aesthetician</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Scroll Indicator -->
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
        <div class="w-px h-12 bg-gradient-to-b from-white/50 to-transparent animate-pulse"></div>
      </div>
    </div>
  </section>
  
  <style>
    @keyframes slow-zoom {
      0% { transform: scale(1.05); }
      100% { transform: scale(1.15); }
    }
    .animate-slow-zoom {
      animation: slow-zoom 20s ease-out forwards;
    }
  </style>

  <!-- The Experience Section (replaces How It Works) -->
  <section class="py-20 lg:py-28 bg-[#faf9f7]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      
      <!-- Section Header -->
      <div class="max-w-3xl mb-16 lg:mb-20">
        <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-4 block">The Journey</span>
        <h2 class="text-4xl lg:text-5xl xl:text-6xl font-serif text-neutral-900 leading-[1.1] mb-6">
          A ritual designed<br class="hidden sm:block" />
          <span class="italic font-light">around you.</span>
        </h2>
        <p class="text-lg text-neutral-600 leading-relaxed">
          Every session is a personalized journey toward radiant skin. No rushed appointments, no cookie-cutter treatments—just intentional care tailored to your unique needs.
        </p>
      </div>
      
      <!-- Journey Steps -->
      <div class="grid lg:grid-cols-3 gap-8 lg:gap-4">
        
        <!-- Step 1 -->
        <div class="group relative">
          <div class="relative overflow-hidden mb-6">
            <img 
              src="https://images.pexels.com/photos/5938558/pexels-photo-5938558.jpeg?auto=compress&cs=tinysrgb&w=600" 
              alt="Book your appointment online" 
              class="w-full aspect-[4/5] object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-neutral-900/20 group-hover:bg-transparent transition-colors duration-500"></div>
            <div class="absolute top-6 left-6">
              <span class="inline-flex items-center justify-center w-12 h-12 bg-white text-neutral-900 font-serif text-xl">01</span>
            </div>
          </div>
          <h3 class="text-2xl font-serif text-neutral-900 mb-3">Reserve Your Time</h3>
          <p class="text-neutral-600 leading-relaxed">
            Browse treatments and book online in seconds. Select a time that honors your schedule—we believe self-care shouldn't feel like a chore.
          </p>
          <div class="mt-4">
            <a href="https://blissdermacare.setmore.com/" class="inline-flex items-center gap-2 text-primary-600 font-medium group-hover:gap-3 transition-all">
              Book Now
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
        
        <!-- Step 2 -->
        <div class="group relative lg:mt-12">
          <div class="relative overflow-hidden mb-6">
            <img 
              src="https://images.pexels.com/photos/3985329/pexels-photo-3985329.jpeg?auto=compress&cs=tinysrgb&w=600" 
              alt="Personalized skin consultation" 
              class="w-full aspect-[4/5] object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-neutral-900/20 group-hover:bg-transparent transition-colors duration-500"></div>
            <div class="absolute top-6 left-6">
              <span class="inline-flex items-center justify-center w-12 h-12 bg-white text-neutral-900 font-serif text-xl">02</span>
            </div>
          </div>
          <h3 class="text-2xl font-serif text-neutral-900 mb-3">The Consultation</h3>
          <p class="text-neutral-600 leading-relaxed">
            We begin with a thorough skin analysis. Understanding your concerns, lifestyle, and goals allows us to craft a treatment uniquely yours.
          </p>
        </div>
        
        <!-- Step 3 -->
        <div class="group relative lg:mt-24">
          <div class="relative overflow-hidden mb-6">
            <img 
              src="https://images.pexels.com/photos/3997381/pexels-photo-3997381.jpeg?auto=compress&cs=tinysrgb&w=600" 
              alt="Leave glowing and radiant" 
              class="w-full aspect-[4/5] object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-neutral-900/20 group-hover:bg-transparent transition-colors duration-500"></div>
            <div class="absolute top-6 left-6">
              <span class="inline-flex items-center justify-center w-12 h-12 bg-white text-neutral-900 font-serif text-xl">03</span>
            </div>
          </div>
          <h3 class="text-2xl font-serif text-neutral-900 mb-3">Glow Forward</h3>
          <p class="text-neutral-600 leading-relaxed">
            Leave with luminous skin and a curated at-home protocol. We're invested in your long-term radiance, not just the moment.
          </p>
        </div>
        
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-12 md:py-16 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-8">
        <span class="text-primary-600 font-semibold text-sm uppercase tracking-wider">Treatments</span>
        <h2 class="text-4xl md:text-5xl font-bold font-serif text-neutral-900 mt-2 mb-4">Our Services</h2>
        <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
          Expert treatments designed to address your specific concerns and enhance your natural radiance.
        </p>
      </div>

      <!-- Featured Services Section -->
      <div class="mb-10">
        <div class="flex items-center justify-center gap-3 mb-8">
          <div class="h-px bg-gradient-to-r from-transparent to-primary-200 flex-1 max-w-[100px]"></div>
          <span class="inline-flex items-center gap-2 bg-primary-50 text-primary-700 px-4 py-2 rounded-full text-sm font-semibold">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            Most Popular
          </span>
          <div class="h-px bg-gradient-to-l from-transparent to-primary-200 flex-1 max-w-[100px]"></div>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <!-- Featured Service 1: Signature Radiance Facial -->
          <div class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all duration-300 border-2 border-primary-100 hover:border-primary-300 relative">
            <div class="absolute top-4 right-4 z-10">
              <span class="bg-primary-600 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">BESTSELLER</span>
            </div>
            <div class="relative h-56 overflow-hidden">
              <img src="https://images.unsplash.com/photo-1519415387722-a1c3bbef716c?w=600&h=400&fit=crop&q=80" alt="Classic Facial Treatment with professional aesthetician" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
            </div>
            <div class="p-8">
              <h3 class="text-2xl font-bold font-serif text-neutral-900 mb-3">Signature Radiance Facial</h3>
              <p class="text-neutral-600 mb-4">
                Personalized deep cleansing treatment with double cleanse, exfoliation, steam therapy, professional extractions, custom mask, serums, and therapeutic facial massage. Perfect for all skin types.
              </p>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-3xl font-bold text-primary-600">$120</p>
                  <p class="text-sm text-neutral-500">60 minutes</p>
                </div>
                <a href="#booking" class="px-5 py-2.5 bg-primary-600 text-white text-sm font-semibold rounded-full hover:bg-primary-700 transition-colors shadow-md hover:shadow-lg">Book Now</a>
              </div>
            </div>
          </div>

          <!-- Featured Service 2: Vampire Facial (PRP) -->
          <div class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all duration-300 border-2 border-primary-100 hover:border-primary-300 relative">
            <div class="absolute top-4 right-4 z-10">
              <span class="bg-amber-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">PREMIUM</span>
            </div>
            <div class="relative h-56 overflow-hidden">
              <img src="https://images.pexels.com/photos/29648626/pexels-photo-29648626.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Professional PRP Vampire Facial microneedling treatment" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
            </div>
            <div class="p-8">
              <h3 class="text-2xl font-bold font-serif text-neutral-900 mb-3">Vampire Facial (PRP)</h3>
              <p class="text-neutral-600 mb-4">
                Advanced platelet-rich plasma facial combining microneedling with your body's own growth factors. Reduces fine lines, acne scars, hyperpigmentation, and improves overall skin texture.
              </p>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-3xl font-bold text-primary-600">$450</p>
                  <p class="text-sm text-neutral-500">75 min | Series of 3</p>
                </div>
                <a href="#booking" class="px-5 py-2.5 bg-primary-600 text-white text-sm font-semibold rounded-full hover:bg-primary-700 transition-colors shadow-md hover:shadow-lg">Book Now</a>
              </div>
            </div>
          </div>

          <!-- Featured Service 3: Lash Lift & Brow Lamination -->
          <div class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all duration-300 border-2 border-primary-100 hover:border-primary-300 relative">
            <div class="absolute top-4 right-4 z-10">
              <span class="bg-rose-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">TRENDING</span>
            </div>
            <div class="relative h-56 overflow-hidden">
              <img src="https://images.pexels.com/photos/5178001/pexels-photo-5178001.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Professional brow and lash lamination treatment" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
            </div>
            <div class="p-8">
              <h3 class="text-2xl font-bold font-serif text-neutral-900 mb-3">Lash Lift & Brow Lamination</h3>
              <p class="text-neutral-600 mb-4">
                Professional eyebrow and lash lift treatment that straightens and sets hairs into a lifted, defined shape for 6-8 weeks. Great for natural-looking enhancement and low-maintenance beauty.
              </p>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-3xl font-bold text-primary-600">$85</p>
                  <p class="text-sm text-neutral-500">60 minutes</p>
                </div>
                <a href="#booking" class="px-5 py-2.5 bg-primary-600 text-white text-sm font-semibold rounded-full hover:bg-primary-700 transition-colors shadow-md hover:shadow-lg">Book Now</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- More Services Section -->
      <div>
        <div class="flex items-center justify-center gap-3 mb-8">
          <div class="h-px bg-neutral-200 flex-1 max-w-[100px]"></div>
          <span class="text-neutral-500 text-sm font-medium uppercase tracking-wider">More Treatments</span>
          <div class="h-px bg-neutral-200 flex-1 max-w-[100px]"></div>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">

          <!-- Compact Service Card: Age-Defying Renewal -->
          <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all duration-300 border border-neutral-200">
            <div class="relative h-32 overflow-hidden">
              <img src="https://images.unsplash.com/photo-1646457417455-77a66a9fcf34?w=400&h=300&fit=crop&q=80" alt="Age-Defying Renewal treatment" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            </div>
            <div class="p-4">
              <h3 class="text-lg font-bold text-neutral-900 mb-1">Age-Defying Renewal</h3>
              <p class="text-neutral-500 text-sm mb-3 line-clamp-2">Advanced rejuvenation with peptide serums, LED therapy & firming mask.</p>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-xl font-bold text-primary-600">$175</p>
                  <p class="text-xs text-neutral-400">75 min</p>
                </div>
                <a href="#booking" class="px-3 py-1.5 bg-primary-600 text-white text-xs font-medium rounded-full hover:bg-primary-700 transition-colors">Book</a>
              </div>
            </div>
          </div>

          <!-- Compact Service Card: Brightening Peel -->
          <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all duration-300 border border-neutral-200">
            <div class="relative h-32 overflow-hidden">
              <img src="https://images.pexels.com/photos/5069454/pexels-photo-5069454.jpeg?auto=compress&cs=tinysrgb&w=400" alt="Brightening Resurfacing Peel" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            </div>
            <div class="p-4">
              <h3 class="text-lg font-bold text-neutral-900 mb-1">Brightening Peel</h3>
              <p class="text-neutral-500 text-sm mb-3 line-clamp-2">Medical-grade chemical exfoliation for texture & hyperpigmentation.</p>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-xl font-bold text-primary-600">$150</p>
                  <p class="text-xs text-neutral-400">45 min</p>
                </div>
                <a href="#booking" class="px-3 py-1.5 bg-primary-600 text-white text-xs font-medium rounded-full hover:bg-primary-700 transition-colors">Book</a>
              </div>
            </div>
          </div>

          <!-- Compact Service Card: Diamond Glow -->
          <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all duration-300 border border-neutral-200">
            <div class="relative h-32 overflow-hidden">
              <img src="/images/diamond-glow.jpg" alt="Diamond Glow Exfoliation" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            </div>
            <div class="p-4">
              <h3 class="text-lg font-bold text-neutral-900 mb-1">Diamond Glow</h3>
              <p class="text-neutral-500 text-sm mb-3 line-clamp-2">Diamond-tip microdermabrasion for instant glow with no downtime.</p>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-xl font-bold text-primary-600">$135</p>
                  <p class="text-xs text-neutral-400">50 min</p>
                </div>
                <a href="#booking" class="px-3 py-1.5 bg-primary-600 text-white text-xs font-medium rounded-full hover:bg-primary-700 transition-colors">Book</a>
              </div>
            </div>
          </div>

          <!-- Compact Service Card: Clear Skin Treatment -->
          <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all duration-300 border border-neutral-200">
            <div class="relative h-32 overflow-hidden">
              <img src="https://images.pexels.com/photos/6476078/pexels-photo-6476078.jpeg?auto=compress&cs=tinysrgb&w=400" alt="Clear Skin Purifying Treatment" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            </div>
            <div class="p-4">
              <h3 class="text-lg font-bold text-neutral-900 mb-1">Clear Skin Treatment</h3>
              <p class="text-neutral-500 text-sm mb-3 line-clamp-2">Deep-pore cleansing with high-frequency & LED for acne-prone skin.</p>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-xl font-bold text-primary-600">$130</p>
                  <p class="text-xs text-neutral-400">75 min</p>
                </div>
                <a href="#booking" class="px-3 py-1.5 bg-primary-600 text-white text-xs font-medium rounded-full hover:bg-primary-700 transition-colors">Book</a>
