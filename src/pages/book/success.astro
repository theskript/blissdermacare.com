---
import Layout from '../../layouts/Layout.astro';
// Static site (output: 'static') — Astro.url.searchParams is empty at build
// time. All conditional rendering is handled client-side via inline scripts.
---

<Layout
  title="Booking Confirmed – Bliss Dermacare"
  description="Your booking has been received at Bliss Dermacare. We'll be in touch within 24 hours."
>

  <!--
    ① Synchronous inline script — runs before the browser paints anything.
       Sets data-pay-method on <html> so the CSS below hides the wrong
       sections instantly, with zero flash.
  -->
  <script is:inline>
    (function () {
      var ip = new URLSearchParams(location.search).get('payment') === 'in-person';
      document.documentElement.setAttribute('data-pay-method', ip ? 'in-person' : 'online');
    })();
  </script>

  <style is:inline>
    /* Applied before first paint — no flash of wrong content */
    [data-pay-method="online"]    .ip-only     { display: none !important; }
    [data-pay-method="in-person"] .online-only { display: none !important; }
    /* Fallback: if script hasn't run yet, hide ip-only by default */
    :not([data-pay-method]) .ip-only { display: none !important; }
  </style>

  <!-- ── HERO BAND ─────────────────────────────────────────────────── -->

  <section class="online-only py-14 border-b bg-emerald-50 border-emerald-100">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <div class="w-16 h-16 rounded-full bg-emerald-100 flex items-center justify-center mx-auto mb-5">
        <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <span class="text-emerald-700 text-xs font-bold uppercase tracking-[0.2em] mb-3 block">Payment Confirmed</span>
      <h1 class="text-4xl font-serif text-neutral-900 mb-3">You're all set.</h1>
      <p class="text-base text-neutral-600 max-w-md mx-auto">
        Payment received. We'll reach out within <strong>24 hours</strong> to confirm your appointment details and send everything you need before your visit.
      </p>
    </div>
  </section>

  <section class="ip-only py-14 border-b bg-amber-50 border-amber-100">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <div class="w-16 h-16 rounded-full bg-amber-100 flex items-center justify-center mx-auto mb-5">
        <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
        </svg>
      </div>
      <span class="text-amber-700 text-xs font-bold uppercase tracking-[0.2em] mb-3 block">Request Submitted</span>
      <h1 class="text-4xl font-serif text-neutral-900 mb-3">We've got your request.</h1>
      <p class="text-base text-neutral-600 max-w-md mx-auto">
        Your appointment request is in. We'll reach out within <strong>24 hours</strong> to confirm your date and time. Nothing is locked in until you hear from us.
      </p>
    </div>
  </section>

  <!-- ── DETAIL CARDS ──────────────────────────────────────────────── -->
  <section class="py-12 bg-white">
    <div class="max-w-2xl mx-auto px-6 space-y-4">

      <!-- ONLINE ONLY: payment received -->
      <div class="online-only rounded-2xl border-2 border-emerald-200 bg-emerald-50 p-5 flex gap-4">
        <div class="w-9 h-9 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
          <p class="font-semibold text-neutral-900 text-sm mb-1">Payment received</p>
          <p class="text-sm text-neutral-600 leading-relaxed">Your card has been charged and a receipt has been sent to your email. Keep it handy — it includes your booking reference.</p>
          <p class="mt-2 text-xs text-neutral-400 hidden" id="ref-display-line"></p>
        </div>
      </div>

      <!-- ONLINE ONLY: what happens next -->
      <div class="online-only rounded-2xl border border-neutral-200 bg-[#fafaf8] p-5">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-neutral-400 mb-4">What Happens Next</p>
        <ol class="space-y-4">
          <li class="flex gap-4">
            <div class="w-6 h-6 rounded-full bg-primary-600 text-white text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">1</div>
            <div>
              <p class="font-semibold text-neutral-900 text-sm">We confirm your booking</p>
              <p class="text-xs text-neutral-500 mt-0.5">Expect a confirmation from us by phone, text, or email within 24 hours — whichever you selected on the booking form.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="w-6 h-6 rounded-full bg-primary-600 text-white text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">2</div>
            <div>
              <p class="font-semibold text-neutral-900 text-sm">Reminders before your visit</p>
              <p class="text-xs text-neutral-500 mt-0.5">We'll remind you 24 hours before and again 2 hours before your appointment.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="w-6 h-6 rounded-full bg-primary-600 text-white text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">3</div>
            <div>
              <p class="font-semibold text-neutral-900 text-sm">Come in &amp; enjoy</p>
              <p class="text-xs text-neutral-500 mt-0.5">You're fully paid — just arrive and we'll handle the rest. No checkout at the end.</p>
            </div>
          </li>
        </ol>
      </div>

      <!-- ONLINE ONLY: studio location -->
      <div class="online-only rounded-2xl border border-neutral-200 p-5 flex gap-4">
        <div class="w-9 h-9 rounded-full bg-neutral-100 flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div>
          <p class="font-semibold text-neutral-900 text-sm mb-1">Studio location</p>
          <p class="text-sm text-neutral-600 leading-relaxed">Bliss Dermacare · Pebble Creek, FL 33544. The exact address is included in your confirmation message. We're a private studio — please don't arrive without a confirmed appointment.</p>
        </div>
      </div>

      <!-- IN-PERSON ONLY: appointment confirmed -->
      <div class="ip-only rounded-2xl border-2 border-emerald-200 bg-emerald-50 p-5 flex gap-4">
        <div class="w-9 h-9 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
          <p class="font-semibold text-neutral-900 text-sm mb-1">Your appointment is booked — we'll see you then.</p>
          <p class="text-sm text-neutral-600 leading-relaxed">Your slot is reserved. You'll receive a confirmation with the studio address and full details shortly. Just show up and we'll take care of everything — payment is settled at the end of your visit.</p>
        </div>
      </div>

      <!-- IN-PERSON ONLY: nothing was charged -->
      <div class="ip-only rounded-2xl border-2 border-amber-200 bg-amber-50 p-5 flex gap-4">
        <div class="w-9 h-9 rounded-full bg-amber-100 flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-amber-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
        </div>
        <div>
          <p class="font-semibold text-neutral-900 text-sm mb-1">Nothing was charged today</p>
          <p class="text-sm text-neutral-600 leading-relaxed">Payment is due at your appointment. We accept <strong>cash</strong>, <strong>Zelle</strong>, <strong>Venmo</strong>, and all major <strong>credit &amp; debit cards</strong> in person when you arrive.</p>
        </div>
      </div>

      <!-- IN-PERSON ONLY: what happens next -->
      <div class="ip-only rounded-2xl border border-neutral-200 bg-[#fafaf8] p-5">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-neutral-400 mb-4">What Happens Next</p>
        <ol class="space-y-4">
          <li class="flex gap-4">
            <div class="w-6 h-6 rounded-full bg-primary-600 text-white text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">1</div>
            <div>
              <p class="font-semibold text-neutral-900 text-sm">We review your request</p>
              <p class="text-xs text-neutral-500 mt-0.5">We'll check availability for your requested date and time within 24 hours.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="w-6 h-6 rounded-full bg-primary-600 text-white text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">2</div>
            <div>
              <p class="font-semibold text-neutral-900 text-sm">You'll receive a confirmation</p>
              <p class="text-xs text-neutral-500 mt-0.5">We'll confirm by phone, text, or email — whichever you selected — with your appointment details and the studio address.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="w-6 h-6 rounded-full bg-primary-600 text-white text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">3</div>
            <div>
              <p class="font-semibold text-neutral-900 text-sm">Reminders before your visit</p>
              <p class="text-xs text-neutral-500 mt-0.5">We'll send a reminder 24 hours before and again 2 hours before your appointment.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="w-6 h-6 rounded-full bg-primary-600 text-white text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">4</div>
            <div>
              <p class="font-semibold text-neutral-900 text-sm">Arrive &amp; pay in person</p>
              <p class="text-xs text-neutral-500 mt-0.5">Come in, get taken care of, and settle up at the end of your visit.</p>
            </div>
          </li>
        </ol>
      </div>

      <!-- SHARED: cancellation policy -->
      <div class="rounded-2xl border border-neutral-200 p-5 flex gap-4">
        <div class="w-9 h-9 rounded-full bg-neutral-100 flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
          <p class="font-semibold text-neutral-900 text-sm mb-1">Need to cancel or reschedule?</p>
          <p class="text-sm text-neutral-600 leading-relaxed">Please give us at least <strong>24 hours' notice</strong>. Late cancellations are subject to a 50% fee and no-shows are charged in full. Call or text <a href="tel:+16093660857" class="text-primary-600 font-medium">(609) 366-0857</a> to make any changes.</p>
        </div>
      </div>

      <!-- SHARED: community discount -->
      <div class="rounded-2xl border border-neutral-200 p-5 flex gap-4">
        <div class="w-9 h-9 rounded-full bg-neutral-100 flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
        </div>
        <div>
          <p class="font-semibold text-neutral-900 text-sm mb-1">Bringing a discount credential?</p>
          <p class="text-sm text-neutral-600 leading-relaxed">If you selected a community discount (first responder, teacher, senior, or student), bring a valid ID or credential to your appointment. Discounts are verified and applied at the visit.</p>
        </div>
      </div>

      <!-- SHARED: pre-service form -->
      <div class="rounded-2xl border-2 border-primary-100 bg-primary-50 p-5 flex gap-4">
        <div class="w-9 h-9 rounded-full bg-primary-100 flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <div class="flex-1">
          <p class="font-semibold text-neutral-900 text-sm mb-1">First time with us? Complete your pre-service form.</p>
          <p class="text-sm text-neutral-600 leading-relaxed mb-3">New clients should fill out our intake questionnaire before their visit. It takes about 2 minutes and helps us personalise your treatment and ensure your safety.</p>
          <a href="/pre-service-form/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary-700 hover:text-primary-800 transition-colors">
            Start the form
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ── CTA FOOTER ────────────────────────────────────────────────── -->
  <section class="py-10 bg-[#faf9f7] border-t border-neutral-100">
    <div class="max-w-2xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <p class="font-semibold text-neutral-900 text-sm mb-0.5">Questions or need to make a change?</p>
        <p class="text-sm text-neutral-500">We respond quickly — don't hesitate to reach out.</p>
      </div>
      <div class="flex flex-wrap gap-3 shrink-0">
        <a href="tel:+16093660857" class="inline-flex items-center gap-2 bg-neutral-900 text-white px-5 py-2.5 rounded-xl text-sm font-semibold hover:bg-neutral-800 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          (609) 366-0857
        </a>
        <a href="/" class="inline-flex items-center gap-2 border border-neutral-300 text-neutral-700 px-5 py-2.5 rounded-xl text-sm font-semibold hover:border-neutral-400 transition-colors">
          Back to Home
        </a>
      </div>
    </div>
  </section>

  <!-- ② Populate booking reference from Stripe session_id in URL (non-blocking) -->
  <script is:inline>
    (function () {
      var sid = new URLSearchParams(location.search).get('session_id') || '';
      if (sid.length > 8) {
        var el = document.getElementById('ref-display-line');
        if (el) {
          el.textContent = 'Reference ending in ' + sid.slice(-8).toUpperCase();
          el.classList.remove('hidden');
        }
      }
    })();
  </script>

</Layout>
