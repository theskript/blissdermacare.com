---
import Layout from '../../layouts/Layout.astro';
const sessionId = Astro.url.searchParams.get('session_id') ?? '';
const refDisplay = sessionId.length > 8 ? `…${sessionId.slice(-8)}` : sessionId;
const payInPerson = Astro.url.searchParams.get('payment') === 'in-person';
---

<Layout
  title="Booking Confirmed – Bliss Dermacare"
  description={payInPerson ? "Your appointment request has been received at Bliss Dermacare. We'll confirm within 24 hours." : "Your payment was successful and your appointment request has been received at Bliss Dermacare."}
>
  <section class="min-h-[70vh] flex items-center justify-center py-20 bg-[#faf9f7]">
    <div class="max-w-lg mx-auto px-6 text-center">

      <div class="w-20 h-20 rounded-full bg-emerald-100 flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-4xl font-serif text-neutral-900 mb-3">
        {payInPerson ? 'Request Received!' : "You're All Set!"}
      </h1>
      <p class="text-lg text-neutral-600 mb-8">
        {payInPerson
          ? <>Booking request submitted. We'll reach out within <strong>24 hours</strong> to confirm your appointment.</>
          : <>Payment received. We'll reach out within <strong>24 hours</strong> to finalise your appointment details.</>
        }
      </p>

      <div class="bg-white rounded-2xl border border-neutral-200 p-6 text-left space-y-4 mb-8">

        {payInPerson ? (
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-0.5">Payment Due at Appointment</p>
              <p class="text-sm text-neutral-700">Please bring payment — we accept <strong>cash</strong>, <strong>Zelle</strong>, or <strong>Venmo</strong> at your appointment.</p>
            </div>
          </div>
        ) : (
          <>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-0.5">Booking Reference</p>
                <p class="font-mono text-sm text-neutral-800">{refDisplay || '—'}</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-0.5">Receipt</p>
                <p class="text-sm text-neutral-700">A Stripe payment receipt has been sent to your email address.</p>
              </div>
            </div>
          </>
        )}

        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-0.5">Community Discount</p>
            <p class="text-sm text-neutral-700">If you selected a community discount, please bring valid credentials. If unable to verify, the standard rate applies and the difference is collected in person.</p>
          </div>
        </div>

      </div>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="px-6 py-3 bg-primary-600 text-white rounded-xl font-semibold text-sm hover:bg-primary-700 transition-all">Back to Home</a>
        <a href="/pre-service-form/" class="px-6 py-3 bg-white border border-neutral-300 text-neutral-700 rounded-xl font-semibold text-sm hover:border-neutral-400 transition-all">Complete Pre-Service Form</a>
      </div>

      <p class="text-xs text-neutral-500 mt-8">
        Questions? Call us at <a href="tel:+16093660857" class="text-primary-600 hover:text-primary-700 font-medium">(609) 366-0857</a>
      </p>

    </div>
  </section>
</Layout>
