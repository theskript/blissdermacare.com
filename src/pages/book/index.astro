            <a href="/consultation/" class="inline-block text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">Free Consultation &rarr;</a>
          </div>

          <div class="bg-blue-50 rounded-2xl p-6 border border-blue-200">
            <h3 class="font-semibold text-neutral-900 mb-2">Complete Your Pre-Service Form</h3>
            <p class="text-sm text-neutral-600 mb-4">First-time clients should fill out our pre-service questionnaire to ensure your safety and the best results.</p>
            <a href="/pre-service-form/" class="inline-block text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors">Start Form &rarr;</a>
          </div>

          <div class="bg-white rounded-2xl p-6 border border-neutral-200">
            <h3 class="font-semibold text-neutral-900 mb-1">Accepted Payment Methods</h3>
            <p class="text-xs text-neutral-500 mb-3">Online payments are encrypted and processed securely.</p>
            <div class="flex flex-wrap gap-2 mb-3">
              <span class="text-xs bg-neutral-100 text-neutral-700 px-3 py-1.5 rounded-full font-medium">Visa</span>
              <span class="text-xs bg-neutral-100 text-neutral-700 px-3 py-1.5 rounded-full font-medium">Mastercard</span>
              <span class="text-xs bg-neutral-100 text-neutral-700 px-3 py-1.5 rounded-full font-medium">Amex</span>
              <span class="text-xs bg-neutral-100 text-neutral-700 px-3 py-1.5 rounded-full font-medium">Apple Pay</span>
              <span class="text-xs bg-neutral-100 text-neutral-700 px-3 py-1.5 rounded-full font-medium">Google Pay</span>
            </div>
            <p class="text-xs text-neutral-400">Cash, Zelle &amp; Venmo accepted in person.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    (function () {
      const PRICES: Record<string, number> = {
        'other': 1,
        'signature-radiance-facial': 99,
        'brightening-peel': 128,
        'diamond-glow': 119,
        'teen-skincare-facial': 64,
        'high-frequency-skin-tightening': 95,
        'pumpkin-enzyme-facial': 85,
        'chlorophyll-skin-tightening-facial': 105,
        'pineapple-enzyme-facial': 88,
        'skin-recovery-facial': 92,
        'lash-extensions': 159,
        'lash-extensions-fill': 43,
        'lash-lift-brow-lamination': 79,
        'body-and-face-waxing': 65,
        'brazilian-wax': 87,
        'vampire-facial-prp': 380,
        'lash-body-smooth': 185,
        'brow-lash-wax-ritual': 115,
        'glow-smooth-escape': 135,
        'mix-match-package': 129,
        'spray-tan': 65,
        'bronze-bare-glow': 110,
        'dermaplane-glow-facial': 105,
        'smooth-canvas-facial': 89,
        'prp-treatment': 399,
        'lip-filler': 599,
        'ed-injectables': 499,
        'collagen-induction-therapy': 299,
        'weight-loss-program': 299,
        'scalp-micropigmentation': 650,
        'lip-neutralization': 399,
        'lip-blush': 499,
        'nano-brows': 499,
        'powder-brows': 549,
        'custom-semipermanent-makeup': 450,
        'iv-hydration-therapy': 149,
        'lab-collection': 199,
        'hormone-lab-panel': 349,
        'regenerative-blood-services': 450,
      };

      const SERVICE_LABELS: Record<string, string> = {
        'signature-radiance-facial': 'Signature Radiance Facial',
        'brightening-peel': 'Brightening Peel',
        'diamond-glow': 'Diamond Glow',
        'teen-skincare-facial': 'Teen Skincare Facial',
        'high-frequency-skin-tightening': 'High Frequency Skin Tightening',
        'pumpkin-enzyme-facial': 'Pumpkin Enzyme Facial',
        'chlorophyll-skin-tightening-facial': 'Chlorophyll Skin Tightening Facial',
        'pineapple-enzyme-facial': 'Pineapple Enzyme Facial',
        'skin-recovery-facial': 'Skin Recovery Facial',
        'lash-extensions': 'Lash Extensions',
        'lash-extensions-fill': 'Lash Extensions Fill',
        'lash-lift-brow-lamination': 'Lash Lift & Brow Lamination',
        'body-and-face-waxing': 'Body & Face Waxing',
        'brazilian-wax': 'Brazilian Wax',
        'vampire-facial-prp': 'Vampire Facial (PRP)',
        'lash-body-smooth': 'Lash & Body Smooth Package',
        'brow-lash-wax-ritual': 'Brow, Lash & Wax Ritual Package',
        'glow-smooth-escape': 'Glow & Smooth Escape Package',
        'mix-match-package': 'Mix & Match Escape Package',
        'spray-tan': 'Custom Airbrush Spray Tan',
        'bronze-bare-glow': 'Bronze & Bare Glow Package',
        'dermaplane-glow-facial': 'Dermaplane Glow Facial',
        'smooth-canvas-facial': 'Smooth Canvas Facial',
        'prp-treatment': 'PRP (Platelet-Rich Plasma)',
        'lip-filler': 'Lip Filler',
        'ed-injectables': 'Erectile Dysfunction Injectables',
        'collagen-induction-therapy': 'Collagen Induction Therapy',
        'weight-loss-program': 'Weight Loss Program (GLP-1/Semiglutide)',
        'scalp-micropigmentation': 'Scalp Micropigmentation',
        'lip-neutralization': 'Lip Neutralization',
        'lip-blush': 'Lip Blush',
        'nano-brows': 'Nano Brows',
        'powder-brows': 'Powder Brows',
        'custom-semipermanent-makeup': 'Custom Semipermanent Makeup',
        'iv-hydration-therapy': 'IV Hydration Therapy',
        'lab-collection': 'Personalized Lab Collection',
        'hormone-lab-panel': 'Hormone Lab Panel Support',
        'regenerative-blood-services': 'Regenerative Blood-Based Services',
        'other': 'Other / Not Sure',
      };

      const DISCOUNT_PCT: Record<string, number> = {
        'none': 0,
        'first-responder-veteran': 15,
        'teacher-educator': 10,
        'senior-65-plus': 10,
        'student': 10,
      };

      const DISCOUNT_LABELS: Record<string, string> = {
        'first-responder-veteran': 'First Responder / Veteran (15% off)',
        'teacher-educator': 'Teacher / Educator (10% off)',
        'senior-65-plus': 'Senior 65+ (10% off)',
        'student': 'Student (10% off)',
      };

      function fmt(n: number): string {
        return '$' + n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      }

      const DURATIONS: Record<string, number> = {
        'signature-radiance-facial': 60,
        'brightening-peel': 45,
        'diamond-glow': 50,
        'teen-skincare-facial': 45,
        'high-frequency-skin-tightening': 45,
        'pumpkin-enzyme-facial': 60,
        'chlorophyll-skin-tightening-facial': 60,
        'pineapple-enzyme-facial': 60,
        'skin-recovery-facial': 60,
        'lash-extensions': 120,
        'lash-extensions-fill': 60,
        'lash-lift-brow-lamination': 60,
        'body-and-face-waxing': 60,
        'brazilian-wax': 60,
        'vampire-facial-prp': 75,
        'lash-body-smooth': 135,
        'brow-lash-wax-ritual': 135,
        'glow-smooth-escape': 135,
        'mix-match-package': 135,
        'spray-tan': 45,
        'bronze-bare-glow': 105,
        'dermaplane-glow-facial': 60,
        'smooth-canvas-facial': 45,
        'prp-treatment': 60,
        'lip-filler': 45,
        'ed-injectables': 60,
        'collagen-induction-therapy': 60,
        'weight-loss-program': 30,
        'scalp-micropigmentation': 180,
        'lip-neutralization': 120,
        'lip-blush': 120,
        'nano-brows': 150,
        'powder-brows': 150,
        'custom-semipermanent-makeup': 120,
        'iv-hydration-therapy': 60,
        'lab-collection': 30,
        'hormone-lab-panel': 45,
        'regenerative-blood-services': 60,
        'other': 60,
      };

      // Services that must be booked alone (packages, hairline restoration, other)
      const SOLO_SERVICES = new Set([
        'lash-body-smooth', 'brow-lash-wax-ritual', 'glow-smooth-escape',
        'mix-match-package', 'bronze-bare-glow', 'other',
        'prp-treatment', 'lip-filler', 'ed-injectables', 'collagen-induction-therapy', 'weight-loss-program',
        'scalp-micropigmentation', 'lip-neutralization', 'lip-blush', 'nano-brows', 'powder-brows', 'custom-semipermanent-makeup',
        'iv-hydration-therapy', 'lab-collection', 'hormone-lab-panel', 'regenerative-blood-services',
      ]);

      function getChecked(): string[] {
        return Array.from(
          document.querySelectorAll<HTMLInputElement>('input[name="service"]:checked')
        ).map(el => el.value);
      }

      function totalDuration(svcs: string[]): number {
        return svcs.reduce((s, v) => s + (DURATIONS[v] ?? 60), 0);
      }

      function update() {
        const checked = getChecked();
        const discountInput = document.querySelector<HTMLInputElement>('input[name="discount"]:checked');
        const summary = document.getElementById('price-summary')!;
        const tracker = document.getElementById('duration-tracker') as HTMLElement | null;
        const durationText = document.getElementById('duration-text') as HTMLElement | null;
        const durationBar = document.getElementById('duration-bar') as HTMLElement | null;

        if (checked.length === 0) {
          summary.classList.add('hidden');
          if (tracker) { tracker.classList.add('hidden'); tracker.classList.remove('flex'); }
          return;
        }

        // Duration tracker
        const totalMins = totalDuration(checked);
        const isSolo = checked.length === 1 && SOLO_SERVICES.has(checked[0]);
        if (tracker && durationText && durationBar) {
          tracker.classList.remove('hidden');
          tracker.classList.add('flex');
          if (isSolo) {
            durationText.textContent = 'Package / standalone';
            durationBar.style.width = '100%';
            durationBar.className = 'h-full bg-primary-500 rounded-full transition-all duration-200';
          } else {
            const pct = Math.min((totalMins / 120) * 100, 100);
            durationText.textContent = `${totalMins} / 120 min`;
            durationBar.style.width = pct + '%';
            const color = totalMins > 120 ? 'bg-red-500' : totalMins > 90 ? 'bg-amber-500' : 'bg-primary-500';
            durationBar.className = `h-full ${color} rounded-full transition-all duration-200`;
          }
        }

        // Price summary
        summary.classList.remove('hidden');
        const disc = discountInput?.value ?? 'none';
        const baseTotal = checked.reduce((s, v) => s + (PRICES[v] ?? 0), 0);
        const listEl = document.getElementById('summary-services-list');
        if (listEl) {
          listEl.innerHTML = checked.map(v =>
            `<div class="flex justify-between items-center text-sm">
              <span class="text-neutral-600">${SERVICE_LABELS[v] ?? v}</span>
              <span class="font-semibold text-neutral-900">${fmt(PRICES[v] ?? 0)}</span>
            </div>`
          ).join('');
        }

        const discRow = document.getElementById('summary-discount-row')!;
        const discLabelEl = document.getElementById('summary-discount-label')!;
        const discAmtEl = document.getElementById('summary-discount-amount')!;
        const totalEl = document.getElementById('summary-total')!;

        const pct = DISCOUNT_PCT[disc] ?? 0;
        if (pct > 0 && baseTotal > 0) {
          const savings = baseTotal * pct / 100;
          discLabelEl.textContent = DISCOUNT_LABELS[disc];
          discAmtEl.textContent = '−' + fmt(savings);
          discRow.classList.remove('hidden');
          totalEl.textContent = fmt(baseTotal - savings);
        } else {
          discRow.classList.add('hidden');
          totalEl.textContent = fmt(baseTotal);
        }
      }

      function enforceAvailability() {
        const checked = getChecked();
        const currentTotal = totalDuration(checked);
        const hasSolo = checked.some(s => SOLO_SERVICES.has(s));
        const hasAny = checked.length > 0;

        document.querySelectorAll<HTMLInputElement>('input[name="service"]').forEach(input => {
          if (input.checked) {
            input.disabled = false;
            const lbl = input.closest('label') as HTMLElement | null;
            if (lbl) { lbl.classList.remove('opacity-40', 'pointer-events-none'); lbl.classList.add('cursor-pointer'); }
            return;
          }
          const dur = DURATIONS[input.value] ?? 60;
          let disable = false;
          if (hasSolo) {
            disable = true;
          } else if (SOLO_SERVICES.has(input.value)) {
            disable = hasAny;
          } else {
            disable = currentTotal + dur > 120;
          }
          input.disabled = disable;
          const lbl = input.closest('label') as HTMLElement | null;
          if (lbl) {
            lbl.classList.toggle('opacity-40', disable);
            lbl.classList.toggle('pointer-events-none', disable);
            lbl.classList.toggle('cursor-pointer', !disable);
          }
        });
      }

      function onServiceChange(changed: HTMLInputElement) {
        if (changed.checked) {
          if (SOLO_SERVICES.has(changed.value)) {
            document.querySelectorAll<HTMLInputElement>('input[name="service"]:checked').forEach(el => {
              if (el !== changed) el.checked = false;
            });
          } else {
            document.querySelectorAll<HTMLInputElement>('input[name="service"]:checked').forEach(el => {
              if (SOLO_SERVICES.has(el.value) && el !== changed) el.checked = false;
            });
            if (totalDuration(getChecked()) > 120) {
              changed.checked = false;
            }
          }
        }
        update();
        enforceAvailability();
      }

      // ── Cart Pre-population ────────────────────────────────────────────────
      try {
        const cartItems: Array<{id: string}> = JSON.parse(localStorage.getItem('bliss_cart_v1') || '[]');
        if (cartItems.length > 0) {
          const banner    = document.getElementById('cart-prefill-banner');
          const countEl   = document.getElementById('cart-prefill-count');
          if (banner && countEl) {
            countEl.textContent = cartItems.length === 1 ? '1 service' : cartItems.length + ' services';
            banner.classList.remove('hidden');
            banner.classList.add('flex');
          }
          cartItems.forEach(item => {
            const cb = document.querySelector<HTMLInputElement>(`input[name="service"][value="${item.id}"]`);
            if (cb) cb.checked = true;
          });
          enforceAvailability();
          update();
        }
      } catch (_) {}
      // ── End Cart Pre-population ────────────────────────────────────────────

      document.querySelectorAll<HTMLInputElement>('input[name="service"]')
        .forEach(el => el.addEventListener('change', () => onServiceChange(el)));
      document.querySelectorAll<HTMLInputElement>('input[name="discount"]')
        .forEach(el => el.addEventListener('change', update));

      // ── Mix & Match Panel ──────────────────────────────────────────────────
      const MM_DISCOUNT = 15;
      const mmCheckbox = document.getElementById('mix-match-checkbox') as HTMLInputElement | null;
      const mmPanel = document.getElementById('mix-match-panel');
      const mmPriceLabel = document.getElementById('mix-match-price-label');
      const mmBreakdown = document.getElementById('mm-price-breakdown');
      const mmInstructions = document.getElementById('mm-instructions');
      const mmSvc1Label = document.getElementById('mm-svc1-label')!;
      const mmSvc1Price = document.getElementById('mm-svc1-price')!;
      const mmSvc2Label = document.getElementById('mm-svc2-label')!;
      const mmSvc2Price = document.getElementById('mm-svc2-price')!;
      const mmTotal = document.getElementById('mm-total')!;

      // Track selected mix & match services (max 2, must be different categories)
      let mmSelected: Array<{value: string; label: string; price: number}> = [];

      // Category map — mirrors MM_OPTIONS categories in Layout.astro
      const MM_CAT: Record<string, string> = {
        'mm-signature-radiance': 'facial', 'mm-brightening-peel':  'facial',
        'mm-diamond-glow':       'facial', 'mm-high-freq':          'facial',
        'mm-teen-facial':        'facial', 'mm-pumpkin-enzyme':     'facial',
        'mm-chlorophyll':        'facial', 'mm-pineapple-enzyme':   'facial',
        'mm-skin-recovery':      'facial',
        'mm-lash-lift':          'lash',   'mm-lash-ext':           'lash',
        'mm-body-wax':           'wax',    'mm-brazilian':          'wax',
      };

      // Visually grey out same-category labels after each selection change
      function refreshMMLabels() {
        const takenCat = mmSelected.length === 1 ? MM_CAT[mmSelected[0].value] : null;
        document.querySelectorAll<HTMLInputElement>('.mix-match-service-cb').forEach(cb => {
          const label = cb.closest('label');
          if (!label) return;
          const sameCat = takenCat && MM_CAT[cb.dataset.mmValue ?? ''] === takenCat && !cb.checked;
          label.classList.toggle('opacity-40', !!sameCat);
          label.classList.toggle('pointer-events-none', !!sameCat);
        });
      }

      function updateMixMatchPanel() {
        const count = mmSelected.length;

        if (count === 2) {
          const total = mmSelected[0].price + mmSelected[1].price - MM_DISCOUNT;
          mmSvc1Label.textContent = mmSelected[0].label;
          mmSvc1Price.textContent = '$' + mmSelected[0].price.toFixed(2);
          mmSvc2Label.textContent = mmSelected[1].label;
          mmSvc2Price.textContent = '$' + mmSelected[1].price.toFixed(2);
          mmTotal!.textContent = '$' + total.toFixed(2);
          mmBreakdown?.classList.remove('hidden');
          mmInstructions?.classList.add('hidden');
          // Update the main package price label and PRICES entry
          if (mmPriceLabel) mmPriceLabel.textContent = '$' + total.toFixed(2);
          PRICES['mix-match-package'] = total;
          SERVICE_LABELS['mix-match-package'] = `Mix & Match: ${mmSelected[0].label} + ${mmSelected[1].label}`;
        } else {
          mmBreakdown?.classList.add('hidden');
          mmInstructions?.classList.remove('hidden');
          if (mmPriceLabel) mmPriceLabel.textContent = count === 1
            ? `$${mmSelected[0].price} + 1 more`
            : 'From $129';
          PRICES['mix-match-package'] = 129;
          SERVICE_LABELS['mix-match-package'] = 'Mix & Match Escape Package';
        }
        // Refresh main summary
        update();
      }

      document.querySelectorAll<HTMLInputElement>('.mix-match-service-cb').forEach(cb => {
        cb.addEventListener('change', () => {
          const lbl   = cb.dataset.mmLabel ?? '';
          const price = parseInt(cb.dataset.mmPrice ?? '0', 10);
          const value = cb.dataset.mmValue ?? '';

          if (cb.checked) {
            if (mmSelected.length >= 2) {
              // Already full — reject and revert
              cb.checked = false;
              return;
            }
            // Category rule: both must be different types
            if (mmSelected.length === 1 && MM_CAT[mmSelected[0].value] === MM_CAT[value]) {
              cb.checked = false;
              // Show inline hint below the grid
              const hint = document.getElementById('mm-category-hint');
              if (hint) { hint.classList.remove('hidden'); setTimeout(() => hint.classList.add('hidden'), 3500); }
              return;
            }
            mmSelected.push({ value, label: lbl, price });
          } else {
            mmSelected = mmSelected.filter(s => s.value !== value);
          }
          refreshMMLabels();
          updateMixMatchPanel();
        });
      });

      // Show/hide the panel when the main mix-match checkbox is toggled
      if (mmCheckbox) {
        mmCheckbox.addEventListener('change', () => {
          if (mmCheckbox.checked) {
            mmPanel?.classList.remove('hidden');
          } else {
            mmPanel?.classList.add('hidden');
            // Clear all mix-match sub-selections
            mmSelected = [];
            document.querySelectorAll<HTMLInputElement>('.mix-match-service-cb').forEach(cb => { cb.checked = false; });
            refreshMMLabels();
            mmBreakdown?.classList.add('hidden');
            mmInstructions?.classList.remove('hidden');
            if (mmPriceLabel) mmPriceLabel.textContent = 'From $129';
            PRICES['mix-match-package'] = 129;
            SERVICE_LABELS['mix-match-package'] = 'Mix & Match Escape Package';
          }
        });
      }
      // ── End Mix & Match Panel ──────────────────────────────────────────────

      // ── Cart: MM Pre-population ────────────────────────────────────────────
      // Runs AFTER mmSelected and updateMixMatchPanel are defined above
      try {
        const cartRaw = JSON.parse(localStorage.getItem('bliss_cart_v1') || '[]') as Array<any>;
        const mmCart  = cartRaw.find((i: any) => i.id === 'mix-match-package');
        if (mmCart && Array.isArray(mmCart.mmServices) && mmCart.mmServices.length === 2) {
          const [v1, v2] = mmCart.mmServices as string[];
          [v1, v2].forEach(val => {
            const cb = document.querySelector<HTMLInputElement>(`.mix-match-service-cb[data-mm-value="${val}"]`);
            if (!cb) return;
            cb.checked = true;
            const label = cb.dataset.mmLabel ?? '';
            const price = parseInt(cb.dataset.mmPrice ?? '0', 10);
            if (!mmSelected.some(s => s.value === val)) {
              mmSelected.push({ value: val, label, price });
            }
          });
          if (mmSelected.length === 2) {
            updateMixMatchPanel();
            refreshMMLabels();
            mmPanel?.classList.remove('hidden');
          }
        }
      } catch (_) {}
      // ── End Cart: MM Pre-population ───────────────────────────────────────

      // Enforce strict 24-hour advance booking (exact datetime, not just calendar day)
      const dateInput = document.getElementById('bookingDate') as HTMLInputElement;

      function toDateStr(d: Date): string {
        const yyyy = d.getFullYear();
        const mm = String(d.getMonth() + 1).padStart(2, '0');
        const dd = String(d.getDate()).padStart(2, '0');
        return `${yyyy}-${mm}-${dd}`;
      }

      // Parse a time slot value like "10:00am", "1:30pm" into total minutes since midnight
      function slotToMinutes(value: string): number {
        const m = value.match(/^(\d+):(\d+)(am|pm)$/i);
        if (!m) return -1;
        let h = parseInt(m[1]);
        const min = parseInt(m[2]);
        const period = m[3].toLowerCase();
        if (period === 'pm' && h !== 12) h += 12;
        if (period === 'am' && h === 12) h = 0;
        return h * 60 + min;
      }

      // ── Availability (dynamic from DB) ─────────────────────────────────────
      const DEFAULT_SCHEDULE = [
        { day_of_week: 0, is_open: false, open_time: '12:30', close_time: '19:00', slot_interval: 30 },
        { day_of_week: 1, is_open: false, open_time: '12:30', close_time: '19:00', slot_interval: 30 },
        { day_of_week: 2, is_open: false, open_time: '12:30', close_time: '19:00', slot_interval: 30 },
        { day_of_week: 3, is_open: true,  open_time: '12:30', close_time: '19:00', slot_interval: 30 },
        { day_of_week: 4, is_open: true,  open_time: '12:30', close_time: '19:00', slot_interval: 30 },
        { day_of_week: 5, is_open: true,  open_time: '12:30', close_time: '19:00', slot_interval: 30 },
        { day_of_week: 6, is_open: true,  open_time: '12:30', close_time: '18:00', slot_interval: 30 },
      ];
      let avail: { schedule: any[], overrides: any[] } = { schedule: DEFAULT_SCHEDULE, overrides: [] };
      (async () => {
        try {
          const resp = await fetch('/.netlify/functions/get-availability');
          if (resp.ok) { const d = await resp.json(); if (d.schedule?.length) avail = d; }
        } catch {}
        if (dateInput?.value) refreshTimeSlots();
        // Sync sidebar hours display with live schedule
        const hoursEl = document.getElementById('book-hours-list');
        if (hoursEl) {
          const { renderHoursInto } = await import('../../scripts/hoursDisplay.js');
          renderHoursInto(hoursEl, avail.schedule);
          // Update last-slot note
          const noteEl = document.getElementById('book-hours-note');
          if (noteEl) {
            const openDays = avail.schedule.filter((s: any) => s.is_open);
            if (openDays.length) {
              const lastSlotTimes = openDays.map((s: any) => {
                const [h, m] = (s.close_time || '19:00').split(':').map(Number);
                const interval = s.slot_interval || 30;
                const closeMins = h * 60 + m;
                const lastMins  = closeMins - interval;
                const lh = Math.floor(lastMins / 60);
                const lm = lastMins % 60;
                const p  = lh >= 12 ? 'PM' : 'AM';
                const h12 = lh > 12 ? lh - 12 : lh === 0 ? 12 : lh;
                return `${h12}:${String(lm).padStart(2,'0')} ${p}`;
              });
              const unique = [...new Set(lastSlotTimes)];
              noteEl.textContent = `Last available appointment starts at ${unique.join(' / ')}.`;
            }
          }
        }
      })();

      function getAvailForDate(dateStr: string) {
        const override = avail.overrides.find((o: any) => o.date === dateStr);
        if (override) {
          if (override.is_closed) return null;
          return { open_time: override.open_time, close_time: override.close_time, slot_interval: 30 };
        }
        const day = new Date(dateStr + 'T00:00:00').getDay();
        const sched = avail.schedule.find((s: any) => s.day_of_week === day);
        if (!sched || !sched.is_open) return null;
        return sched;
      }

      function parseHHMM(t: string): number {
        const [h, m] = (t || '').split(':').map(Number);
        return (isNaN(h) ? 0 : h) * 60 + (isNaN(m) ? 0 : m);
      }

      function minsToLabel(mins: number): { value: string; label: string } {
        const h = Math.floor(mins / 60);
        const m = mins % 60;
        const period = h >= 12 ? 'PM' : 'AM';
        const h12 = h > 12 ? h - 12 : h === 0 ? 12 : h;
        const label = `${h12}:${String(m).padStart(2, '0')} ${period}`;
        const value = `${h12}:${String(m).padStart(2, '0')}${period.toLowerCase()}`;
        return { value, label };
      }

      function fmt24to12(t: string): string {
        if (!t) return '';
        const [h, m] = t.split(':').map(Number);
        const period = h >= 12 ? 'PM' : 'AM';
        const h12 = h > 12 ? h - 12 : h === 0 ? 12 : h;
        return `${h12}:${String(m).padStart(2, '0')} ${period}`;
      }

      function refreshTimeSlots() {
        const grid    = document.getElementById('time-slots-grid')!;
        const hint    = document.getElementById('hours-hint')!;
        const now     = new Date();
        const todayStr = toDateStr(now);
        const nowMins  = now.getHours() * 60 + now.getMinutes();
        const selectedDate = dateInput?.value ?? '';

        if (!selectedDate) {
          grid.innerHTML = '<div class="col-span-full text-sm text-neutral-400 text-center py-6">Select a date above to see available time slots.</div>';
          hint.textContent = '';
          return;
        }

        const dayAvail = getAvailForDate(selectedDate);
        if (!dayAvail) {
          grid.innerHTML = '<div class="col-span-full text-sm text-amber-700 bg-amber-50 rounded-lg px-4 py-3">This date is unavailable for booking. Please choose another day.</div>';
          hint.textContent = '';
          return;
        }

        const openMins  = parseHHMM(dayAvail.open_time  || '12:30');
        const closeMins = parseHHMM(dayAvail.close_time || '19:00');
        const interval  = dayAvail.slot_interval || 30;
        const slots: Array<{ value: string; label: string; disabled: boolean }> = [];

        for (let t = openMins; t < closeMins; t += interval) {
          const { value, label } = minsToLabel(t);
          const tooSoon = selectedDate === todayStr && t <= nowMins;
          slots.push({ value, label, disabled: tooSoon });
        }

        if (slots.length === 0) {
          grid.innerHTML = '<div class="col-span-full text-sm text-neutral-400 text-center py-6">No time slots available for this date.</div>';
          hint.textContent = '';
          return;
        }

        grid.innerHTML = slots.map(s => `
          <label class="${s.disabled ? 'cursor-not-allowed opacity-40' : 'cursor-pointer'}">
            <input type="radio" name="timeslot" value="${s.value}" class="sr-only peer" ${s.disabled ? 'disabled' : ''} />
            <div class="text-center rounded-lg border-2 border-neutral-200 py-3 px-1 text-sm font-medium peer-checked:border-primary-600 peer-checked:bg-primary-600 peer-checked:text-white hover:border-primary-300 transition-all">
              ${s.label}
            </div>
          </label>`).join('');

        hint.textContent = `${fmt24to12(dayAvail.open_time)} – ${fmt24to12(dayAvail.close_time)}`;
      }

      if (dateInput) {
        dateInput.min = toDateStr(new Date());
        dateInput.addEventListener('change', () => {
          if (dateInput.value) {
            const dayAvail = getAvailForDate(dateInput.value);
            if (!dayAvail) {
              dateInput.setCustomValidity('This date is unavailable for booking. Please choose another day.');
              dateInput.reportValidity();
            } else {
              dateInput.setCustomValidity('');
            }
          }
          refreshTimeSlots();
        });
        refreshTimeSlots();
      }

      // Show/hide Groupon voucher code field based on referral selection
      const grouponCodeField = document.getElementById('groupon-code-field');
      document.querySelectorAll<HTMLInputElement>('input[name="referral"]').forEach(input => {
        input.addEventListener('change', () => {
          if (grouponCodeField) {
            grouponCodeField.classList.toggle('hidden', input.value !== 'groupon');
          }
        });
      });

      const submitBtn   = document.getElementById('booking-submit') as HTMLButtonElement | null;
      const submitLabel = document.getElementById('booking-submit-label')!;
      const spinner     = document.getElementById('booking-spinner')!;
      const errorBox    = document.getElementById('booking-error')!;
      const errorText   = document.getElementById('booking-error-text')!;

      function showError(msg: string) {
        errorText.textContent = msg;
        errorBox.classList.remove('hidden');
        errorBox.classList.add('flex');
        errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      function clearError() {
        errorBox.classList.add('hidden');
        errorBox.classList.remove('flex');
      }
      const payOnlineRadio    = document.getElementById('pay-online')    as HTMLInputElement | null;
      const payInPersonRadio  = document.getElementById('pay-in-person') as HTMLInputElement | null;
      const submitNote        = document.getElementById('booking-submit-note')!;

      function getPaymentMethod(): 'online' | 'in-person' {
        const sel = document.querySelector<HTMLInputElement>('input[name="paymentMethod"]:checked');
        return sel?.value === 'in-person' ? 'in-person' : 'online';
      }

      function syncSubmitButton() {
        const method = getPaymentMethod();
        if (method === 'in-person') {
          submitLabel.textContent = 'Request Appointment';
          submitBtn!.className = submitBtn!.className
            .replace('bg-primary-600', 'bg-amber-600')
            .replace('hover:bg-primary-700', 'hover:bg-amber-700');
          submitNote.innerHTML = '<svg class="w-3.5 h-3.5 text-neutral-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>No payment required now — pay cash, Zelle, or Venmo at your appointment.';
        } else {
          submitLabel.textContent = 'Pay \u0026 Book Appointment';
          submitBtn!.className = submitBtn!.className
            .replace('bg-amber-600', 'bg-primary-600')
            .replace('hover:bg-amber-700', 'hover:bg-primary-700');
          submitNote.innerHTML = '<svg class="w-3.5 h-3.5 text-neutral-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>Secure, encrypted payment. We&apos;ll confirm your appointment shortly.';
        }
      }

      payOnlineRadio?.addEventListener('change', syncSubmitButton);
      payInPersonRadio?.addEventListener('change', syncSubmitButton);

      function setLoading(on: boolean) {
        if (!submitBtn) return;
        submitBtn.disabled = on;
        const method = getPaymentMethod();
        if (on) {
          submitLabel.textContent = method === 'in-person' ? 'Submitting request…' : 'Redirecting to payment…';
        } else {
          syncSubmitButton();
        }
        spinner.classList.toggle('hidden', !on);
      }

      const form = document.getElementById('booking-form') as HTMLFormElement | null;
      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearError();

        // Date / time validation using dynamic availability
        const d = document.getElementById('bookingDate') as HTMLInputElement;
        if (d?.value) {
          const dayAvail = getAvailForDate(d.value);
          if (!dayAvail) {
            d.setCustomValidity('This date is unavailable for booking. Please choose another day.');
            d.reportValidity();
            return;
          }
        }
        const t = document.querySelector<HTMLInputElement>('input[name="timeslot"]:checked');
        if (d?.value && t?.value) {
          const slotMins = slotToMinutes(t.value);
          const slotHours = Math.floor(slotMins / 60);
          const slotMinutes = slotMins % 60;
          const selectedDT = new Date(d.value + 'T00:00:00');
          selectedDT.setHours(slotHours, slotMinutes, 0, 0);
          if (selectedDT < new Date()) {
            d.setCustomValidity('Please select a date and time in the future.');
            d.reportValidity();
            return;
          }
        } else if (d?.value) {
          const selectedDT = new Date(d.value + 'T00:00:00');
          if (selectedDT < new Date(toDateStr(new Date()) + 'T00:00:00')) {
            d.setCustomValidity('Please select a date in the future.');
            d.reportValidity();
            return;
          }
        }
        d?.setCustomValidity('');

        // Service + time required
        const checkedSvcs = Array.from(
          document.querySelectorAll<HTMLInputElement>('input[name="service"]:checked')
        ).map((el: HTMLInputElement) => el.value);
        if (checkedSvcs.length === 0) {
          showError('Please select at least one service before continuing.');
          return;
        }
        if (checkedSvcs.includes('mix-match-package') && mmSelected.length < 2) {
          showError('Please choose 2 services for your Mix & Match Escape package.');
          document.getElementById('mix-match-panel')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
        if (!t) {
          showError('Please select a time slot before continuing.');
          return;
        }

        const discountInput     = document.querySelector<HTMLInputElement>('input[name="discount"]:checked');
        const nameInput         = document.querySelector<HTMLInputElement>('[name="name"]');
        const emailInput        = document.querySelector<HTMLInputElement>('[name="email"]');
        const phoneInput        = document.querySelector<HTMLInputElement>('[name="phone"]');
        const notesInput        = document.querySelector<HTMLTextAreaElement>('[name="notes"]');
        const referralInput     = document.querySelector<HTMLInputElement>('input[name="referral"]:checked');
        const grouponInput      = document.querySelector<HTMLInputElement>('[name="groupon-code"]');
        const confirmPhoneInput = document.querySelector<HTMLInputElement>('[name="confirm-phone"]');
        const confirmTextInput  = document.querySelector<HTMLInputElement>('[name="confirm-text"]');
        const confirmEmailInput = document.querySelector<HTMLInputElement>('[name="confirm-email"]');

        const payload = {
          services:        checkedSvcs,
          mixMatchServices: checkedSvcs.includes('mix-match-package') ? mmSelected.map(s => s.label) : [],
          discount:        discountInput?.value ?? 'none',
          customerName:    nameInput?.value ?? '',
          customerEmail:   emailInput?.value ?? '',
          customerPhone:   phoneInput?.value ?? '',
          appointmentDate: d?.value ?? '',
          appointmentTime: t.value,
          notes:           notesInput?.value ?? '',
          referral:        referralInput?.value ?? '',
          grouponCode:     grouponInput?.value ?? '',
          confirmPhone:    confirmPhoneInput?.checked ? 'yes' : '',
          confirmText:     confirmTextInput?.checked  ? 'yes' : '',
          confirmEmail:    confirmEmailInput?.checked ? 'yes' : '',
        };

        setLoading(true);
        const paymentMethod = getPaymentMethod();
        try {
          if (paymentMethod === 'in-person') {
            const res  = await fetch('/.netlify/functions/book-request', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            const data = await res.json().catch(() => ({ error: 'Unexpected server response.' }));
            if (!res.ok) throw new Error(data.error ?? 'Booking request failed. Please try again.');
            window.location.href = data.redirect ?? '/book/success?payment=in-person';
          } else {
            const res  = await fetch('/.netlify/functions/create-checkout-session', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            const data = await res.json().catch(() => ({ error: 'Unexpected server response.' }));
            if (!res.ok) throw new Error(data.error ?? 'Payment setup failed. Please try again.');
            window.location.href = data.url;
          }
        } catch (err: unknown) {
          showError(err instanceof Error ? err.message : 'Something went wrong. Please try again or call (609) 366-0857.');
          setLoading(false);
        }
      });
    })();
  </script>
</Layout>
