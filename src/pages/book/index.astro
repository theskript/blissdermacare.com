---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Book an Appointment – Bliss Dermacare" description="Request a skincare appointment at Bliss Dermacare in Pebble Creek, FL. Choose your service, preferred date and time, and we'll confirm within 24 hours.">

  <!-- Page Header -->
  <section class="py-14 bg-[#faf9f7] border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-4 block">Schedule Your Visit</span>
      <h1 class="text-5xl font-serif text-neutral-900 mb-4">Book an Appointment</h1>
      <p class="text-lg text-neutral-600">Choose your service and a time that works for you. We'll confirm within 24 hours.</p>
    </div>
  </section>

  <!-- Booking Form -->
  <section class="py-14 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-3 gap-10">

        <!-- Form -->
        <div class="lg:col-span-2"> 
          <form
            id="booking-form"
            name="appointment-booking"
            class="space-y-10"
            novalidate
          >

            <!-- Contact -->
            <div class="space-y-5">
              <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3">Your Details</h2>
              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="bookingName" class="block text-sm font-medium text-neutral-700 mb-1.5">Full Name *</label>
                  <input type="text" id="bookingName" name="name" required placeholder="Jane Smith"
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
                </div>
                <div>
                  <label for="bookingPhone" class="block text-sm font-medium text-neutral-700 mb-1.5">Phone Number *</label>
                  <input type="tel" id="bookingPhone" name="phone" required placeholder="(609) 366-0857"
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
                </div>
              </div>
              <div>
                <label for="bookingEmail" class="block text-sm font-medium text-neutral-700 mb-1.5">Email Address *</label>
                <input type="email" id="bookingEmail" name="email" required placeholder="jane@example.com"
                  class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
              </div>
            </div>

            <!-- Service Picker -->
            <div>
              <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3 mb-6">Choose a Service *</h2>
              <div class="space-y-6">

                <!-- Facials -->
                <div>
                  <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-neutral-400 mb-3">Facials</p>
                  <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">

                    <label class="cursor-pointer">
                      <input type="radio" name="service" value="signature-radiance-facial" class="sr-only peer" required />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Signature Radiance Facial</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$99</p>
                        <p class="text-xs text-neutral-400 mt-0.5">60 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="radio" name="service" value="brightening-peel" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Brightening Peel</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$128</p>
                        <p class="text-xs text-neutral-400 mt-0.5">45 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="radio" name="service" value="diamond-glow" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Diamond Glow</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$119</p>
                        <p class="text-xs text-neutral-400 mt-0.5">50 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="radio" name="service" value="high-frequency-skin-tightening" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">High Frequency Skin Tightening</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$95</p>
                        <p class="text-xs text-neutral-400 mt-0.5">45 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="radio" name="service" value="teen-skincare-facial" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Teen Skincare Facial</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$64</p>
                        <p class="text-xs text-neutral-400 mt-0.5">45 min</p>
                      </div>
                    </label>

                  </div>
                </div>

                <!-- Lash & Brow -->
                <div>
                  <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-neutral-400 mb-3">Lash &amp; Brow</p>
                  <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">

                    <label class="cursor-pointer">
                      <input type="radio" name="service" value="lash-extensions" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Lash Extensions</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$159</p>
                        <p class="text-xs text-neutral-400 mt-0.5">2 hr</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="radio" name="service" value="lash-extensions-fill" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Lash Extensions Fill</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$43</p>
                        <p class="text-xs text-neutral-400 mt-0.5">1 hr</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="radio" name="service" value="lash-lift-brow-lamination" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Lash Lift &amp; Brow Lamination</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$79</p>
                        <p class="text-xs text-neutral-400 mt-0.5">60 min</p>
                      </div>
                    </label>

                  </div>
                </div>

                <!-- Body & Advanced -->
                <div class="grid sm:grid-cols-2 gap-6">

                  <div>
                    <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-neutral-400 mb-3">Body &amp; Wax</p>
                    <div class="flex items-start gap-2 mb-3 p-2.5 bg-amber-50 border border-amber-200 rounded-lg">
                      <svg class="w-3.5 h-3.5 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4v2m0 4v2m0-14a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      <p class="text-xs text-amber-800"><strong>Age 21+</strong> required for waxing services</p>
                    </div>
                    <div class="space-y-2">
                      <label class="cursor-pointer block">
                        <input type="radio" name="service" value="body-and-face-waxing" class="sr-only peer" />
                        <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                          <p class="font-semibold text-sm text-neutral-900">Body &amp; Face Waxing</p>
                          <p class="text-xs text-neutral-600 mt-1">Facial, arms, legs, underarms</p>
                          <p class="text-primary-600 font-bold text-sm mt-1.5">$65</p>
                          <p class="text-xs text-neutral-400 mt-0.5">45–60 min</p>
                        </div>
                      </label>

                      <label class="cursor-pointer block">
                        <input type="radio" name="service" value="brazilian-wax" class="sr-only peer" />
                        <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                          <p class="font-semibold text-sm text-neutral-900">Brazilian Wax</p>
                          <p class="text-xs text-neutral-600 mt-1">Complete bikini area hair removal</p>
                          <p class="text-primary-600 font-bold text-sm mt-1.5">$87</p>
                          <p class="text-xs text-neutral-400 mt-0.5">45–60 min</p>
                        </div>
                      </label>
                    </div>
                  </div>

                  <div>
                    <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-neutral-400 mb-3">Advanced Treatments</p>
                    <div class="space-y-2">

                      <label class="cursor-pointer block">
                        <input type="radio" name="service" value="vampire-facial-prp" class="sr-only peer" />
                        <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                          <p class="font-semibold text-sm text-neutral-900">Vampire Facial (PRP)</p>
                          <p class="text-primary-600 font-bold text-sm mt-1.5">$380</p>
                          <p class="text-xs text-neutral-400 mt-0.5">75 min</p>
                        </div>
                      </label>

                      <label class="cursor-pointer block">
                        <input type="radio" name="service" value="scalp-therapy" class="sr-only peer" />
                        <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                          <p class="font-semibold text-sm text-neutral-900">Scalp Therapy</p>
                          <p class="text-primary-600 font-bold text-sm mt-1.5">$219</p>
                          <p class="text-xs text-neutral-400 mt-0.5">60 min</p>
                        </div>
                      </label>

                      <label class="cursor-pointer block">
                        <input type="radio" name="service" value="hairline-restoration" class="sr-only peer" />
                        <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                          <p class="font-semibold text-sm text-neutral-900">Hairline Restoration</p>
                          <p class="text-primary-600 font-bold text-sm mt-1.5">$680</p>
                          <p class="text-xs text-neutral-400 mt-0.5">2–3 sessions</p>
                        </div>
                      </label>

                    </div>
                  </div>
                </div>

                <!-- Seasonal Face & Body Packages -->
                <div>
                  <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-neutral-400 mb-3">Seasonal Face &amp; Body Packages</p>
                  <p class="text-xs text-neutral-500 mb-3">2 sessions (60 min each) with a 15-min break &mdash; approx. 2 hrs 15 min total.</p>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">

                    <label class="cursor-pointer">
                      <input type="radio" name="service" value="lash-body-smooth" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Lash &amp; Body Smooth</p>
                        <p class="text-xs text-neutral-500 mt-0.5">Lash Extensions + Body Waxing</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$185</p>
                        <p class="text-xs text-neutral-400 mt-0.5">~2 hrs 15 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="radio" name="service" value="brow-lash-wax-ritual" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Brow, Lash &amp; Wax Ritual</p>
                        <p class="text-xs text-neutral-500 mt-0.5">Lash Lift + Brow Lamination + Waxing</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$115</p>
                        <p class="text-xs text-neutral-400 mt-0.5">~2 hrs 15 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="radio" name="service" value="glow-smooth-escape" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Glow &amp; Smooth Escape</p>
                        <p class="text-xs text-neutral-500 mt-0.5">Dermaplane Facial + Body Waxing</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$135</p>
                        <p class="text-xs text-neutral-400 mt-0.5">~2 hrs 15 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="radio" name="service" value="mix-match-package" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Mix &amp; Match Escape</p>
                        <p class="text-xs text-neutral-500 mt-0.5">Waxing + Lash Lift, Lash Ext, or Facial</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">From $129</p>
                        <p class="text-xs text-neutral-400 mt-0.5">~2 hrs 15 min</p>
                      </div>
                    </label>

                  </div>
                </div>

                <!-- Other -->
                <label class="cursor-pointer inline-block">
                  <input type="radio" name="service" value="other" class="sr-only peer" />
                  <div class="rounded-xl border-2 border-neutral-200 px-5 py-3.5 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                    <p class="font-semibold text-sm text-neutral-900">Other / Not Sure</p>
                    <p class="text-primary-600 font-bold text-sm mt-1">$1</p>
                    <p class="text-xs text-neutral-400 mt-0.5">Describe in the notes section below</p>
                  </div>
                </label>

              </div>
            </div>

            <!-- Date -->
            <div>
              <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3 mb-5">Preferred Date *</h2>
              <div class="flex items-start gap-2.5 bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 mb-4">
                <svg class="w-4 h-4 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-sm text-amber-800">Appointments must be booked at least <strong>24 hours in advance</strong>. Same-day bookings are not available.</p>
              </div>
              <input type="date" id="bookingDate" name="date" required
                class="px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
            </div>

            <!-- Time Picker -->
            <div>
              <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3 mb-5">Preferred Time *</h2>
              <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-2">
                {[
                  ['10:00am','10:00 AM'],
                  ['10:30am','10:30 AM'],
                  ['11:00am','11:00 AM'],
                  ['11:30am','11:30 AM'],
                  ['12:00pm','12:00 PM'],
                  ['12:30pm','12:30 PM'],
                  ['1:00pm', '1:00 PM'],
                  ['1:30pm', '1:30 PM'],
                  ['2:00pm', '2:00 PM'],
                  ['2:30pm', '2:30 PM'],
                  ['3:00pm', '3:00 PM'],
                  ['3:30pm', '3:30 PM'],
                  ['4:00pm', '4:00 PM'],
                  ['4:30pm', '4:30 PM'],
                  ['5:00pm', '5:00 PM'],
                  ['5:30pm', '5:30 PM'],
                  ['6:00pm', '6:00 PM'],
                  ['6:30pm', '6:30 PM'],
                  ['7:00pm', '7:00 PM'],
                ].map(([value, label]) => (
                  <label class="cursor-pointer">
                    <input type="radio" name="timeslot" value={value} class="sr-only peer" required />
                    <div class="text-center rounded-lg border-2 border-neutral-200 py-3 px-1 text-sm font-medium peer-checked:border-primary-600 peer-checked:bg-primary-600 peer-checked:text-white hover:border-primary-300 transition-all">
                      {label}
                    </div>
                  </label>
                ))}
              </div>
              <p class="text-xs text-neutral-400 mt-3">Mon–Fri 10 AM – 7 PM &middot; Sat 10 AM – 6 PM &middot; Sun by request</p>
            </div>

            <!-- Notes -->
            <div>
              <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3 mb-5">Additional Notes</h2>
              <textarea id="bookingNotes" name="notes" rows="4" placeholder="Skin concerns, allergies, questions, or anything else we should know..."
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm resize-none"></textarea>
            </div>

            <!-- Discount Eligibility -->
            <div>
              <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3 mb-2">Discount Eligibility</h2>
              <p class="text-sm text-neutral-500 mb-4">We're proud to offer savings to those who serve our community. Select a category if applicable — valid ID or credentials will be verified at your appointment.</p>
              <div class="space-y-2">

                <label class="flex items-center gap-4 p-4 rounded-xl border-2 border-neutral-200 cursor-pointer hover:border-neutral-300 transition-all has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                  <input type="radio" name="discount" value="none" checked class="w-4 h-4 accent-primary-600 shrink-0" />
                  <p class="text-sm font-medium text-neutral-700">No discount — standard rate applies</p>
                </label>

                <label class="flex items-start gap-4 p-4 rounded-xl border-2 border-neutral-200 cursor-pointer hover:border-primary-300 transition-all has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                  <input type="radio" name="discount" value="first-responder-veteran" class="w-4 h-4 accent-primary-600 shrink-0 mt-0.5" />
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-3 mb-1.5">
                      <p class="text-sm font-semibold text-neutral-900">First Responder / Veteran</p>
                      <span class="shrink-0 text-xs font-bold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2.5 py-1 rounded-lg">15% off</span>
                    </div>
                    <p class="text-xs text-neutral-500">Active or retired military, police, fire, EMT, paramedic</p>
                    <div class="mt-2 flex items-start gap-1.5">
                      <svg class="w-3.5 h-3.5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                      <p class="text-xs text-amber-700"><span class="font-semibold">Proof required:</span> Military ID, DD-214, badge, or official department ID. Must be presented at appointment.</p>
                    </div>
                  </div>
                </label>

                <label class="flex items-start gap-4 p-4 rounded-xl border-2 border-neutral-200 cursor-pointer hover:border-primary-300 transition-all has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                  <input type="radio" name="discount" value="teacher-educator" class="w-4 h-4 accent-primary-600 shrink-0 mt-0.5" />
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-3 mb-1.5">
                      <p class="text-sm font-semibold text-neutral-900">Teacher / Educator</p>
                      <span class="shrink-0 text-xs font-bold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2.5 py-1 rounded-lg">10% off</span>
                    </div>
                    <p class="text-xs text-neutral-500">K–12, college, university, or licensed childcare professional</p>
                    <div class="mt-2 flex items-start gap-1.5">
                      <svg class="w-3.5 h-3.5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                      <p class="text-xs text-amber-700"><span class="font-semibold">Proof required:</span> School-issued ID, pay stub, or official employment letter. Must be presented at appointment.</p>
                    </div>
                  </div>
                </label>

                <label class="flex items-start gap-4 p-4 rounded-xl border-2 border-neutral-200 cursor-pointer hover:border-primary-300 transition-all has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                  <input type="radio" name="discount" value="senior-65-plus" class="w-4 h-4 accent-primary-600 shrink-0 mt-0.5" />
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-3 mb-1.5">
                      <p class="text-sm font-semibold text-neutral-900">Senior</p>
                      <span class="shrink-0 text-xs font-bold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2.5 py-1 rounded-lg">10% off</span>
                    </div>
                    <p class="text-xs text-neutral-500">Age 65 and older</p>
                    <div class="mt-2 flex items-start gap-1.5">
