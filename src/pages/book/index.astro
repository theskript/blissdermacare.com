---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Book an Appointment – Bliss Dermacare" description="Request a skincare appointment at Bliss Dermacare in Pebble Creek, FL. Choose your service, preferred date and time, and we'll confirm within 24 hours.">

  <!-- Page Header -->
  <section class="py-14 bg-[#faf9f7] border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-4 block">Schedule Your Visit</span>
      <h1 class="text-5xl font-serif text-neutral-900 mb-4">Book an Appointment</h1>
      <p class="text-lg text-neutral-600">Fill out the form below. We'll confirm your appointment by phone, text, or email within 24 hours.</p>
    </div>
  </section>

  <!-- Booking Form Section -->
  <section class="py-14 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-3 gap-10">

        <!-- Form -->
        <div class="lg:col-span-2">
          <form
            name="appointment-booking"
            method="POST"
            data-netlify="true"
            action="/book/?submitted=booking"
            class="space-y-6"
          >
            <input type="hidden" name="form-name" value="appointment-booking" />

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="bookingName" class="block text-sm font-medium text-neutral-700 mb-1.5">Full Name *</label>
                <input type="text" id="bookingName" name="name" required placeholder="Jane Smith"
                  class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
              </div>
              <div>
                <label for="bookingPhone" class="block text-sm font-medium text-neutral-700 mb-1.5">Phone Number *</label>
                <input type="tel" id="bookingPhone" name="phone" required placeholder="(813) 555-0100"
                  class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
              </div>
            </div>

            <div>
              <label for="bookingEmail" class="block text-sm font-medium text-neutral-700 mb-1.5">Email Address *</label>
              <input type="email" id="bookingEmail" name="email" required placeholder="jane@example.com"
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
            </div>

            <div>
              <label for="bookingService" class="block text-sm font-medium text-neutral-700 mb-1.5">Service Requested *</label>
              <select id="bookingService" name="service" required
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm bg-white">
                <option value="">Choose a service...</option>
                <optgroup label="Facials">
                  <option value="signature-radiance-facial">Signature Radiance Facial — $99</option>
                  <option value="age-defying-renewal">Age-Defying Renewal — $149</option>
                  <option value="brightening-peel">Brightening Peel — $128</option>
                  <option value="clear-skin-treatment">Clear Skin Treatment — $111</option>
                  <option value="diamond-glow">Diamond Glow — $115</option>
                  <option value="teen-skincare-facial">Teen Skincare Facial — $64</option>
                </optgroup>
                <optgroup label="Lash & Brow">
                  <option value="lash-extensions">Lash Extensions — $153</option>
                  <option value="lash-extensions-fill">Lash Extensions Fill — $43</option>
                  <option value="lash-lift-brow-lamination">Lash Lift & Brow Lamination — $72</option>
                </optgroup>
                <optgroup label="Body & Wax">
                  <option value="body-waxing">Body Waxing — $45</option>
                </optgroup>
                <optgroup label="Advanced Treatments">
                  <option value="vampire-facial-prp">Vampire Facial (PRP) — $380</option>
                  <option value="scalp-therapy">Scalp Therapy — $213</option>
                  <option value="hairline-restoration">Hairline Restoration — $680</option>
                </optgroup>
                <optgroup label="Packages">
                  <option value="fresh-start-collection">Fresh Start Collection (3 sessions) — $280</option>
                  <option value="radiant-glow-ritual">Radiant Glow Ritual (6 sessions) — $665</option>
                  <option value="ultimate-transformation">Ultimate Transformation (12 sessions) — $1,425</option>
                  <option value="luxury-in-home">Luxury In-Home Experience — $170</option>
                </optgroup>
                <option value="other">Other / Not Sure</option>
              </select>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="bookingDate" class="block text-sm font-medium text-neutral-700 mb-1.5">Preferred Date *</label>
                <input type="date" id="bookingDate" name="date" required
                  class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
              </div>
              <div>
                <label for="bookingTimeslot" class="block text-sm font-medium text-neutral-700 mb-1.5">Preferred Time *</label>
                <select id="bookingTimeslot" name="timeslot" required
                  class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm bg-white">
                  <option value="">Select a time...</option>
                  <option value="10:00am">10:00 AM</option>
                  <option value="10:30am">10:30 AM</option>
                  <option value="11:00am">11:00 AM</option>
                  <option value="11:30am">11:30 AM</option>
                  <option value="12:00pm">12:00 PM</option>
                  <option value="12:30pm">12:30 PM</option>
                  <option value="1:00pm">1:00 PM</option>
                  <option value="1:30pm">1:30 PM</option>
                  <option value="2:00pm">2:00 PM</option>
                  <option value="2:30pm">2:30 PM</option>
                  <option value="3:00pm">3:00 PM</option>
                  <option value="3:30pm">3:30 PM</option>
                  <option value="4:00pm">4:00 PM</option>
                  <option value="4:30pm">4:30 PM</option>
                  <option value="5:00pm">5:00 PM</option>
                  <option value="5:30pm">5:30 PM</option>
                  <option value="6:00pm">6:00 PM</option>
                  <option value="6:30pm">6:30 PM</option>
                  <option value="7:00pm">7:00 PM</option>
                </select>
              </div>
            </div>

            <div>
              <label for="bookingNotes" class="block text-sm font-medium text-neutral-700 mb-1.5">Skin Concerns or Notes</label>
              <textarea id="bookingNotes" name="notes" rows="4" placeholder="Tell us about your skin concerns, allergies, or any questions you have..."
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm resize-none"></textarea>
            </div>

            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-2">How would you like us to confirm? *</label>
              <div class="flex flex-wrap gap-4">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="confirm-phone" value="yes" class="w-4 h-4 accent-primary-600" />
                  <span class="text-sm text-neutral-700">Phone call</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="confirm-text" value="yes" class="w-4 h-4 accent-primary-600" />
                  <span class="text-sm text-neutral-700">Text message</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="confirm-email" value="yes" class="w-4 h-4 accent-primary-600" />
                  <span class="text-sm text-neutral-700">Email</span>
                </label>
              </div>
            </div>

            <button type="submit"
              class="w-full bg-primary-600 text-white py-4 px-6 rounded-xl hover:bg-primary-700 transition-all font-semibold text-base shadow-sm hover:shadow-md">
              Request Appointment
            </button>

            <p class="text-xs text-neutral-500 text-center">This is a booking request — not an instant confirmation. We'll reach out within 24 hours to confirm your slot.</p>
          </form>
        </div>

        <!-- Sidebar -->
        <div class="space-y-5">
          <div class="bg-[#faf9f7] rounded-2xl p-6 border border-neutral-100">
            <h3 class="font-semibold text-neutral-900 mb-4">Appointment Hours</h3>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between"><span class="text-neutral-600">Monday – Friday</span><span class="font-medium text-neutral-900">10:00 AM – 7:00 PM</span></div>
              <div class="flex justify-between"><span class="text-neutral-600">Saturday</span><span class="font-medium text-neutral-900">10:00 AM – 6:00 PM</span></div>
              <div class="flex justify-between"><span class="text-neutral-600">Sunday</span><span class="font-medium text-neutral-900">By request</span></div>
            </div>
            <div class="mt-4 pt-4 border-t border-neutral-200 text-xs text-neutral-500">
              Last appointment starts at 7:00 PM on weekdays, 6:00 PM on Saturdays.
            </div>
          </div>

          <div class="bg-white rounded-2xl p-6 border border-neutral-200">
            <h3 class="font-semibold text-neutral-900 mb-4">Location</h3>
            <p class="text-sm text-neutral-600 mb-1">Bliss Dermacare Studio</p>
            <p class="text-sm text-neutral-900 font-medium">Pebble Creek, FL 33544</p>
            <p class="text-xs text-neutral-500 mt-2">Exact address provided upon booking confirmation.</p>
          </div>

          <div class="bg-neutral-900 rounded-2xl p-6 text-white">
            <h3 class="font-semibold mb-3">Can't find the right time?</h3>
            <p class="text-sm text-neutral-400 mb-4">Reach out directly and we'll work something out.</p>
            <a href="tel:+18138101304" class="flex items-center gap-2 text-primary-400 hover:text-primary-300 text-sm font-medium transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              (813) 810-1304
            </a>
          </div>

          <div class="bg-primary-50 rounded-2xl p-6 border border-primary-100">
            <h3 class="font-semibold text-neutral-900 mb-2">Not sure what to book?</h3>
            <p class="text-sm text-neutral-600 mb-4">Take our free skin consultation first. We'll recommend the right treatment for your skin type and goals.</p>
            <a href="/consultation/" class="inline-block text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">Free Consultation &rarr;</a>
          </div>

          <div class="bg-white rounded-2xl p-6 border border-neutral-200">
            <h3 class="font-semibold text-neutral-900 mb-3">Payment Methods</h3>
            <div class="flex flex-wrap gap-2">
              <span class="text-xs bg-neutral-100 text-neutral-700 px-3 py-1.5 rounded-full font-medium">Visa</span>
              <span class="text-xs bg-neutral-100 text-neutral-700 px-3 py-1.5 rounded-full font-medium">Mastercard</span>
              <span class="text-xs bg-neutral-100 text-neutral-700 px-3 py-1.5 rounded-full font-medium">Amex</span>
              <span class="text-xs bg-neutral-100 text-neutral-700 px-3 py-1.5 rounded-full font-medium">Cash</span>
              <span class="text-xs bg-neutral-100 text-neutral-700 px-3 py-1.5 rounded-full font-medium">Zelle</span>
              <span class="text-xs bg-neutral-100 text-neutral-700 px-3 py-1.5 rounded-full font-medium">Venmo</span>
              <span class="text-xs bg-neutral-100 text-neutral-700 px-3 py-1.5 rounded-full font-medium">Apple Pay</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
