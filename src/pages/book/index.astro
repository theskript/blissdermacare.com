---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Book an Appointment – Bliss Dermacare" description="Request a skincare appointment at Bliss Dermacare in Tampa, FL. Choose your service, preferred date and time, and we'll confirm your appointment shortly.">

  <!-- Page Header -->
  <section class="py-14 bg-[#faf9f7] border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-4 block">Schedule Your Visit</span>
      <h1 class="text-5xl font-serif text-neutral-900 mb-4">Book an Appointment</h1>
      <p class="text-lg text-neutral-600">Choose your service and a time that works for you. Same-day bookings are welcome!</p>
    </div>
  </section>

  <!-- Membership Upsell Banner -->
  <section class="bg-gradient-to-r from-primary-600 to-rose-600 text-white py-4 px-6">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <svg class="w-5 h-5 text-rose-200 shrink-0 hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
        <div>
          <p class="font-semibold text-sm">Book monthly and save up to $132 with a Bliss Membership</p>
          <p class="text-xs text-rose-200 hidden sm:block">Monthly facial + lash + body credits, priority booking, and up to 20% off. Cancel anytime.</p>
        </div>
      </div>
      <a href="/memberships/" class="shrink-0 bg-white text-primary-700 px-4 py-2 rounded-full text-xs font-bold hover:bg-rose-50 transition-colors whitespace-nowrap shadow-sm">
        See Membership Plans →
      </a>
    </div>
  </section>

  <!-- Booking Form -->
  <section class="py-14 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-3 gap-10">

        <!-- Form -->
        <div class="lg:col-span-2">

          <!-- Cart Pre-fill Banner -->
          <div id="cart-prefill-banner" class="hidden mb-6 items-start gap-3 bg-primary-50 border border-primary-200 rounded-xl px-4 py-3">
            <svg class="w-5 h-5 text-primary-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-primary-800"><span id="cart-prefill-count">Your services</span> from your saved list have been pre-selected.</p>
              <p class="text-xs text-primary-600 mt-0.5">Review your selections below, pick a date &amp; time, then submit to request your booking.</p>
            </div>
            <button onclick="document.getElementById('cart-prefill-banner').classList.remove('flex');document.getElementById('cart-prefill-banner').classList.add('hidden')" class="text-primary-400 hover:text-primary-600 transition-colors shrink-0 text-lg leading-none">&times;</button>
          </div>

          <form
            id="booking-form"
            name="appointment-booking"
            class="space-y-10"
            novalidate
          >

            <!-- Contact -->
            <div class="space-y-5">
              <h2 class="text-lg font-semibold text-neutral-900 border-b border-neutral-100 pb-3">Your Details</h2>
              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="bookingName" class="block text-sm font-medium text-neutral-700 mb-1.5">Full Name *</label>
                  <input type="text" id="bookingName" name="name" required placeholder="Jane Smith"
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
                </div>
                <div>
                  <label for="bookingPhone" class="block text-sm font-medium text-neutral-700 mb-1.5">Phone Number *</label>
                  <input type="tel" id="bookingPhone" name="phone" required placeholder="(609) 366-0857"
                    class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
                </div>
              </div>
              <div>
                <label for="bookingEmail" class="block text-sm font-medium text-neutral-700 mb-1.5">Email Address *</label>
                <input type="email" id="bookingEmail" name="email" required placeholder="jane@example.com"
                  class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
              </div>
            </div>

            <!-- Service Picker -->
            <div>
              <div class="border-b border-neutral-100 pb-3 mb-4 flex items-end justify-between gap-3">
                <h2 class="text-lg font-semibold text-neutral-900">Choose Your Services *</h2>
                <div id="duration-tracker" class="hidden items-center gap-2 pb-0.5">
                  <span id="duration-text" class="text-xs font-medium text-neutral-400 tabular-nums whitespace-nowrap">0 / 120 min</span>
                  <div class="h-1.5 bg-neutral-200 rounded-full w-20 overflow-hidden">
                    <div id="duration-bar" class="h-full bg-primary-500 rounded-full transition-all duration-200" style="width:0%"></div>
                  </div>
                </div>
              </div>
              <p class="text-sm text-neutral-500 mb-5">Select one or more services. <strong class="text-neutral-700">2-hour max</strong> for combined individual services. Packages are standalone bookings.</p>
              <div class="space-y-6">

                <!-- Facials -->
                <div>
                  <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-neutral-400 mb-3">Facials</p>
                  <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="signature-radiance-facial" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Signature Radiance Facial</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$99</p>
                        <p class="text-xs text-neutral-400 mt-0.5">60 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="brightening-peel" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Brightening Peel</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$128</p>
                        <p class="text-xs text-neutral-400 mt-0.5">45 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="diamond-glow" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Diamond Glow</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$119</p>
                        <p class="text-xs text-neutral-400 mt-0.5">50 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="high-frequency-skin-tightening" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">High Frequency Skin Tightening</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$95</p>
                        <p class="text-xs text-neutral-400 mt-0.5">45 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="teen-skincare-facial" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Teen Skincare Facial</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$64</p>
                        <p class="text-xs text-neutral-400 mt-0.5">45 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="pumpkin-enzyme-facial" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Pumpkin Enzyme Facial</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$85</p>
                        <p class="text-xs text-neutral-400 mt-0.5">60 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="chlorophyll-skin-tightening-facial" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Chlorophyll Skin Tightening Facial</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$105</p>
                        <p class="text-xs text-neutral-400 mt-0.5">60 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="pineapple-enzyme-facial" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Pineapple Enzyme Facial</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$88</p>
                        <p class="text-xs text-neutral-400 mt-0.5">60 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="skin-recovery-facial" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Skin Recovery Facial</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$92</p>
                        <p class="text-xs text-neutral-400 mt-0.5">60 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="dermaplane-glow-facial" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-amber-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-amber-300 transition-all h-full relative">
                        <span class="absolute top-2 right-2 text-[10px] font-bold bg-amber-500 text-white px-2 py-0.5 rounded-full">NEW</span>
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Dermaplane Glow Facial</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$105</p>
                        <p class="text-xs text-neutral-400 mt-0.5">60 min</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="smooth-canvas-facial" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-amber-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-amber-300 transition-all h-full relative">
                        <span class="absolute top-2 right-2 text-[10px] font-bold bg-amber-500 text-white px-2 py-0.5 rounded-full">NEW</span>
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Smooth Canvas Facial</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$89</p>
                        <p class="text-xs text-neutral-400 mt-0.5">45 min</p>
                      </div>
                    </label>

                  </div>
                </div>

                <!-- Lash & Brow -->
                <div>
                  <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-neutral-400 mb-3">Lash &amp; Brow</p>
                  <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="lash-extensions" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Lash Extensions</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$159</p>
                        <p class="text-xs text-neutral-400 mt-0.5">2 hr</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="lash-extensions-fill" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Lash Extensions Fill</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$43</p>
                        <p class="text-xs text-neutral-400 mt-0.5">1 hr</p>
                      </div>
                    </label>

                    <label class="cursor-pointer">
                      <input type="checkbox" name="service" value="lash-lift-brow-lamination" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all h-full">
                        <p class="font-semibold text-sm text-neutral-900 leading-snug">Lash Lift &amp; Brow Lamination</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$79</p>
                        <p class="text-xs text-neutral-400 mt-0.5">60 min</p>
                      </div>
                    </label>

                  </div>
                </div>

                <!-- Body & Advanced -->
                <div class="grid sm:grid-cols-2 gap-6">

                  <div>
                    <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-neutral-400 mb-3">Body Treatments</p>
                    <div class="flex items-start gap-2 mb-3 p-2.5 bg-amber-50 border border-amber-200 rounded-lg">
                      <svg class="w-3.5 h-3.5 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4v2m0 4v2m0-14a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      <p class="text-xs text-amber-800"><strong>Age 21+</strong> required for waxing services only</p>
                    </div>
                    <div class="space-y-2">
                      <label class="cursor-pointer block">
                        <input type="checkbox" name="service" value="body-and-face-waxing" class="sr-only peer" />
                        <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                          <p class="font-semibold text-sm text-neutral-900">Body &amp; Face Waxing</p>
                          <p class="text-xs text-neutral-600 mt-1">Facial, arms, legs, underarms</p>
                          <p class="text-primary-600 font-bold text-sm mt-1.5">$65</p>
                          <p class="text-xs text-neutral-400 mt-0.5">45–60 min</p>
                        </div>
                      </label>

                      <label class="cursor-pointer block">
                        <input type="checkbox" name="service" value="brazilian-wax" class="sr-only peer" />
                        <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                          <p class="font-semibold text-sm text-neutral-900">Brazilian Wax</p>
                          <p class="text-xs text-neutral-600 mt-1">Complete bikini area hair removal</p>
                          <p class="text-primary-600 font-bold text-sm mt-1.5">$87</p>
                          <p class="text-xs text-neutral-400 mt-0.5">45–60 min</p>
                        </div>
                      </label>

                      <label class="cursor-pointer block">
                        <input type="checkbox" name="service" value="spray-tan" class="sr-only peer" />
                        <div class="rounded-xl border-2 border-amber-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-amber-300 transition-all relative">
                          <span class="absolute top-2 right-2 text-[10px] font-bold bg-amber-500 text-white px-2 py-0.5 rounded-full">NEW</span>
                          <p class="font-semibold text-sm text-neutral-900">Custom Airbrush Spray Tan</p>
                          <p class="text-xs text-neutral-600 mt-1">Streak-free, custom bronze glow &mdash; no age restriction</p>
                          <p class="text-primary-600 font-bold text-sm mt-1.5">$65</p>
                          <p class="text-xs text-neutral-400 mt-0.5">30–45 min</p>
                        </div>
                      </label>
                    </div>
                  </div>

                  <div>
                    <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-neutral-400 mb-3">Advanced Treatments</p>
                    <div class="space-y-2">

                      <label class="cursor-pointer block">
                        <input type="checkbox" name="service" value="vampire-facial-prp" class="sr-only peer" />
                        <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                          <p class="font-semibold text-sm text-neutral-900">Vampire Facial (PRP)</p>
                          <p class="text-primary-600 font-bold text-sm mt-1.5">$380</p>
                          <p class="text-xs text-neutral-400 mt-0.5">75 min</p>
                        </div>
                      </label>



                    </div>
                  </div>
                </div>

                <!-- Advanced Treatments (New Clinical Services) -->
                <div>
                  <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-neutral-400 mb-3">Advanced Treatments</p>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">

                    <label class="cursor-pointer block">
                      <input type="checkbox" name="service" value="prp-treatment" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                        <p class="font-semibold text-sm text-neutral-900">PRP (Platelet-Rich Plasma)</p>
                        <p class="text-xs text-neutral-600 mt-1">Skin rejuvenation &amp; collagen stimulation</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$399</p>
                        <p class="text-xs text-neutral-400 mt-0.5">60 min / session</p>
                      </div>
                    </label>

                    <label class="cursor-pointer block">
                      <input type="checkbox" name="service" value="lip-filler" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                        <p class="font-semibold text-sm text-neutral-900">Lip Filler</p>
                        <p class="text-xs text-neutral-600 mt-1">Hyaluronic acid — natural enhancement</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$599</p>
                        <p class="text-xs text-neutral-400 mt-0.5">45 min / syringe</p>
                      </div>
                    </label>

                    <label class="cursor-pointer block">
                      <input type="checkbox" name="service" value="ed-injectables" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                        <p class="font-semibold text-sm text-neutral-900">ED Injectables</p>
                        <p class="text-xs text-neutral-600 mt-1">Erectile dysfunction injectable therapy</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$499</p>
                        <p class="text-xs text-neutral-400 mt-0.5">60 min / session</p>
                      </div>
                    </label>

                    <label class="cursor-pointer block">
                      <input type="checkbox" name="service" value="collagen-induction-therapy" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                        <p class="font-semibold text-sm text-neutral-900">Collagen Induction Therapy</p>
                        <p class="text-xs text-neutral-600 mt-1">Precision microneedling for skin renewal</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$299</p>
                        <p class="text-xs text-neutral-400 mt-0.5">60 min / session</p>
                      </div>
                    </label>

                    <label class="cursor-pointer block">
                      <input type="checkbox" name="service" value="weight-loss-program" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                        <p class="font-semibold text-sm text-neutral-900">Weight Loss Program</p>
                        <p class="text-xs text-neutral-600 mt-1">GLP-1 / Semiglutide assisted, monthly</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$299</p>
                        <p class="text-xs text-neutral-400 mt-0.5">/month · incl. consultation</p>
                      </div>
                    </label>

                  </div>
                </div>

                <!-- Semipermanent Makeup -->
                <div>
                  <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-neutral-400 mb-3">Semipermanent Makeup</p>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">

                    <label class="cursor-pointer block">
                      <input type="checkbox" name="service" value="scalp-micropigmentation" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                        <p class="font-semibold text-sm text-neutral-900">Scalp Micropigmentation</p>
                        <p class="text-xs text-neutral-600 mt-1">SMP for density or shaved-head look</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$650</p>
                        <p class="text-xs text-neutral-400 mt-0.5">3 hr / session · 2–3 sessions</p>
                      </div>
                    </label>

                    <label class="cursor-pointer block">
                      <input type="checkbox" name="service" value="lip-neutralization" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                        <p class="font-semibold text-sm text-neutral-900">Lip Neutralization</p>
                        <p class="text-xs text-neutral-600 mt-1">Correct dark or uneven lip pigmentation</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$399</p>
                        <p class="text-xs text-neutral-400 mt-0.5">2 hr / session</p>
                      </div>
                    </label>

                    <label class="cursor-pointer block">
                      <input type="checkbox" name="service" value="lip-blush" class="sr-only peer" />
                      <div class="rounded-xl border-2 border-neutral-200 p-4 peer-checked:border-primary-500 peer-checked:bg-primary-50 hover:border-primary-300 transition-all">
                        <p class="font-semibold text-sm text-neutral-900">Lip Blush</p>
                        <p class="text-xs text-neutral-600 mt-1">Soft color &amp; definition, naturally blended</p>
                        <p class="text-primary-600 font-bold text-sm mt-1.5">$499</p>
                        <p class="text-xs text-neutral-400 mt-0.5">2 hr / session</p>
                      </div>
