---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Payment Cancelled – Bliss Dermacare"
  description="Your payment was not completed. Return to the booking page to try again."
>
  <section class="min-h-[70vh] flex items-center justify-center py-20 bg-[#faf9f7]">
    <div class="max-w-lg mx-auto px-6 text-center">

      <div class="w-20 h-20 rounded-full bg-neutral-100 flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </div>

      <h1 class="text-4xl font-serif text-neutral-900 mb-3">Payment Cancelled</h1>
      <p class="text-lg text-neutral-600 mb-8">No charge was made. You can go back and try again whenever you're ready.</p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/book/" class="px-6 py-3 bg-primary-600 text-white rounded-xl font-semibold text-sm hover:bg-primary-700 transition-all">Try Again</a>
        <a href="/" class="px-6 py-3 bg-white border border-neutral-300 text-neutral-700 rounded-xl font-semibold text-sm hover:border-neutral-400 transition-all">Back to Home</a>
      </div>

      <p class="text-xs text-neutral-500 mt-8">
        Need help? Call us at <a href="tel:+18135346839" class="text-primary-600 hover:text-primary-700 font-medium">(813) 534-6839</a>
      </p>

    </div>
  </section>
</Layout>
