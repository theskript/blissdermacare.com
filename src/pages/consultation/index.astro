---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Free Consultation – Bliss Dermacare" description="Book a free skincare consultation at Bliss Dermacare. Tell us about your skin concerns and we'll build a personalized treatment plan — no commitment required.">

  <!-- Page Header -->
  <section class="py-14 bg-[#faf9f7] border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="text-primary-600 uppercase tracking-[0.2em] text-xs font-semibold mb-4 block">No Commitment. No Charge.</span>
      <h1 class="text-5xl font-serif text-neutral-900 mb-4">Free Skin Consultation</h1>
      <p class="text-lg text-neutral-600">Tell us about your skin and goals. We'll reach out with a personalized plan — no pressure, no obligation.</p>
    </div>
  </section>

  <!-- Form Section -->
  <section class="py-14 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid lg:grid-cols-5 gap-10">

        <!-- Form -->
        <div class="lg:col-span-3">
          <form
            name="skincare-consultation"
            method="POST"
            data-netlify="true"
            action="/consultation/?submitted=consultation"
            class="space-y-5"
          >
            <input type="hidden" name="form-name" value="skincare-consultation" />

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="consultName" class="block text-sm font-medium text-neutral-700 mb-1.5">Full Name *</label>
                <input type="text" id="consultName" name="name" required placeholder="Jane Smith"
                  class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
              </div>
              <div>
                <label for="consultPhone" class="block text-sm font-medium text-neutral-700 mb-1.5">Phone Number *</label>
                <input type="tel" id="consultPhone" name="phone" required placeholder="(609) 366-0857"
                  class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
              </div>
            </div>

            <div>
              <label for="consultEmail" class="block text-sm font-medium text-neutral-700 mb-1.5">Email Address *</label>
              <input type="email" id="consultEmail" name="email" required placeholder="jane@example.com"
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm" />
            </div>

            <div>
              <label for="consultSkinType" class="block text-sm font-medium text-neutral-700 mb-1.5">Skin Type *</label>
              <select id="consultSkinType" name="skin-type" required
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm bg-white">
                <option value="">Select your skin type...</option>
                <option value="normal">Normal</option>
                <option value="dry">Dry</option>
                <option value="oily">Oily</option>
                <option value="combination">Combination</option>
                <option value="sensitive">Sensitive</option>
                <option value="mature">Mature</option>
                <option value="not-sure">Not Sure</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-2">Primary Skin Concerns (select all that apply)</label>
              <div class="grid grid-cols-2 gap-2">
                {[
                  'Acne / Breakouts',
                  'Signs of Aging',
                  'Dark Spots / Hyperpigmentation',
                  'Uneven Texture',
                  'Dryness / Dehydration',
                  'Redness / Sensitivity',
                  'Dull / Tired Skin',
                  'Large Pores',
                  'Scarring',
                  'Hair / Scalp Issues'
                ].map(concern => (
                  <label class="flex items-center gap-2 cursor-pointer text-sm text-neutral-600 py-1">
                    <input type="checkbox" name="concerns" value={concern.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')} class="w-4 h-4 accent-primary-600 flex-shrink-0" />
                    {concern}
                  </label>
                ))}
              </div>
            </div>

            <div>
              <label for="consultRoutine" class="block text-sm font-medium text-neutral-700 mb-1.5">Current Skincare Routine</label>
              <textarea id="consultRoutine" name="current-routine" rows="3" placeholder="Describe your current routine (cleansers, moisturizers, serums, SPF, etc.) or write 'none' if you don't have one yet."
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm resize-none"></textarea>
            </div>

            <div>
              <label for="consultGoals" class="block text-sm font-medium text-neutral-700 mb-1.5">What do you hope to achieve? *</label>
              <textarea id="consultGoals" name="goals" required rows="4" placeholder="Tell us what you're working toward — clearer skin, anti-aging, a consistent routine, or something else entirely..."
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm resize-none"></textarea>
            </div>

            <div>
              <label for="consultContact" class="block text-sm font-medium text-neutral-700 mb-1.5">Best way to reach you *</label>
              <select id="consultContact" name="contact-preference" required
                class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm bg-white">
                <option value="">Select preferred contact method...</option>
                <option value="phone-call">Phone Call</option>
                <option value="text">Text Message</option>
                <option value="email">Email</option>
                <option value="instagram">Instagram DM</option>
              </select>
            </div>

            <button type="submit"
              class="w-full bg-primary-600 text-white py-4 px-6 rounded-xl hover:bg-primary-700 transition-all font-semibold text-base shadow-sm hover:shadow-md">
              Request Free Consultation
            </button>

            <p class="text-xs text-neutral-500 text-center">We'll review your submission and reach out within 24 hours — no sales pressure, just helpful guidance.</p>
          </form>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2 space-y-5">
          <div class="bg-primary-50 rounded-2xl p-6 border border-primary-100">
            <h3 class="font-semibold text-neutral-900 mb-4">What to expect</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-sm text-neutral-700">
                <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                We'll review your skin type and concerns
              </li>
              <li class="flex items-start gap-3 text-sm text-neutral-700">
                <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                You'll get a personalized treatment recommendation
              </li>
              <li class="flex items-start gap-3 text-sm text-neutral-700">
                <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                We'll answer any questions about services or products
              </li>
              <li class="flex items-start gap-3 text-sm text-neutral-700">
                <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Completely free — no commitment needed
              </li>
            </ul>
          </div>

          <div class="bg-neutral-900 rounded-2xl p-6 text-white">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 rounded-full bg-primary-600 flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              </div>
              <div>
                <p class="font-semibold text-sm">FL Licensed Esthetician</p>
                <p class="text-neutral-400 text-xs">7+ years experience · 5.0★ rated</p>
              </div>
            </div>
            <p class="text-neutral-400 text-sm">"My goal is to give every client a clear, honest picture of what their skin needs — not just sell them something. Start with a consultation and we'll figure it out together."</p>
          </div>

          <div class="bg-white rounded-2xl p-6 border border-neutral-200 text-center">
            <p class="text-sm text-neutral-600 mb-3">Have questions first?</p>
            <a href="/faq/" class="text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">Read the FAQ &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
